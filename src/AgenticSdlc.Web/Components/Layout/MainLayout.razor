@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS

<div class="app-shell">
    <header class="app-header">
        <div class="brand">
            <span class="brand-mark">◆</span>
            <span class="brand-text">Agentic SDLC <em>Agent Studio</em></span>
        </div>
        <div class="brand-sub">Leader · Specialists · Quality Loop — a .NET multi-agent framework</div>
        <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle light/dark theme">
            @(_theme == "light" ? "🌙 Dark" : "☀ Light")
        </button>
    </header>
    <main class="app-main">
        @Body
    </main>
</div>

@code {
    private string _theme = "light";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _theme = await JS.InvokeAsync<string>("agenticTheme.get");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
        => _theme = await JS.InvokeAsync<string>("agenticTheme.toggle");
}
