@page "/settings"
@using AgenticSdlc.Application.Configuration
@using AgenticSdlc.Domain.Llm
@inject Microsoft.Extensions.Options.IOptions<LlmOptions> LlmOpts
@inject IRuntimeOverrides Overrides
@inject Microsoft.Extensions.Configuration.IConfiguration Config

<PageTitle>Settings — Agentic SDLC</PageTitle>

<div class="page-head">
    <h1 class="page-title">Settings</h1>
    <p class="page-sub">Configure LLM providers, API keys, and the GitHub integration.</p>
</div>

<div class="card">
    <h2>Current configuration</h2>
    <table class="settings-table">
        <tbody>
            <tr><th>Default provider</th><td><code>@LlmOpts.Value.Provider</code></td></tr>
            <tr><th>Effective force provider</th><td>@EffectiveForceLabel()</td></tr>
            <tr><th>Anthropic API key</th><td>@KeyState(LlmOpts.Value.Claude.ApiKey)</td></tr>
            <tr><th>Azure OpenAI API key</th><td>@KeyState(LlmOpts.Value.AzureOpenAi.ApiKey)</td></tr>
            <tr><th>Azure OpenAI endpoint</th><td>@(string.IsNullOrEmpty(LlmOpts.Value.AzureOpenAi.Endpoint) ? "— not set —" : LlmOpts.Value.AzureOpenAi.Endpoint)</td></tr>
            <tr><th>Persistence</th><td>@(_dbConnected ? "Postgres connected" : "Stateless (no DB)")</td></tr>
        </tbody>
    </table>
</div>

<div class="card">
    <h2>Runtime overrides</h2>
    <p class="muted">Stored in memory; live for the lifetime of the server process. Permanent changes belong in <code>appsettings.json</code> or <code>dotnet user-secrets</code>.</p>

    <label class="field">
        <span>Force provider — applies to <strong>every</strong> agent regardless of its per-agent setting</span>
        <select @bind="_forceProvider">
            <option value="">— no override (use per-agent config) —</option>
            <option value="Claude">Claude (Anthropic)</option>
            <option value="AzureOpenAI">Azure OpenAI</option>
            <option value="MAF">MAF (Azure OpenAI via SDK)</option>
        </select>
    </label>

    <label class="field">
        <span>Anthropic API key</span>
        <input type="password" @bind="_anthropicKey" placeholder="sk-ant-..." />
    </label>

    <label class="field">
        <span>Azure OpenAI API key</span>
        <input type="password" @bind="_azureKey" placeholder="(Azure key)" />
    </label>

    <label class="field">
        <span>Azure OpenAI endpoint</span>
        <input type="text" @bind="_azureEndpoint" placeholder="https://your-resource.openai.azure.com" />
    </label>

    <button class="btn btn-primary" @onclick="Save">💾 Save overrides</button>
    <button class="btn btn-ghost" @onclick="Clear">Reset to appsettings</button>

    @if (_saved)
    {
        <p class="hint" style="margin-top:10px;">
            <span class="badge ok">Saved</span>
            <span class="muted">Applied to subsequent LLM calls. Return to the <a href="/">pipeline</a> to run.</span>
        </p>
    }
</div>

<div class="card">
    <h2>GitHub integration</h2>
    <p class="muted">Open a pull request with the generated code + tests to a target repo. Personal access token needs the <code>repo</code> scope.</p>

    <label class="field">
        <span>Personal access token (PAT)</span>
        <input type="password" @bind="_githubPat" placeholder="ghp_..." />
    </label>

    <label class="field">
        <span>Repo owner (user or org)</span>
        <input type="text" @bind="_repoOwner" placeholder="your-username" />
    </label>

    <label class="field">
        <span>Repo name</span>
        <input type="text" @bind="_repoName" placeholder="target-repo" />
    </label>

    <label class="field">
        <span>Base branch (default: main)</span>
        <input type="text" @bind="_baseBranch" placeholder="main" />
    </label>

    <button class="run" @onclick="SaveGithub">💾 Save GitHub settings</button>
    @if (_savedGithub)
    {
        <p class="hint" style="margin-top:10px;">
            <span class="badge ok">Saved</span>
            <span class="muted">"Open PR" button on the pipeline page will use these.</span>
        </p>
    }
</div>

<div class="card">
    <h2>Where data lives</h2>
    <ul class="clean">
        <li><strong>Pipeline results</strong>: in-memory unless <code>ConnectionStrings:DefaultConnection</code> is set → Postgres tables <code>pipeline_runs</code>, <code>run_metrics</code>, <code>orchestrations</code>.</li>
        <li><strong>API keys</strong>: persistent values live in <code>dotnet user-secrets</code> (dev) or environment variables (prod). The runtime overrides on this page are in-memory only — restart clears them. Use the form above for ad-hoc runs, or save permanently via:
            <pre class="code" style="font-size:11.5px;">cd src/AgenticSdlc.Api
dotnet user-secrets set "Llm:Claude:ApiKey"      "sk-ant-..."
dotnet user-secrets set "Llm:AzureOpenAi:ApiKey" "..."
dotnet user-secrets set "Llm:AzureOpenAi:Endpoint" "https://your-resource.openai.azure.com"</pre>
        </li>
        <li><strong>Generated code/tests</strong>: returned inline in the pipeline response; not written to disk by the agents. Real-file build/test execution is a roadmap item (sandbox runner).</li>
        <li><strong>GitHub integration</strong>: not built yet — opening a PR with the generated code is on the roadmap.</li>
    </ul>
</div>

@code {
    private string _forceProvider = "";
    private string _anthropicKey = "";
    private string _azureKey = "";
    private string _azureEndpoint = "";
    private bool _saved;
    private bool _dbConnected;

    private string _githubPat = "";
    private string _repoOwner = "";
    private string _repoName = "";
    private string _baseBranch = "";
    private bool _savedGithub;

    protected override void OnInitialized()
    {
        _forceProvider = Overrides.ForceProvider ?? "";
        _anthropicKey = Overrides.AnthropicApiKey ?? "";
        _azureKey = Overrides.AzureApiKey ?? "";
        _azureEndpoint = Overrides.AzureEndpoint ?? "";
        _dbConnected = !string.IsNullOrWhiteSpace(Config.GetConnectionString("DefaultConnection"));

        _githubPat = Overrides.GitHubPat ?? "";
        _repoOwner = Overrides.GitHubRepoOwner ?? "";
        _repoName = Overrides.GitHubRepoName ?? "";
        _baseBranch = Overrides.GitHubBaseBranch ?? "";
    }

    private void Save()
    {
        Overrides.ForceProvider = string.IsNullOrWhiteSpace(_forceProvider) ? null : _forceProvider;
        Overrides.AnthropicApiKey = string.IsNullOrWhiteSpace(_anthropicKey) ? null : _anthropicKey;
        Overrides.AzureApiKey = string.IsNullOrWhiteSpace(_azureKey) ? null : _azureKey;
        Overrides.AzureEndpoint = string.IsNullOrWhiteSpace(_azureEndpoint) ? null : _azureEndpoint;
        _saved = true;
    }

    private void Clear()
    {
        Overrides.ForceProvider = null;
        Overrides.AnthropicApiKey = null;
        Overrides.AzureApiKey = null;
        Overrides.AzureEndpoint = null;
        _forceProvider = "";
        _anthropicKey = "";
        _azureKey = "";
        _azureEndpoint = "";
        _saved = true;
    }

    private void SaveGithub()
    {
        Overrides.GitHubPat = string.IsNullOrWhiteSpace(_githubPat) ? null : _githubPat;
        Overrides.GitHubRepoOwner = string.IsNullOrWhiteSpace(_repoOwner) ? null : _repoOwner;
        Overrides.GitHubRepoName = string.IsNullOrWhiteSpace(_repoName) ? null : _repoName;
        Overrides.GitHubBaseBranch = string.IsNullOrWhiteSpace(_baseBranch) ? null : _baseBranch;
        _savedGithub = true;
    }

    private string EffectiveForceLabel()
    {
        var runtime = Overrides.ForceProvider;
        var appset = LlmOpts.Value.ForceProvider;
        if (!string.IsNullOrWhiteSpace(runtime))
        {
            return $"{runtime} (runtime override)";
        }
        if (!string.IsNullOrWhiteSpace(appset))
        {
            return $"{appset} (appsettings)";
        }
        return "— none (per-agent config) —";
    }

    private MarkupString KeyState(string key)
        => string.IsNullOrWhiteSpace(key)
            ? new MarkupString("<span class=\"badge err\">⊘ not set</span>")
            : new MarkupString("<span class=\"badge ok\">✓ set</span>");
}
