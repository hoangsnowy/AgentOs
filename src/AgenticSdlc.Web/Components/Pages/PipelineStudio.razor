@page "/"
@page "/timeline"
@using AgenticSdlc.Application.Agents
@using Microsoft.Extensions.DependencyInjection
@using AgenticSdlc.Domain.Llm
@inject IServiceProvider Sp
@inject DemoRunContext DemoCtx
@inject CircuitPipelineProgress Progress
@inject Microsoft.Extensions.Options.IOptions<LlmOptions> LlmOpts
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject AgenticSdlc.Application.Integration.IGitHubPrService GitHubPr
@implements IDisposable

<PageTitle>Agent Studio — Agentic SDLC</PageTitle>

<!-- ============ STATUS BAR (mode · persistence · settings) ============ -->
<div class="status-bar">
    <div class="status-chips">
        @if (_useDemo)
        {
            <span class="status-chip mode-demo">⚙ Demo mode <em>· offline canned data</em></span>
        }
        else
        {
            <span class="status-chip mode-live">⚡ Live · @ActiveProvider</span>
        }

        @if (_dbConnected)
        {
            <span class="status-chip db-on">🗄 Postgres connected</span>
        }
        else
        {
            <span class="status-chip db-off">⊘ Stateless (no DB)</span>
        }
    </div>
    <a class="settings-link" href="/settings" title="Configure providers + API keys">⚙ Settings →</a>
</div>

<!-- ============ ARCHITECTURE OVERVIEW ============ -->
<div class="card arch">
    <div class="arch-head">
        <div>
            <h2>Turn a user story into a reviewed code scaffold</h2>
            <p class="arch-tagline muted">Paste a story below. An <strong>Orchestrator</strong> hands it to four specialist agents (Requirement → Coding → Testing); the <strong>QA agent</strong> scores requirement–code–test consistency and loops until consistent or <code>NMax</code>. <strong>Hybrid LLM</strong>: Anthropic Claude + Azure OpenAI, one model per agent. Output: structured spec, C# code, xUnit tests + QA scorecard.</p>
        </div>
        <a class="arch-designer" href="/orchestration">Workflow designer →</a>
    </div>

    <div class="steps-row">
        <div class="step-pill"><span class="num">1</span> Paste a user story below</div>
        <div class="step-pill"><span class="num">2</span> Click <strong>Run pipeline</strong></div>
        <div class="step-pill"><span class="num">3</span> Review spec, code, tests, QA</div>
    </div>

    <div class="arch-flow">
        <div class="arch-node leader">
            <span class="an-role">◆ Orchestrator</span>
            <span class="an-tag">Leader</span>
            <span class="prov anthropic">Claude Haiku 4.5</span>
        </div>
        <span class="arch-feed">assigns ▸</span>

        <div class="arch-chain">
            <div class="arch-node"><span class="an-role">R · Requirement</span><span class="prov anthropic">Claude Sonnet 4</span></div>
            <span class="arch-arr">→</span>
            <div class="arch-node"><span class="an-role">C · Coding</span><span class="prov azure">Azure GPT-4.1</span></div>
            <span class="arch-arr">→</span>
            <div class="arch-node"><span class="an-role">T · Testing</span><span class="prov azure">Azure GPT-4o-mini</span></div>
            <span class="arch-arr">→</span>
            <div class="arch-node qa"><span class="an-role">Q · QA</span><span class="prov anthropic">Claude Haiku 4.5</span></div>
        </div>

        <span class="arch-feed">▸ aggregates</span>
        <div class="arch-node agg"><span class="an-role">Σ Aggregate</span></div>
    </div>

    <div class="arch-loop">↺ <strong>Quality Loop</strong> — when QA finds the code inconsistent with the requirement, the Orchestrator re-runs Coding → Testing → QA, up to <code>NMax</code> iterations.</div>
</div>

<div class="studio-grid">

    <!-- ============ LEFT COLUMN: CONTROLS ============ -->
    <div>
        <div class="card">
            <h2>Input</h2>

            <label class="field">
                <span>User story</span>
                <textarea @bind="_description" placeholder="E.g.: As an administrator, I want to manage products in the catalog with a unique SKU to avoid duplicates."></textarea>
            </label>

            <label class="field">
                <span>NMax (max QA iterations)</span>
                <input type="number" min="1" max="5" @bind="_nmax" />
            </label>

            <label class="toggle">
                <input type="checkbox" @bind="_useDemo" />
                Run in Demo mode (offline, no API key required)
            </label>

            <button class="run" @onclick="RunAsync" disabled="@(_running || string.IsNullOrWhiteSpace(_description))">
                @(_running ? "Running pipeline…" : "▶ Run pipeline")
            </button>
            @if (_running)
            {
                <button class="ghost" @onclick="Cancel">Cancel</button>
            }

            @if (!_useDemo)
            {
                <p class="hint">Live mode → provider <strong>@ActiveProvider</strong>. Set the API key in user-secrets. Azure-only: set <code>Llm:ForceProvider=AzureOpenAI</code> + your Azure deployment in <code>Llm:AzureOpenAi:Model</code>.</p>
            }
            else
            {
                <p class="hint">Demo mode uses sample data, runs offline, and simulates QA failing the first round → passing the next to illustrate the Quality Loop.</p>
            }
        </div>

        <div class="card">
            <h2>Aggregate metrics (realtime)</h2>
            <div class="metrics">
                <div class="metric"><div class="v">@(_tokIn + _tokOut)</div><div class="k">Tokens (@_tokIn↑ / @_tokOut↓)</div></div>
                <div class="metric"><div class="v">$@_cost.ToString("0.0000")</div><div class="k">Estimated cost</div></div>
                <div class="metric"><div class="v">@((_latencyMs / 1000.0).ToString("0.0"))s</div><div class="k">Total latency</div></div>
                <div class="metric"><div class="v">@_qaRounds.Count</div><div class="k">QA rounds</div></div>
            </div>
        </div>
    </div>

    <!-- ============ RIGHT COLUMN: PROGRESS + RESULTS ============ -->
    <div>
        <div class="card">
            <h2>Agent progress</h2>
            <div class="timeline">
                <div class="stage leader @LeaderState()">
                    <div class="dot">◆</div>
                    <div>
                        <div class="label">Orchestrator <span class="badge info">Leader</span></div>
                        <div class="sub">Assigns the user story to specialists · drives the Quality Loop</div>
                    </div>
                    <div class="meta"><span class="prov anthropic">Claude</span></div>
                </div>
                @foreach (var stage in _order)
                {
                    var row = _stages[stage];
                    <div class="stage @StateClass(row.State)">
                        <div class="dot">@_dotText[stage]</div>
                        <div>
                            <div class="label">
                                @_title[stage]
                                <span class="prov @_agentProv[stage]">@ProvName(stage)</span>
                                @if ((stage == PipelineStage.Coding || stage == PipelineStage.Testing || stage == PipelineStage.Qa)
                                     && row.State != StageState.Idle && _currentIteration > 0)
                                {
                                    <span class="badge info">round @_currentIteration</span>
                                }
                            </div>
                            <div class="sub">@(string.IsNullOrEmpty(row.Sub) ? _subtitle[stage] : row.Sub)</div>
                        </div>
                        <div class="meta">@row.Meta</div>
                    </div>
                }
            </div>

            @if (_qaRounds.Count > 0)
            {
                <div class="qa-rounds">
                    @foreach (var r in _qaRounds)
                    {
                        <div class="qa-round">
                            <span>Round @r.Iteration</span>
                            <span class="score">@r.Score.ToString("0.00")</span>
                            <span class="score-bar"><i style="width:@((int)(r.Score * 100))%"></i></span>
                            @if (r.Consistent)
                            {
                                <span class="badge ok">pass · exit loop</span>
                            }
                            else
                            {
                                <span class="badge warn">not met · repeat</span>
                            }
                        </div>
                    }
                </div>
            }

            @if (_error is not null)
            {
                <p style="margin-top:14px"><span class="badge err">Error</span> <span class="muted">@_error</span></p>
            }
            else if (_result is not null)
            {
                <p style="margin-top:14px">
                    @if (_finalStatus == PipelineStatus.Done)
                    {
                        <span class="badge ok">Complete</span>
                    }
                    else if (_finalStatus == PipelineStatus.MaxIterationReached)
                    {
                        <span class="badge warn">Iteration limit reached</span>
                    }
                    else
                    {
                        <span class="badge err">Failed</span>
                    }
                    <span class="muted"> @_result.IterationCount QA rounds · @_result.Code?.Files.Count code files · @_result.Tests?.TotalCount tests</span>
                </p>
            }
        </div>

        @if (_result is not null && _finalStatus != PipelineStatus.Failed)
        {
            <div class="card">
                <h2>Generated artifacts</h2>
                <div class="tabs">
                    <div class="tab @(_tab == 0 ? "active" : "")" @onclick="() => _tab = 0">Requirements</div>
                    <div class="tab @(_tab == 1 ? "active" : "")" @onclick="() => _tab = 1">Source code</div>
                    <div class="tab @(_tab == 2 ? "active" : "")" @onclick="() => _tab = 2">Test</div>
                    <div class="tab @(_tab == 3 ? "active" : "")" @onclick="() => _tab = 3">QA</div>
                </div>

                @if (_tab == 0)
                {
                    var s = _result.Spec;
                    <h3>@s.Title</h3>
                    <p class="muted">@s.Summary</p>
                    <p class="file-name">Functional requirements</p>
                    <ul class="clean">@foreach (var f in s.FunctionalRequirements){<li>@f</li>}</ul>
                    <p class="file-name">Entities</p>
                    <ul class="clean">@foreach (var e in s.Entities){<li><strong>@e.Name</strong>: @string.Join(", ", e.Fields)</li>}</ul>
                    <p class="file-name">Endpoints</p>
                    <ul class="clean">@foreach (var ep in s.Endpoints){<li><code>@ep.Method @ep.Path</code> — @ep.Purpose</li>}</ul>
                    <p class="file-name">Acceptance criteria</p>
                    <ul class="clean">@foreach (var a in s.AcceptanceCriteria){<li>@a</li>}</ul>
                }
                else if (_tab == 1)
                {
                    @if (!string.IsNullOrEmpty(_result.Code?.Notes))
                    {
                        <p class="muted">@_result.Code!.Notes</p>
                    }
                    @foreach (var f in _result.Code!.Files)
                    {
                        <div class="file-name">@f.Path</div>
                        <pre class="code">@CodeHighlighter.Highlight(f.Content)</pre>
                    }
                }
                else if (_tab == 2)
                {
                    var t = _result.Tests!;
                    <p class="muted">@t.Framework · happy @t.HappyPathCount · edge @t.EdgeCaseCount · error @t.ErrorCaseCount · coverage ~@t.EstimatedCoveragePercent%</p>
                    @foreach (var f in t.Files)
                    {
                        <div class="file-name">@f.Path</div>
                        <pre class="code">@CodeHighlighter.Highlight(f.Content)</pre>
                    }
                }
                else
                {
                    @for (var i = 0; i < _result.QaHistory.Count; i++)
                    {
                        var q = _result.QaHistory[i];
                        <p class="file-name">
                            Round @(i + 1) — score @q.Score.ToString("0.00")
                            @if (q.IsConsistent){<span class="badge ok">consistent</span>}else{<span class="badge warn">needs iteration</span>}
                        </p>
                        @foreach (var issue in q.Issues)
                        {
                            <div class="issue @issue.Severity">
                                <span class="sev">@issue.Severity · @issue.Category</span><br />
                                @issue.Description
                                @if (!string.IsNullOrEmpty(issue.Location)){<span class="muted"> (@issue.Location)</span>}
                            </div>
                        }
                        @if (q.Recommendations.Count > 0)
                        {
                            <ul class="clean">@foreach (var rec in q.Recommendations){<li class="muted">→ @rec</li>}</ul>
                        }
                    }
                }
            </div>

            @if (_result?.Code is not null && _result.Code.Files.Count > 0)
            {
                <div class="card">
                    <h2>Push to GitHub</h2>
                    <p class="muted">Open a pull request with the generated code + tests to a target repo. Set PAT + repo on <a href="/settings">Settings</a>.</p>
                    <button class="run" @onclick="OpenPrAsync" disabled="@_openingPr">
                        @(_openingPr ? "Opening PR…" : "🚀 Open PR on GitHub")
                    </button>
                    @if (_prUrl is not null)
                    {
                        <p class="hint" style="margin-top:10px"><span class="badge ok">PR opened</span> <a href="@_prUrl" target="_blank">@_prUrl</a></p>
                    }
                    @if (_prError is not null)
                    {
                        <p class="hint" style="margin-top:10px"><span class="badge err">Error</span> <span class="muted">@_prError</span></p>
                    }
                </div>
            }
        }
        else if (_result is null && !_running)
        {
            <div class="card">
                <div class="empty-state">
                    <div class="big">◇</div>
                    <p>Enter a user story then click <strong>Run pipeline</strong> to watch the 5 agents collaborate in real time.</p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    // ---- Input ----
    private string _description = "As an administrator, I want to manage products in the catalog with a unique SKU to avoid duplicates.";
    private int _nmax = 3;
    private bool _useDemo = true;

    private string ActiveProvider => string.IsNullOrWhiteSpace(LlmOpts.Value.ForceProvider)
        ? LlmOpts.Value.Provider
        : $"{LlmOpts.Value.ForceProvider} (forced)";

    // ---- Run state ----
    private bool _running;
    private string? _error;
    private int _currentIteration;
    private int _tab;
    private PipelineResult? _result;
    private PipelineStatus _finalStatus;
    private CancellationTokenSource? _cts;

    // ---- Cumulative metrics ----
    private long _tokIn;
    private long _tokOut;
    private decimal _cost;
    private double _latencyMs;

    private readonly List<QaRound> _qaRounds = new();

    private enum StageState { Idle, Running, Done, Failed }
    private sealed class StageRow { public StageState State; public string Sub = ""; public string Meta = ""; }
    private readonly record struct QaRound(int Iteration, double Score, bool Consistent);

    private readonly PipelineStage[] _order =
    {
        PipelineStage.Requirement, PipelineStage.Coding, PipelineStage.Testing, PipelineStage.Qa, PipelineStage.Aggregate,
    };

    private readonly Dictionary<PipelineStage, StageRow> _stages = new();

    private readonly Dictionary<PipelineStage, string> _dotText = new()
    {
        [PipelineStage.Requirement] = "R", [PipelineStage.Coding] = "C",
        [PipelineStage.Testing] = "T", [PipelineStage.Qa] = "Q", [PipelineStage.Aggregate] = "Σ",
    };
    private readonly Dictionary<PipelineStage, string> _title = new()
    {
        [PipelineStage.Requirement] = "Requirement Agent", [PipelineStage.Coding] = "Coding Agent",
        [PipelineStage.Testing] = "Testing Agent", [PipelineStage.Qa] = "QA Agent", [PipelineStage.Aggregate] = "Aggregate",
    };
    private readonly Dictionary<PipelineStage, string> _subtitle = new()
    {
        [PipelineStage.Requirement] = "Analyze user story", [PipelineStage.Coding] = "Generate C# code",
        [PipelineStage.Testing] = "Generate xUnit tests", [PipelineStage.Qa] = "Evaluate consistency",
        [PipelineStage.Aggregate] = "Orchestrator finalizes result + total cost",
    };

    // Hybrid LLM mapping (appsettings Agents:*:Provider) — drives the per-agent provider badge.
    private readonly Dictionary<PipelineStage, string> _agentProv = new()
    {
        [PipelineStage.Requirement] = "anthropic", [PipelineStage.Coding] = "azure",
        [PipelineStage.Testing] = "azure", [PipelineStage.Qa] = "anthropic", [PipelineStage.Aggregate] = "anthropic",
    };

    private bool _dbConnected;

    // GitHub PR state
    private bool _openingPr;
    private string? _prUrl;
    private string? _prError;

    private async Task OpenPrAsync()
    {
        if (_result?.Code is null) return;
        _openingPr = true;
        _prUrl = null;
        _prError = null;
        try
        {
            var title = $"feat: {_result.Spec?.Title ?? "generated code from Agentic SDLC"}";
            var body = $"Generated by Agentic SDLC pipeline.\n\n{_result.Spec?.Summary}\n\nFiles: {_result.Code.Files.Count}, Tests: {_result.Tests?.Files.Count ?? 0}";
            var pr = await GitHubPr.OpenPrAsync(_result, title, body, CancellationToken.None);
            _prUrl = pr.HtmlUrl;
        }
        catch (Exception ex)
        {
            _prError = ex.Message;
        }
        finally
        {
            _openingPr = false;
        }
    }

    protected override void OnInitialized()
    {
        foreach (var s in _order)
        {
            _stages[s] = new StageRow();
        }
        _dbConnected = !string.IsNullOrWhiteSpace(Config.GetConnectionString("DefaultConnection"));
    }

    private async Task RunAsync()
    {
        if (_running)
        {
            return;
        }
        ResetState();
        _running = true;
        DemoCtx.UseDemo = _useDemo;
        Progress.Listener = OnProgress;
        _cts = new CancellationTokenSource();

        try
        {
            var story = new UserStory(_description, _nmax, "en-US");
            var orchestrator = Sp.GetRequiredService<IOrchestratorAgent>();
            _result = await orchestrator.RunAsync(story, _cts.Token);
            _finalStatus = _result.Status;
            if (_finalStatus == PipelineStatus.Failed && _error is null)
            {
                _error = "Pipeline failed — see the server log for details.";
            }
        }
        catch (OperationCanceledException)
        {
            _error = "Run cancelled.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _running = false;
            Progress.Listener = null;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private void Cancel() => _cts?.Cancel();

    private async Task OnProgress(PipelineProgressEvent e)
    {
        await InvokeAsync(() =>
        {
            ApplyEvent(e);
            StateHasChanged();
        });
    }

    private void ApplyEvent(PipelineProgressEvent e)
    {
        _currentIteration = e.Iteration;
        var row = _stages[e.Stage];

        switch (e.Phase)
        {
            case PipelinePhase.Started:
                row.State = StageState.Running;
                row.Sub = e.Message;
                break;

            case PipelinePhase.Completed:
                row.State = StageState.Done;
                row.Sub = e.Message;
                if (e.Metrics is not null)
                {
                    row.Meta = $"{e.Metrics.InputTokens}→{e.Metrics.OutputTokens} tok · ${e.Metrics.CostUsd:0.0000} · {e.Metrics.Latency.TotalMilliseconds:0}ms";
                    if (e.Stage != PipelineStage.Aggregate)
                    {
                        _tokIn += e.Metrics.InputTokens;
                        _tokOut += e.Metrics.OutputTokens;
                        _cost += e.Metrics.CostUsd;
                        _latencyMs += e.Metrics.Latency.TotalMilliseconds;
                    }
                }
                if (e.Stage == PipelineStage.Qa && e.QaScore is double score)
                {
                    _qaRounds.Add(new QaRound(e.Iteration, score, e.QaConsistent ?? false));
                }
                break;

            case PipelinePhase.Failed:
                row.State = StageState.Failed;
                row.Sub = e.Message;
                _error = $"{e.Stage}: {e.Message}";
                break;
        }
    }

    private void ResetState()
    {
        _error = null;
        _result = null;
        _currentIteration = 0;
        _tab = 0;
        _tokIn = _tokOut = 0;
        _cost = 0m;
        _latencyMs = 0;
        _qaRounds.Clear();
        foreach (var s in _order)
        {
            _stages[s] = new StageRow();
        }
    }

    private string ProvName(PipelineStage s) => _agentProv[s] == "azure" ? "Azure" : "Claude";

    private string LeaderState()
        => _running ? "running"
         : _result is null ? "idle"
         : _finalStatus == PipelineStatus.Failed ? "failed" : "done";

    private static string StateClass(StageState s) => s switch
    {
        StageState.Running => "running",
        StageState.Done => "done",
        StageState.Failed => "failed",
        _ => "idle",
    };

    public void Dispose()
    {
        Progress.Listener = null;
        _cts?.Dispose();
    }
}
