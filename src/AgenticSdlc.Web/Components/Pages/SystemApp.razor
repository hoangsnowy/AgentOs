@* SystemApp — bundle of OS-style controls (About / Appearance / Session). Hosted in a Window. *@

@using AgenticSdlc.Web.Services
@inject ToastService Toasts
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="sys-app">
    <div class="sys-tabs">
        <button class="sys-tab @(_tab == "general" ? "active" : "")" @onclick="@(() => _tab = "general")">General</button>
        <button class="sys-tab @(_tab == "appearance" ? "active" : "")" @onclick="@(() => _tab = "appearance")">Appearance</button>
        <button class="sys-tab @(_tab == "about" ? "active" : "")" @onclick="@(() => _tab = "about")">About</button>
        <button class="sys-tab @(_tab == "session" ? "active" : "")" @onclick="@(() => _tab = "session")">Session</button>
    </div>

    <div class="sys-body">
        @switch (_tab)
        {
            case "general":
                <Panel Title="Notifications">
                    <Field Label="Show toast notifications">
                        <Toggle Checked="_notifs" CheckedChanged="@((bool v) => _notifs = v)" />
                    </Field>
                    <Field Label="Demo notification">
                        <Btn OnClick="@(() => Toasts.Show("System", "Hello from System Settings", ToastKind.Info))">Send</Btn>
                    </Field>
                </Panel>
                <Panel Title="Workspace">
                    <Field Label="Focus mode (mute non-critical notifications)">
                        <Toggle Checked="_focus" CheckedChanged="@((bool v) => _focus = v)" />
                    </Field>
                </Panel>
                break;
            case "appearance":
                <Panel Title="Wallpaper">
                    <Field Label="Background style">
                        <select @bind="_wall">
                            <option value="aurora">Aurora — violet × cyan × sky</option>
                            <option value="midnight">Midnight — deep navy</option>
                            <option value="sunset">Sunset — orange × magenta</option>
                        </select>
                    </Field>
                    <Field Label="Glass strength">
                        <input type="range" min="0" max="100" value="@_glass" @oninput="@((ChangeEventArgs e) => _glass = int.Parse(e.Value!.ToString()!))" />
                        <span class="muted">@_glass%</span>
                    </Field>
                </Panel>
                break;
            case "about":
                <Panel Title="AgentOS">
                    <p>A .NET multi-agent AI framework for the software development lifecycle.</p>
                    <table class="about-tbl">
                        <tr><th>Version</th><td>1.0</td></tr>
                        <tr><th>Runtime</th><td>.NET 10</td></tr>
                        <tr><th>License</th><td>MIT</td></tr>
                        <tr><th>Source</th><td><a href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank">github.com/hoangsnowy/agentic-sdlc-net</a></td></tr>
                    </table>
                </Panel>
                break;
            case "session":
                <Panel Title="Session">
                    <p class="muted">Sign-in is local-only via <code>localStorage</code>.</p>
                    <Field Label="Lock and return to splash">
                        <Btn OnClick="Lock">🔒 Lock</Btn>
                    </Field>
                    <Field Label="Sign out (clear stored credentials)">
                        <Btn Variant="Btn.ButtonVariant.Danger" OnClick="SignOut">⏻ Sign out</Btn>
                    </Field>
                </Panel>
                break;
        }
    </div>
</div>

@code {
    private string _tab = "general";
    private bool _notifs = true;
    private bool _focus;
    private string _wall = "aurora";
    private int _glass = 60;

    private async Task Lock()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task SignOut()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Toasts.Show("Signed out", "Refresh to sign in again.", ToastKind.Info);
    }
}
