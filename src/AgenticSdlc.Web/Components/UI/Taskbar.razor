@* Taskbar — Start + pinned apps + open window list + tray (clock + user). *@

@using AgenticSdlc.Web.Services
@inject WindowManagerService WM
@inject IJSRuntime JS
@implements IDisposable

<div class="taskbar">
    <button class="tb-start @(StartOpen ? "open" : "")" @onclick="ToggleStart" @onclick:stopPropagation="true" title="Open Start menu">
        <span class="tb-start-glyph">⊞</span> Start
    </button>

    <div class="tb-divider"></div>

    <div class="tb-pinned">
        <button class="tb-app" @onclick="@(() => WM.OpenApp("pipeline", "Pipeline", "▶"))" title="Pipeline">▶</button>
        <button class="tb-app" @onclick="@(() => WM.OpenApp("workflow", "Workflow", "🕸", w: 1080, h: 660))" title="Workflow">🕸</button>
        <button class="tb-app" @onclick="@(() => WM.OpenApp("settings", "Settings", "⚙", w: 720, h: 600))" title="Settings">⚙</button>
    </div>

    @if (WM.Open.Count > 0)
    {
        <div class="tb-divider"></div>
        <div class="tb-open">
            @foreach (var w in WM.Open)
            {
                <button class="tb-open-btn @(w.Minimized ? "minimized" : "active")"
                        @onclick="@(() => OnTaskbarClick(w))"
                        title="@w.Title">
                    <span class="tb-open-ic">@w.Icon</span>
                    <span class="tb-open-title">@w.Title</span>
                </button>
            }
        </div>
    }

    <div class="tb-spacer"></div>

    <div class="tb-tray">
        <span class="tb-tray-item tb-clock" title="@_today">@_now</span>
        <div class="tb-tray-item tb-user" title="@(_user ?? "guest")">
            <span class="tb-avatar">@AvatarLetter</span>
            <span>@(_user ?? "guest")</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool StartOpen { get; set; }
    [Parameter] public EventCallback OnToggleStart { get; set; }

    private string _now = "";
    private string _today = "";
    private string? _user;
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        UpdateClock();
        _timer = new System.Threading.Timer(_ => InvokeAsync(() => { UpdateClock(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        WM.Changed += OnWmChanged;
    }

    private void OnWmChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _user = await JS.InvokeAsync<string?>("localStorage.getItem", "agentic-signed-in");
                StateHasChanged();
            }
            catch { /* JS interop not ready */ }
        }
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        _now = now.ToString("HH:mm:ss");
        _today = now.ToString("dddd, d MMMM yyyy");
    }

    private void OnTaskbarClick(AppWindowState w)
    {
        if (w.Minimized)
        {
            WM.Restore(w.Id);
        }
        else
        {
            WM.Focus(w.Id);
        }
    }

    private Task ToggleStart() => OnToggleStart.InvokeAsync();

    public void Dispose()
    {
        _timer?.Dispose();
        WM.Changed -= OnWmChanged;
    }
}
