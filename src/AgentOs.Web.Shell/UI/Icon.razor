@* Icon — single-source monochrome SVG icon. Lucide-style 24x24 viewBox, currentColor.
   Usage: <Icon Name="play" Size="16" />
   Add titles for screen readers: <Icon Name="play" Title="Run pipeline" />
   Migration map: docs/design/icon-map.md
*@

<svg xmlns="http://www.w3.org/2000/svg"
     width="@Size" height="@Size" viewBox="0 0 24 24"
     fill="none" stroke="currentColor" stroke-width="@StrokeWidth"
     stroke-linecap="round" stroke-linejoin="round"
     class="icon @(ExtraClass ?? "")"
     aria-hidden="@(string.IsNullOrEmpty(Title) ? "true" : null)"
     role="@(string.IsNullOrEmpty(Title) ? null : "img")"
     focusable="false">
    @if (!string.IsNullOrEmpty(Title))
    {
        <title>@Title</title>
    }
    @switch (Name)
    {
        case "play":
            <polygon points="6 3 20 12 6 21 6 3" fill="currentColor" stroke="none" />
            break;
        case "stop":
            <rect x="6" y="6" width="12" height="12" rx="1" fill="currentColor" stroke="none" />
            break;
        case "pause":
            <rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor" stroke="none" />
            <rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor" stroke="none" />
            break;
        case "gear":
            <circle cx="12" cy="12" r="3" />
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            break;
        case "wrench":
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
            break;
        case "hammer":
            <path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0s-.83-2.17 0-3L12 9" />
            <path d="m17.64 15 3.59-3.59L18 8.46l-3.59 3.59a1 1 0 0 0 0 1.41l1.42 1.42a1 1 0 0 0 1.41 0z" />
            <path d="M14.5 5.5 18 9" />
            break;
        case "graph":
            <circle cx="6" cy="6" r="2" />
            <circle cx="18" cy="6" r="2" />
            <circle cx="12" cy="18" r="2" />
            <path d="M7.5 7.5l3 8" />
            <path d="M16.5 7.5l-3 8" />
            <path d="M8 6h8" />
            break;
        case "terminal":
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <path d="M7 9l3 3-3 3" />
            <line x1="13" y1="15" x2="17" y2="15" />
            break;
        case "folder":
            <path d="M3 7a2 2 0 0 1 2-2h3.6a2 2 0 0 1 1.4.6L12 7h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            break;
        case "file":
            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
            <path d="M14 3v5h5" />
            break;
        case "chevron-right":
            <path d="M9 6l6 6-6 6" />
            break;
        case "git-pull-request":
            <circle cx="6" cy="6" r="2.5" />
            <circle cx="6" cy="18" r="2.5" />
            <circle cx="18" cy="18" r="2.5" />
            <line x1="6" y1="8.5" x2="6" y2="15.5" />
            <path d="M18 11v4" />
            <path d="M14 4h2a2 2 0 0 1 2 2v3" />
            break;
        case "arrow-square-out":
            <path d="M14 4h6v6" />
            <path d="m10 14 10-10" />
            <path d="M20 14v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h6" transform="translate(1 0)" />
            break;
        case "clock":
            <circle cx="12" cy="12" r="9" />
            <polyline points="12 7 12 12 15 14" />
            break;
        case "lock":
            <rect x="4" y="11" width="16" height="10" rx="2" />
            <path d="M8 11V7a4 4 0 0 1 8 0v4" />
            break;
        case "bell":
            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            break;
        case "info":
            <circle cx="12" cy="12" r="9" />
            <line x1="12" y1="11" x2="12" y2="16" />
            <circle cx="12" cy="8" r="0.7" fill="currentColor" stroke="none" />
            break;
        case "warning":
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" y1="9" x2="12" y2="13" />
            <circle cx="12" cy="17" r="0.7" fill="currentColor" stroke="none" />
            break;
        case "power":
            <path d="M18.36 6.64a9 9 0 1 1-12.72 0" />
            <line x1="12" y1="2" x2="12" y2="12" />
            break;
        case "palette":
            <circle cx="13.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="17.5" cy="10.5" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="8.5" cy="7.5" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="6.5" cy="12.5" r="1.5" fill="currentColor" stroke="none" />
            <path d="M12 2a10 10 0 0 0-9.5 13.16A10 10 0 0 0 12 22a2.5 2.5 0 0 0 0-5h-1.5a1.5 1.5 0 0 1 0-3h3.5a5 5 0 0 0 5-5 7 7 0 0 0-7-7z" />
            break;
        case "squares-four":
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
            break;
        case "house":
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
            break;
        case "arrow-clockwise":
            <polyline points="21 12 21 5 14 5" />
            <path d="M21 5A9 9 0 1 0 21 13" transform="translate(0 -1)" />
            break;
        case "diamond":
            <polygon points="12 2 22 12 12 22 2 12" fill="currentColor" stroke="none" />
            break;
        case "circle-fill":
            <circle cx="12" cy="12" r="6" fill="currentColor" stroke="none" />
            break;
        case "moon":
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            break;
        case "sun":
            <circle cx="12" cy="12" r="4" />
            <line x1="12" y1="2" x2="12" y2="5" />
            <line x1="12" y1="19" x2="12" y2="22" />
            <line x1="2" y1="12" x2="5" y2="12" />
            <line x1="19" y1="12" x2="22" y2="12" />
            <line x1="4.93" y1="4.93" x2="7" y2="7" />
            <line x1="17" y1="17" x2="19.07" y2="19.07" />
            <line x1="4.93" y1="19.07" x2="7" y2="17" />
            <line x1="17" y1="7" x2="19.07" y2="4.93" />
            break;
        case "floppy-disk":
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
            <polyline points="17 21 17 13 7 13 7 21" />
            <polyline points="7 3 7 8 15 8" />
            break;
        case "trash":
            <polyline points="3 6 5 6 21 6" />
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            <line x1="10" y1="11" x2="10" y2="17" />
            <line x1="14" y1="11" x2="14" y2="17" />
            break;
        case "lightning":
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" fill="currentColor" stroke="none" />
            break;
        case "question":
            <circle cx="12" cy="12" r="9" />
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
            <circle cx="12" cy="17" r="0.7" fill="currentColor" stroke="none" />
            break;
        case "device-mobile":
            <rect x="6" y="2" width="12" height="20" rx="2" />
            <line x1="11" y1="18" x2="13" y2="18" />
            break;
        case "minus":
            <line x1="5" y1="12" x2="19" y2="12" />
            break;
        case "square":
            <rect x="5" y="5" width="14" height="14" rx="1" />
            break;
        case "squares-stack":
            <rect x="3" y="3" width="14" height="14" rx="1" />
            <rect x="7" y="7" width="14" height="14" rx="1" />
            break;
        case "x":
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="18" y1="6" x2="6" y2="18" />
            break;
        case "search":
            <circle cx="11" cy="11" r="7" />
            <line x1="16.5" y1="16.5" x2="21" y2="21" />
            break;
        case "user":
            <circle cx="12" cy="8" r="4" />
            <path d="M4 21a8 8 0 0 1 16 0" />
            break;
        case "clock-counter":
            <path d="M3 12a9 9 0 1 0 3-6.7" />
            <polyline points="3 4 3 9 8 9" />
            <polyline points="12 8 12 12 15 14" />
            break;
        case "tag":
            <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z" />
            <circle cx="7.5" cy="7.5" r="1" fill="currentColor" stroke="none" />
            break;
        case "arrow-right":
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
            break;
        case "arrow-left":
            <line x1="19" y1="12" x2="5" y2="12" />
            <polyline points="12 19 5 12 12 5" />
            break;
        case "check":
            <polyline points="20 6 9 17 4 12" />
            break;
        case "wifi":
            <path d="M5 12.55a11 11 0 0 1 14 0" />
            <path d="M8.5 16.1a6 6 0 0 1 7 0" />
            <path d="M2 8.82a15 15 0 0 1 20 0" />
            <circle cx="12" cy="20" r="0.8" fill="currentColor" stroke="none" />
            break;
        case "speaker-high":
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="currentColor" stroke="none" />
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
            break;
        case "battery":
            <rect x="2" y="7" width="16" height="10" rx="2" />
            <line x1="22" y1="11" x2="22" y2="13" />
            <rect x="4" y="9" width="11" height="6" rx="1" fill="currentColor" stroke="none" />
            break;
        default:
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <line x1="3" y1="3" x2="21" y2="21" />
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter] public int Size { get; set; } = 16;
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? ExtraClass { get; set; }
    [Parameter] public double StrokeWidth { get; set; } = 2;
}
