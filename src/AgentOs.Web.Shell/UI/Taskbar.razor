@* Floating dock (bottom-center) + system tray (top-right) — macOS / KDE Latte vibe. *@

@using Microsoft.AspNetCore.Components.Authorization
@inject WindowManagerService WM
@inject IAppRegistry Registry
@inject IJSRuntime JS
@implements IDisposable

@* ===== Dock (floating bottom-center pill) ===== *@
<div class="dock" role="toolbar" aria-label="Application dash">
    @foreach (var app in Registry.VisiblePinned(_isAdmin))
    {
        var isOpen = WM.Open.Any(o => o.AppKey == app.Key);
        <button class="dock-item @(isOpen ? "running" : "")"
                @onclick="@(() => Launch(app))"
                title="@app.Title" aria-label="@app.Title">
            <span class="di-ic" style="background:@app.Color;color:#fff"><Icon Name="@app.Icon" Size="18" /></span>
            @if (isOpen)
            {
                <span class="di-dot"></span>
            }
        </button>
    }

    @{
        var floating = WM.Open.Where(w => !Registry.Pinned.Any(p => p.Key == w.AppKey)).ToList();
    }
    @if (floating.Count > 0)
    {
        <span class="dock-sep"></span>
        @foreach (var w in floating)
        {
            <button class="dock-item running @(w.Minimized ? "min" : "")"
                    @onclick="@(() => OnTaskClick(w))"
                    title="@w.Title" aria-label="@w.Title">
                <span class="di-ic" style="background:@(Registry.Find(w.AppKey)?.Color ?? "#3584e4");color:#fff"><Icon Name="@w.Icon" Size="18" /></span>
                <span class="di-dot"></span>
            </button>
        }
    }
</div>

@code {
    [Parameter] public bool StartOpen { get; set; }
    [Parameter] public EventCallback OnToggleStart { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string? _user;
    private bool _isAdmin;
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    protected override void OnInitialized()
    {
        // No clock here: the dock shows no time, so there is no per-second timer. The dock only needs
        // to repaint when windows open/close (WM.Changed) — a 1s StateHasChanged was re-rendering the
        // whole dock every second for nothing (idle SignalR churn). The TopBar owns the visible clock.
        WM.Changed += OnWmChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsAdmin();
        }
    }

    private void OnWmChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _user = await JS.InvokeAsync<string?>("localStorage.getItem", "agentic-signed-in");
                StateHasChanged();
            }
            catch (Microsoft.JSInterop.JSException ex)
            {
                // Prerender / JS unavailable — leave the signed-in label unresolved.
                _ = ex.Message;
            }
            catch (System.InvalidOperationException ex)
            {
                _ = ex.Message;
            }
        }
    }

    private void OnTaskClick(AppWindowState w)
    {
        if (w.Minimized) { WM.Restore(w.Id); }
        else { WM.Focus(w.Id); }
    }

    private void Launch(DesktopApp app)
    {
        WM.OpenApp(app.Key, app.Title, app.Icon, app.W, app.H);
    }

    public void Dispose()
    {
        WM.Changed -= OnWmChanged;
    }
}
