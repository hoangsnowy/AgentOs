@* SettingsHub — one window that collects every admin/system surface behind a single category rail,
   so the desktop dock stays at five pinned apps instead of a scatter of one-off admin windows. Each
   category renders an existing app component inline in the content pane (they remain independently
   launchable + deep-linkable). The two "full" categories (LLM, System) bring their own prefs rail, so
   their pane runs edge-to-edge (.flush). Categories the signed-in user can't access are hidden. *@

@using Microsoft.AspNetCore.Components.Authorization

<div class="prefs">
    <aside class="prefs-side">
        <div class="prefs-side-head">Settings</div>
        @foreach (var c in VisibleCats())
        {
            <button class="prefs-cat @(_tab == c.Key ? "active" : "")" @onclick="@(() => _tab = c.Key)">
                <span class="prefs-cat-ic"><Icon Name="@c.Icon" Size="14" /></span> @c.Label
            </button>
        }
    </aside>

    <div class="@ContentClass">
        @switch (_tab)
        {
            case "llm":      <Settings />;    break;
            case "prompts":  <PromptsApp />;  break;
            case "policy":   <PolicyApp />;   break;
            case "cost":     <CostApp />;     break;
            case "evidence": <EvidenceApp />; break;
            case "users":    <UsersApp />;    break;
            case "plugins":  <PluginsApp />;  break;
            case "mcp":      <McpApp />;      break;
            case "system":   <SystemApp />;   break;
            default:         <SystemApp />;   break;
        }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isAdmin;
    private string _tab = "system";

    private sealed record Cat(string Key, string Label, string Icon, bool AdminOnly = false, bool Full = false);

    // Order = rail order. "Full" categories host a component that owns its own prefs rail.
    private static readonly Cat[] Cats =
    [
        new("llm",      "LLM & providers", "gear",           AdminOnly: true, Full: true),
        new("prompts",  "Prompts",         "lightning",      AdminOnly: true),
        new("policy",   "Tool policy",     "lock",           AdminOnly: true),
        new("cost",     "Cost",            "graph",          AdminOnly: true),
        new("evidence", "Evidence",        "lock",           AdminOnly: true),
        new("users",    "Users",           "user",           AdminOnly: true),
        new("mcp",      "MCP servers",     "arrow-square-out", AdminOnly: true),
        new("plugins",  "Plugins",         "squares-stack"),
        new("system",   "System",          "wrench",         Full: true),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsAdmin();
        }
        // Land on the first category the user can actually use (admins → LLM, members → System).
        _tab = VisibleCats().FirstOrDefault()?.Key ?? "system";
    }

    private IEnumerable<Cat> VisibleCats() => Cats.Where(c => _isAdmin || !c.AdminOnly);

    private Cat? ActiveCat() => Cats.FirstOrDefault(c => c.Key == _tab);

    // "Full" categories host a component with its own prefs rail → run the pane edge-to-edge.
    private string ContentClass => ActiveCat() is { Full: true } ? "prefs-content flush" : "prefs-content";
}
