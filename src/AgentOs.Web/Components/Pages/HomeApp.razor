@* HomeApp — the guided starting place for AgentOS. Turns the desktop's pile of apps into ONE flow:
   idea → spec → code → test → PR. The hero hands an idea to the Spine wizard (deep-link payload); the
   stage rail deep-links each step to the app that owns it; the governance row threads to Cost/Evidence/
   Policy. Pure navigation — no data load — so it renders identically standalone or full-stack. *@

@using Microsoft.AspNetCore.Components.Authorization
@using AgentOs.Web.Services
@inject AgentOs.Web.Shell.Services.WindowManagerService WM

<header class="page-head">
    <div>
        <h1 class="page-title">Welcome to AgentOS</h1>
        <p class="page-sub">Turn an idea into a reviewed pull request — the agents do the spec, code and tests.</p>
    </div>
</header>

<Panel Title="Start from an idea">
    <Field Label="What do you want to build?"
           Hint="One or two sentences. AgentOS drafts tickets, then implements, tests and opens a PR.">
        <textarea class="prefs-input home-idea" rows="3" @bind="_idea" @bind:event="oninput"
                  placeholder="e.g. Add CSV export to the cost report"></textarea>
    </Field>
    <div class="home-cta">
        <Btn Variant="Btn.ButtonVariant.Primary" OnClick="StartFromIdea"
             Disabled="@(string.IsNullOrWhiteSpace(_idea))">
            <Icon Name="lightning" Size="14" /> Start from idea
        </Btn>
        <span class="muted">Opens the Spine wizard with your idea — review the tickets, then run them to PRs.</span>
    </div>
</Panel>

<Panel Title="The flow">
    <div class="home-rail">
        @for (var i = 0; i < Stages.Length; i++)
        {
            var s = Stages[i];
            <div class="home-stage">
                <div class="home-stage-top">
                    <span class="home-stage-ic"><Icon Name="@s.Icon" Size="18" /></span>
                    <span class="home-step">@s.No</span>
                </div>
                <div class="home-stage-name">@s.Name</div>
                <div class="home-stage-desc">@s.Desc</div>
                <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Ghost" OnClick="@(() => Open(s.AppKey))">
                    Open @AppTitle(s.AppKey) <Icon Name="arrow-right" Size="13" />
                </Btn>
            </div>
            @if (i < Stages.Length - 1)
            {
                <span class="home-arrow" aria-hidden="true"><Icon Name="arrow-right" Size="16" /></span>
            }
        }
    </div>
</Panel>

@if (_isAdmin)
{
    <Panel Title="Track every run">
        <p class="muted home-track-sub">Every run is metered and audited — open the governance apps for the spend, the tool-call evidence and the policy gate.</p>
        <div class="home-track">
            @foreach (var t in Track)
            {
                <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Ghost" OnClick="@(() => Open(t.Key))">
                    <Icon Name="@t.Icon" Size="14" /> @AppTitle(t.Key)
                </Btn>
            }
        </div>
    </Panel>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _idea = "";
    private bool _isAdmin;

    private sealed record Stage(int No, string Name, string Desc, string Icon, string AppKey);

    private static readonly Stage[] Stages =
    [
        new(1, "Idea", "Describe what you want to build.",         "lightning",        "spine"),
        new(2, "Spec", "AI drafts tickets + acceptance criteria.", "tag",              "spine"),
        new(3, "Code", "Agents implement it on your runner.",      "play",             "pipeline"),
        new(4, "Test", "Testing + QA loop until it converges.",    "check",            "pipeline"),
        new(5, "PR",   "A pull request opens on your repo.",       "git-pull-request", "sessions"),
    ];

    private static readonly (string Name, string Icon, string Key)[] Track =
    [
        ("Cost", "graph", "cost"),
        ("Evidence", "lock", "evidence"),
        ("Policy", "lock", "policy"),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsAdmin();
        }
    }

    private static string AppTitle(string key) => AppCatalog.Find(key)?.Title ?? key;

    private void Open(string key)
    {
        var app = AppCatalog.Find(key);
        if (app is null) { return; }
        WM.OpenApp(app.Key, app.Title, app.Icon, app.W, app.H);
    }

    // Hand the idea to the Spine wizard via a one-shot launch payload, then open it on the Idea step.
    private void StartFromIdea()
    {
        var idea = _idea.Trim();
        if (idea.Length == 0) { return; }
        WM.RequestLaunchPayload("spine", idea);
        Open("spine");
    }
}
