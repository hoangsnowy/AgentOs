@* CostApp — admin view of LLM spend across the 5-agent pipeline. Reads the persisted run_metrics
   (one row per LLM call) and shows headline totals + breakdowns by agent / provider / model / day.
   Admin-gated (AdminOnly in AppCatalog + a re-check here). Tenant is read from AuthenticationState —
   a circuit has no HttpContext — and passed to the tenant-explicit GetCostSummaryForTenantAsync. *@

@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using AgentOs.Modules.Pipeline.Persistence
@using AgentOs.Modules.Pipeline.Cost
@using AgentOs.Domain.Cost
@inject IPipelineRunRepository Runs
@inject IBudgetService Budgets
@inject AgentOs.Web.Services.ToastService Toasts
@inject NavigationManager Nav

@if (!_resolved)
{
    <Spinner />
}
else if (!_isAdmin)
{
    <div class="login-error">Admin role required to view LLM cost.</div>
}
else
{
    <header class="page-head">
        <div>
            <h1 class="page-title">Cost · <code>@_tenantId</code></h1>
            <p class="page-sub">LLM spend across the 5-agent pipeline — @_rangeLabel.</p>
        </div>
        <div class="cost-actions">
            <Btn Size="Btn.ButtonSize.Sm" Variant="@RangeVariant(7)"  OnClick="() => SetRange(7)"  Disabled="_loading">7d</Btn>
            <Btn Size="Btn.ButtonSize.Sm" Variant="@RangeVariant(30)" OnClick="() => SetRange(30)" Disabled="_loading">30d</Btn>
            <Btn Size="Btn.ButtonSize.Sm" Variant="@RangeVariant(0)"  OnClick="() => SetRange(0)"  Disabled="_loading">All</Btn>
            <Btn OnClick="Reload" Disabled="_loading"><Icon Name="arrow-clockwise" Size="14" /> Refresh</Btn>
            <Btn Size="Btn.ButtonSize.Sm" OnClick="ExportCsv" Disabled="_loading"><Icon Name="arrow-square-out" Size="14" /> Export CSV</Btn>
        </div>
    </header>

    <Panel Title="Budget">
        <div class="budget-row">
            <Field Label="Monthly cap (USD)" Hint="0 = no cap (unconstrained spend)">
                <input class="prefs-input" type="number" min="0" step="1" @bind="_cap" />
            </Field>
            <Toggle Label="Enforce" Checked="_enforce" CheckedChanged="(v) => _enforce = v"
                    Title="When on, a run is blocked once month-to-date spend reaches the cap." />
            <Btn OnClick="SaveBudget" Disabled="_savingBudget" Variant="Btn.ButtonVariant.Primary">Save</Btn>
            <Badge Variant="@BudgetBadge()">@BudgetStateLabel()</Badge>
        </div>
        @if (_budget is { CapUsd: > 0 })
        {
            <div class="budget-bar">
                <Progress Value="@System.Math.Min(_budget.Percent, 1.0)" ShowLabel="true" />
                <span class="muted">@Money(_budget.SpentUsd) of @Money(_budget.CapUsd) spent this month</span>
            </div>
        }
    </Panel>

    @if (_summary is null)
    {
        <Spinner />
    }
    else if (_summary.CallCount == 0)
    {
        <EmptyState Icon="graph"
                    Title="@($"No LLM calls recorded {(_days == 0 ? "yet" : "in " + _rangeLabel)}")"
                    Hint="Cost appears here after a pipeline run." />
    }
    else
    {
        <div class="metrics">
            <div class="metric">
                <div class="v">@Money(_summary.TotalCostUsd)</div>
                <div class="k">Total cost (USD)</div>
            </div>
            <div class="metric">
                <div class="v">@Num(_summary.TotalTokensIn) → @Num(_summary.TotalTokensOut)</div>
                <div class="k">Tokens in → out</div>
            </div>
            <div class="metric">
                <div class="v">@Num(_summary.RunCount)</div>
                <div class="k">Pipeline runs</div>
            </div>
            <div class="metric">
                <div class="v">@Num(_summary.CallCount)</div>
                <div class="k">LLM calls</div>
            </div>
        </div>

        <div class="cost-grid">
            @foreach (var bd in Breakdowns())
            {
                <Panel Title="@bd.Title">
                    @if (bd.Rows.Count == 0)
                    {
                        <EmptyState Title="No data for this breakdown" Hint="Rows appear once a run records cost in the selected range." />
                    }
                    else
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>@bd.Header</th>
                                    <th class="num">Cost</th>
                                    <th class="num">In</th>
                                    <th class="num">Out</th>
                                    <th class="num">Calls</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in bd.Rows)
                                {
                                    <tr>
                                        <td><code>@b.Key</code></td>
                                        <td class="num">@Money(b.CostUsd)</td>
                                        <td class="num">@Num(b.TokensIn)</td>
                                        <td class="num">@Num(b.TokensOut)</td>
                                        <td class="num">@Num(b.Calls)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </Panel>
            }
        </div>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _resolved;
    private bool _isAdmin;
    private bool _loading;
    private string _tenantId = "default";
    private int _days;                       // 0 = all time (default)
    private string _rangeLabel = "all time";
    private CostSummary? _summary;

    private decimal _cap;
    private bool _enforce;
    private bool _savingBudget;
    private BudgetStatus? _budget;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsAdmin();
            _tenantId = state.User.GetTenantId() ?? string.Empty;
        }
        _resolved = true;
        if (_isAdmin && _tenantId.Length > 0)
        {
            await LoadBudgetAsync();
            await LoadAsync();
        }
    }

    private async Task LoadBudgetAsync()
    {
        try
        {
            _budget = await Budgets.GetAsync(_tenantId);
            _cap = _budget.CapUsd;
            _enforce = _budget.EnforceOn;
        }
        catch (System.InvalidOperationException ex)
        {
            Toasts.Show("Budget", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            Toasts.Show("Budget", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.Text.Json.JsonException ex)
        {
            Toasts.Show("Budget", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.TimeoutException ex)
        {
            Toasts.Show("Budget", $"Load failed: {ex.Message}", ToastKind.Err);
        }
    }

    private async Task SaveBudget()
    {
        _savingBudget = true;
        try
        {
            await Budgets.SetCapAsync(_tenantId, _cap);
            await Budgets.SetEnforceAsync(_tenantId, _enforce);
            await LoadBudgetAsync();
            Toasts.Show("Budget", _cap > 0 ? $"Cap set to {Money(_cap)}/month." : "Cap cleared.", ToastKind.Ok);
        }
        catch (System.InvalidOperationException ex)
        {
            Toasts.Show("Budget", $"Save failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            Toasts.Show("Budget", $"Save failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.Text.Json.JsonException ex)
        {
            Toasts.Show("Budget", $"Save failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.TimeoutException ex)
        {
            Toasts.Show("Budget", $"Save failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _savingBudget = false;
        }
    }

    private Badge.BadgeVariant BudgetBadge() => _budget?.State switch
    {
        BudgetState.Exceeded => Badge.BadgeVariant.Err,
        BudgetState.Warn => Badge.BadgeVariant.Warn,
        BudgetState.Ok when _budget.CapUsd > 0 => Badge.BadgeVariant.Ok,
        _ => Badge.BadgeVariant.Default,
    };

    private string BudgetStateLabel() => _budget?.State switch
    {
        BudgetState.Exceeded => "Over budget",
        BudgetState.Warn => "Near cap",
        BudgetState.Ok when _budget.CapUsd > 0 => "Within budget",
        _ => "No cap",
    };

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            DateTimeOffset? since = _days > 0 ? DateTimeOffset.UtcNow.AddDays(-_days) : null;
            _summary = await Runs.GetCostSummaryForTenantAsync(_tenantId, since);
        }
        catch (System.InvalidOperationException ex)
        {
            Toasts.Show("Cost", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            Toasts.Show("Cost", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.Text.Json.JsonException ex)
        {
            Toasts.Show("Cost", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        catch (System.TimeoutException ex)
        {
            Toasts.Show("Cost", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SetRange(int days)
    {
        _days = days;
        _rangeLabel = days switch { 0 => "all time", 7 => "last 7 days", _ => $"last {days} days" };
        await LoadAsync();
    }

    private async Task Reload() => await LoadAsync();

    // Same-origin, cookie-authed browser download via the /cost/export endpoint (mapped in Web Program.cs).
    private void ExportCsv() => Nav.NavigateTo($"/cost/export?days={_days}", forceLoad: true);

    private Btn.ButtonVariant RangeVariant(int days) =>
        _days == days ? Btn.ButtonVariant.Primary : Btn.ButtonVariant.Default;

    private IEnumerable<(string Title, string Header, IReadOnlyList<CostBucket> Rows)> Breakdowns() =>
    [
        ("By agent",    "Agent",    _summary!.ByAgent),
        ("By provider", "Provider", _summary!.ByProvider),
        ("By model",    "Model",    _summary!.ByModel),
        ("By day",      "Day",      _summary!.ByDay),
    ];

    private static string Money(decimal v) => "$" + v.ToString("0.0000", CultureInfo.InvariantCulture);
    private static string Num(int v) => v.ToString("N0", CultureInfo.InvariantCulture);
}
