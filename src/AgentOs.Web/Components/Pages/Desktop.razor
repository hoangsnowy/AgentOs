@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AgentOs.Web.Shell.Services.WindowManagerService WM
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>Desktop — AgentOS</PageTitle>

<div class="desktop desktop-empty"
     @oncontextmenu="OnRightClick"
     @oncontextmenu:preventDefault="true">

    @* Authentic GNOME desktop: a clean empty wallpaper — no icons, no widgets. Apps live only in the
       Dash and the Activities overview; right-click opens the desktop context menu. *@
</div>

<ContextMenu Show="_ctxShow" X="_ctxX" Y="_ctxY" OnClose="@(() => _ctxShow = false)">
    <button class="ctx-item" @onclick="OpenActivities">
        <span class="ctx-ic"><Icon Name="squares-four" Size="14" /></span> Activities
    </button>
    <button class="ctx-item" @onclick="ChangeBackground">
        <span class="ctx-ic"><Icon Name="palette" Size="14" /></span> Change background…
    </button>
    <div class="ctx-sep"></div>
    <button class="ctx-item" @onclick="ToggleTheme">
        <span class="ctx-ic"><Icon Name="moon" Size="14" /></span> Toggle theme
    </button>
    <button class="ctx-item" @onclick="@(() => Launch("system", "System", "wrench", 760, 600))">
        <span class="ctx-ic"><Icon Name="gear" Size="14" /></span> Display settings…
    </button>
</ContextMenu>

@code {
    private bool _ctxShow;
    private int _ctxX, _ctxY;

    private void OnRightClick(MouseEventArgs e)
    {
        _ctxX = (int)e.ClientX;
        _ctxY = (int)e.ClientY;
        _ctxShow = true;
    }

    // GNOME wallpaper menu: open the Activities overview.
    private void OpenActivities()
    {
        _ctxShow = false;
        WM.RequestStartMenuToggle();
    }

    // Deep-link the System app to its Appearance (wallpaper/theme) tab.
    private void ChangeBackground()
    {
        WM.RequestLaunchTab("system", "appearance");
        WM.OpenApp("system", "System", "wrench", 760, 600);
        _ctxShow = false;
    }

    private async Task ToggleTheme()
    {
        _ctxShow = false;
        try
        {
            await JS.InvokeAsync<string>("agenticTheme.toggleAppearance");
            WM.NotifyThemeChanged();
        }
        catch (Microsoft.JSInterop.JSException ex) { _ = ex.Message; }
        catch (System.InvalidOperationException ex) { _ = ex.Message; }
    }

    private void Launch(string key, string title, string icon, int w, int h)
    {
        WM.OpenApp(key, title, icon, w, h);
        _ctxShow = false;
    }
}
