@* SpineApp — Projects (connected repos) → Issues (GitHub) → AI sessions (M2/M3/M4/M5).
   Primary flow: select a project, browse its open GitHub Issues, click "Work on this" to
   start an AI session, then "Run" to trigger the IssueWorkAgent → branch → PR.
   Reads data in-process via module repositories. A Blazor Server circuit has no HttpContext,
   so ITenantContext is blank here — we read the tenant + user from AuthenticationState and
   call repos via tenant-explicit overloads.
   M5 adds: Run button (Draft sessions), PR link (Done sessions), 5-second poll when Running. *@

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using AgentOs.Domain.Workspaces
@using AgentOs.Domain.Sessions
@using AgentOs.Modules.AppConfig
@using AgentOs.Modules.Integration
@using AgentOs.Modules.Workspaces
@using AgentOs.Modules.Workspaces.Persistence
@using AgentOs.Modules.Workspaces.Persistence.Entities
@using AgentOs.Modules.Sessions.Persistence
@using AgentOs.Modules.Sessions.Persistence.Entities
@inject IWorkspaceRepository Workspaces
@inject IWorkspaceConnector Connector
@inject IRunnerRepository Runners
@inject ISessionRepository Sessions
@inject IRunnerPairingService Pairing
@inject IAppConfigStore ConfigStore
@inject IGitHubIssueService IssueService
@inject AgentOs.Web.Services.ToastService Toasts
@inject AgentOs.Domain.Sessions.IIssueWorkAgent IssueWorkAgent
@inject AgentOs.Domain.Workspaces.IPrCreationService PrCreation
@inject IServiceScopeFactory ScopeFactory
@implements IDisposable

<header class="page-head">
    <div>
        <h1 class="page-title">Spine · <code>@_tenantId</code></h1>
        <p class="page-sub">Projects → Issues → AI sessions. Remote repo-execution path (M2/M3/M4).</p>
    </div>
    <Btn OnClick="ReloadAll" Disabled="_loading">
        <Icon Name="arrow-clockwise" Size="14" /> Refresh
    </Btn>
</header>

<div class="spine-tabs">
    <button class="spine-tab @(_tab == Tab.Projects ? "active" : "")" @onclick="@(() => { _tab = Tab.Projects; _selectedProject = null; })">
        Projects <Badge>@(_workspaces?.Count ?? 0)</Badge>
    </button>
    <button class="spine-tab @(_tab == Tab.Runners ? "active" : "")" @onclick="@(() => _tab = Tab.Runners)">
        Runners <Badge>@(_runners?.Count ?? 0)</Badge>
    </button>
    <button class="spine-tab @(_tab == Tab.Sessions ? "active" : "")" @onclick="@(() => _tab = Tab.Sessions)">
        Sessions <Badge>@(_sessions?.Count ?? 0)</Badge>
    </button>
</div>

@if (!_resolved)
{
    <Spinner />
}

@* ── PROJECTS TAB ──────────────────────────────────────────────────────────────────────── *@
else if (_tab == Tab.Projects)
{
    @if (_selectedProject is null)
    {
        @* Projects list view *@
        <Panel Title="Connect a repository">
            <div class="form-grid">
                <Field Label="Provider">
                    <select class="prefs-select" @bind="_wsKind">
                        <option value="@SourceProviderKind.GitHub">GitHub</option>
                        <option value="@SourceProviderKind.AzureDevOps">Azure DevOps</option>
                    </select>
                </Field>
                <Field Label="Name">
                    <input @bind="_wsName" placeholder="my-service" />
                </Field>
                <Field Label="@(_wsKind == SourceProviderKind.AzureDevOps ? "Organization" : "Owner")">
                    <input @bind="_wsOwner" placeholder="octocat" />
                </Field>
                <Field Label="Repository">
                    <input @bind="_wsRepo" placeholder="hello-world" />
                </Field>
                @if (_wsKind == SourceProviderKind.AzureDevOps)
                {
                    <Field Label="Project">
                        <input @bind="_wsProject" placeholder="MyProject" />
                    </Field>
                }
                <Field Label="Default branch">
                    <input @bind="_wsBranch" placeholder="main" />
                </Field>
                <Field Label="Access token (PAT)">
                    <input type="password" @bind="_wsToken" placeholder="ghp_… / Azure PAT" autocomplete="off" />
                </Field>
            </div>
            <div class="form-actions">
                <Btn Variant="Btn.ButtonVariant.Primary" OnClick="ConnectWorkspace" Disabled="_busy">
                    @(_busy ? "Connecting…" : "Connect")
                </Btn>
            </div>
            <p class="muted spine-form-hint">Token is validated, then stored encrypted — never shown again or kept on the row.</p>
        </Panel>

        @if (_workspaces is null) { <Spinner /> }
        else
        {
            <Panel Title="Projects">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Repository</th>
                        <th>Branch</th>
                        <th>Status</th>
                        <th class="actions">Issues</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in _workspaces)
                    {
                        <tr>
                            <td><strong>@w.Name</strong></td>
                            <td><code>@w.Owner/@w.Repo</code></td>
                            <td>@w.DefaultBranch</td>
                            <td><Badge>@w.Status</Badge></td>
                            <td class="actions">
                                @if (w.Kind == SourceProviderKind.GitHub)
                                {
                                    <Btn Size="Btn.ButtonSize.Sm"
                                         OnClick="@(() => SelectProject(w))"
                                         Disabled="@(w.Status != "Active")">
                                        Issues <Icon Name="arrow-right" Size="13" />
                                    </Btn>
                                }
                                else
                                {
                                    <span class="muted" style="font-size:12px">ADO — soon</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (_workspaces.Count == 0)
                    {
                        <tr><td colspan="5" class="data-empty">No projects yet — connect one above.</td></tr>
                    }
                </tbody>
            </table>
            </Panel>
        }
    }
    else
    {
        @* Issues sub-view for the selected project *@
        <div class="spine-back-bar">
            <Btn Size="Btn.ButtonSize.Sm" OnClick="@(() => { _selectedProject = null; _issues = null; _issueError = null; })">
                <Icon Name="arrow-left" Size="13" /> @_selectedProject.Name
            </Btn>
            <span class="spine-back-repo muted"><code>@_selectedProject.Owner/@_selectedProject.Repo</code></span>
        </div>

        @if (_loadingIssues)
        {
            <Spinner />
        }
        else if (_issueError is not null)
        {
            <Panel Title="Issues">
                <p class="login-error">@_issueError</p>
                <div class="form-actions">
                    <Btn OnClick="@(() => SelectProject(_selectedProject))">Retry</Btn>
                </div>
            </Panel>
        }
        else if (_issues is not null)
        {
            <Panel Title="@($"Open Issues · {_selectedProject.Name}")">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Title</th>
                        <th>Labels</th>
                        <th>Assignee</th>
                        <th class="actions">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in _issues)
                    {
                        <tr>
                            <td class="muted">#@issue.Number</td>
                            <td>
                                <a href="@issue.HtmlUrl" target="_blank" rel="noopener" class="spine-issue-link">
                                    @issue.Title
                                </a>
                            </td>
                            <td>
                                @foreach (var label in issue.Labels.Take(3))
                                {
                                    <Badge>@label</Badge>
                                }
                            </td>
                            <td class="muted">@(issue.AssigneeLogin ?? "—")</td>
                            <td class="actions">
                                <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Primary"
                                     OnClick="@(() => StartIssueSession(issue))"
                                     Disabled="_busy">
                                    Work on this <Icon Name="arrow-right" Size="13" />
                                </Btn>
                            </td>
                        </tr>
                    }
                    @if (_issues.Count == 0)
                    {
                        <tr><td colspan="5" class="data-empty">No open issues — project is all clear!</td></tr>
                    }
                </tbody>
            </table>
            </Panel>
        }
    }
}

@* ── RUNNERS TAB ───────────────────────────────────────────────────────────────────────── *@
else if (_tab == Tab.Runners)
{
    <Panel Title="Register a runner (a paired dev machine)">
        <div class="form-grid">
            <Field Label="Label">
                <input @bind="_runnerLabel" placeholder="Hoang's laptop" />
            </Field>
        </div>
        <div class="form-actions">
            <Btn Variant="Btn.ButtonVariant.Primary" OnClick="RegisterRunner" Disabled="_busy">
                @(_busy ? "Registering…" : "Register runner")
            </Btn>
        </div>
        @if (_newRunner is not null)
        {
            <div class="cred-readout">
                <p class="cred-readout-hint">
                    Pairing token — shown <strong>once</strong>. Set these on the dev machine, then run the AgentOS remote agent:
                </p>
                <textarea readonly rows="2">REMOTE_AGENT_ID=@_newRunner.Value.Id
REMOTE_AGENT_TOKEN=@_newRunner.Value.Token</textarea>
            </div>
        }
    </Panel>

    @if (_runners is null) { <Spinner /> }
    else
    {
        <Panel Title="@(_isAdmin ? "Runners (all members)" : "My Runners")">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Label</th>
                    @if (_isAdmin) { <th>Owner</th> }
                    <th>Status</th>
                    <th>Created</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _runners)
                {
                    <tr>
                        <td>@r.Label</td>
                        @if (_isAdmin) { <td><code>@(string.IsNullOrEmpty(r.OwnerUserId) ? "—" : r.OwnerUserId)</code></td> }
                        <td><Badge>@r.Status</Badge></td>
                        <td>@r.CreatedAtUtc.ToString("u")</td>
                        <td class="actions">
                            <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Danger"
                                 OnClick="@(() => RevokeRunner(r))" Disabled="@(_busyId == r.Id || r.Status == "Revoked")">
                                <Icon Name="x" Size="13" /> Revoke
                            </Btn>
                        </td>
                    </tr>
                }
                @if (_runners.Count == 0) { <tr><td colspan="@(_isAdmin ? 5 : 4)" class="data-empty">No runners yet — register one above.</td></tr> }
            </tbody>
        </table>
        </Panel>
    }
}

@* ── SESSIONS TAB ──────────────────────────────────────────────────────────────────────── *@
else if (_tab == Tab.Sessions)
{
    @if (_sessions is null) { <Spinner /> }
    else
    {
        <Panel Title="@(_isAdmin ? "Sessions (all members)" : "My Sessions")">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Project</th>
                    @if (_isAdmin) { <th>Member</th> }
                    <th>Status</th>
                    <th>Created</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _sessions)
                {
                    <tr>
                        <td>
                            @s.Title
                            @if (!string.IsNullOrEmpty(s.Error))
                            {
                                <br /><span class="muted" style="font-size:11px;color:var(--color-err,#e55)">@s.Error</span>
                            }
                        </td>
                        <td><code>@WorkspaceName(s.WorkspaceId)</code></td>
                        @if (_isAdmin) { <td><code>@(string.IsNullOrEmpty(s.MemberUserId) ? "—" : s.MemberUserId)</code></td> }
                        <td>
                            <Badge>@s.Status</Badge>
                            @if (!string.IsNullOrEmpty(s.PrUrl))
                            {
                                <br /><a href="@s.PrUrl" target="_blank" rel="noopener" style="font-size:11px">View PR</a>
                            }
                        </td>
                        <td>@s.CreatedAtUtc.ToString("u")</td>
                        <td class="actions">
                            @if (s.Status == "Draft")
                            {
                                <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Primary"
                                     OnClick="@(() => RunSession(s))"
                                     Disabled="@(_busyId == s.Id)">
                                    <Icon Name="play" Size="13" /> Run
                                </Btn>
                            }
                            <Btn Size="Btn.ButtonSize.Sm" OnClick="@(() => CloseSession(s))"
                                 Disabled="@(_busyId == s.Id || s.Status is "Closed" or "Running")">
                                <Icon Name="check" Size="13" /> Close
                            </Btn>
                        </td>
                    </tr>
                }
                @if (_sessions.Count == 0) { <tr><td colspan="@(_isAdmin ? 6 : 5)" class="data-empty">No sessions yet. Browse a project's issues to start one.</td></tr> }
            </tbody>
        </table>
        </Panel>
    }
}

@code {
    private enum Tab { Projects, Runners, Sessions }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private Tab _tab = Tab.Projects;
    private bool _resolved;
    private bool _loading;
    private bool _busy;
    private Guid? _busyId;

    private string _tenantId = "default";
    private string _userId = "";
    private bool _isAdmin;

    // ── Data ────────────────────────────────────────────────────────────────────────────────
    private IReadOnlyList<WorkspaceEntity>? _workspaces;
    private IReadOnlyList<RunnerEntity>? _runners;
    private IReadOnlyList<RemoteSessionEntity>? _sessions;

    // ── Projects → Issues state ─────────────────────────────────────────────────────────────
    private WorkspaceEntity? _selectedProject;
    private IReadOnlyList<GitHubIssue>? _issues;
    private bool _loadingIssues;
    private string? _issueError;

    // ── Runner registration form ─────────────────────────────────────────────────────────────
    private string _runnerLabel = "";
    private (Guid Id, string Token)? _newRunner;

    // ── Connect workspace form ───────────────────────────────────────────────────────────────
    private SourceProviderKind _wsKind = SourceProviderKind.GitHub;
    private string _wsName = "";
    private string _wsOwner = "";
    private string _wsRepo = "";
    private string _wsProject = "";
    private string _wsBranch = "";
    private string _wsToken = "";

    // ── Polling timer (runs while any session is in "Running" state) ─────────────────────────
    private System.Threading.Timer? _pollTimer;

    // ── Lifecycle ────────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var user = state.User;
            _tenantId = user.FindFirst("tenant")?.Value is { Length: > 0 } t ? t : "default";
            _userId = user.FindFirst("sub")?.Value ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
            _isAdmin = user.IsInRole("admin");
        }
        _resolved = true;
        await ReloadAll();
        // Start the poll timer stopped; RunSession will start it when needed.
        _pollTimer = new System.Threading.Timer(
            _ => InvokeAsync(PollRunningSessions),
            null,
            System.Threading.Timeout.Infinite,
            System.Threading.Timeout.Infinite);
    }

    public void Dispose() => _pollTimer?.Dispose();

    private async Task ReloadAll()
    {
        _loading = true;
        try
        {
            _workspaces = await Workspaces.ListForTenantAsync(_tenantId);

            var allRunners = await Runners.ListForTenantAsync(_tenantId);
            _runners = _isAdmin ? allRunners : allRunners.Where(r => r.OwnerUserId == _userId).ToList();

            var allSessions = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? allSessions : allSessions.Where(s => s.MemberUserId == _userId).ToList();
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Load failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PollRunningSessions()
    {
        try
        {
            var all = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? all : all.Where(s => s.MemberUserId == _userId).ToList();
            StateHasChanged();
            // Stop polling when no sessions are still running.
            if (_sessions.All(s => s.Status != "Running"))
            {
                _pollTimer?.Change(System.Threading.Timeout.Infinite, System.Threading.Timeout.Infinite);
            }
        }
        catch
        {
            // Suppress poll errors — next tick will retry.
        }
    }

    private void StartPolling()
    {
        // Fire after 5s, repeat every 5s.
        _pollTimer?.Change(TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private string WorkspaceName(Guid id) =>
        _workspaces?.FirstOrDefault(w => w.Id == id)?.Name ?? id.ToString("N")[..8];

    // ── Projects → Issues ────────────────────────────────────────────────────────────────────

    private async Task SelectProject(WorkspaceEntity project)
    {
        _selectedProject = project;
        _issues = null;
        _issueError = null;
        _loadingIssues = true;
        StateHasChanged();

        try
        {
            var pat = await ConfigStore.GetForTenantAsync(_tenantId, project.CredentialRef);
            if (string.IsNullOrEmpty(pat))
            {
                _issueError = "Could not retrieve workspace credentials. Reconnect the project.";
                return;
            }

            var descriptor = new WorkspaceDescriptor(
                project.Id, _tenantId, project.Kind, project.Owner, project.Repo,
                project.Project, project.DefaultBranch, pat);

            _issues = await IssueService.ListOpenIssuesAsync(descriptor);
        }
        catch (Exception ex)
        {
            _issueError = $"Failed to load issues: {ex.Message}";
        }
        finally
        {
            _loadingIssues = false;
        }
    }

    private async Task StartIssueSession(GitHubIssue issue)
    {
        if (_busy || _selectedProject is null) { return; }
        _busy = true;
        try
        {
            var entity = new RemoteSessionEntity
            {
                Id = Guid.NewGuid(),
                TenantId = _tenantId,
                WorkspaceId = _selectedProject.Id,
                MemberUserId = _userId,
                Title = $"#{issue.Number} {issue.Title}",
                Status = "Draft",
                IssueNumber = issue.Number,
                CreatedAtUtc = DateTimeOffset.UtcNow,
                CreatedByUserId = string.IsNullOrEmpty(_userId) ? null : _userId,
            };
            await Sessions.AddForTenantAsync(entity);
            Toasts.Show("Spine", $"Session created for issue #{issue.Number}. Switch to Sessions tab to track it.", ToastKind.Ok);

            var allSessions = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? allSessions : allSessions.Where(s => s.MemberUserId == _userId).ToList();
            _tab = Tab.Sessions;
            _selectedProject = null;
            _issues = null;
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Failed to create session: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _busy = false;
        }
    }

    // ── Run session (M5 — fire-and-forget AI pipeline) ──────────────────────────────────────

    private async Task RunSession(RemoteSessionEntity session)
    {
        if (_busyId == session.Id) { return; }
        _busyId = session.Id;
        try
        {
            // Look up workspace + PAT.
            var ws = _workspaces?.FirstOrDefault(w => w.Id == session.WorkspaceId);
            if (ws is null)
            {
                Toasts.Show("Spine", "Workspace not found — reload and try again.", ToastKind.Err);
                return;
            }
            var pat = await ConfigStore.GetForTenantAsync(_tenantId, ws.CredentialRef);
            if (string.IsNullOrEmpty(pat))
            {
                Toasts.Show("Spine", "Could not retrieve workspace credentials. Reconnect the project.", ToastKind.Err);
                return;
            }

            // Mark session Running immediately so UI reflects it.
            await Sessions.UpdateRunResultAsync(_tenantId, session.Id, "Running", null, null);
            var all = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? all : all.Where(s => s.MemberUserId == _userId).ToList();
            Toasts.Show("Spine", $"Session #{session.IssueNumber} is running — AI agent dispatched to runner.", ToastKind.Ok);
            StartPolling();

            // Fire-and-forget background work. Use a fresh DI scope so the LLM client +
            // repositories are properly scoped, independent of this Blazor circuit.
            var capturedTenantId = _tenantId;
            var capturedSession = session;
            var capturedWs = ws;
            var capturedPat = pat;
            _ = Task.Run(async () =>
            {
                try
                {
                    using var scope = ScopeFactory.CreateScope();
                    var agent = scope.ServiceProvider.GetRequiredService<AgentOs.Domain.Sessions.IIssueWorkAgent>();
                    var prService = scope.ServiceProvider.GetRequiredService<AgentOs.Domain.Workspaces.IPrCreationService>();
                    var sessRepo = scope.ServiceProvider.GetRequiredService<AgentOs.Modules.Sessions.Persistence.ISessionRepository>();

                    var issueRequest = new AgentOs.Domain.Sessions.IssueWorkRequest(
                        SessionId: capturedSession.Id,
                        TenantId: capturedTenantId,
                        MemberId: capturedSession.MemberUserId,
                        WorkspaceOwner: capturedWs.Owner,
                        WorkspaceRepo: capturedWs.Repo,
                        WorkspaceDefaultBranch: capturedWs.DefaultBranch,
                        IssueNumber: capturedSession.IssueNumber ?? 0,
                        IssueTitle: capturedSession.Title,
                        IssueBody: "");

                    var workResult = await agent.RunAsync(issueRequest).ConfigureAwait(false);
                    if (!workResult.Ok)
                    {
                        await sessRepo.UpdateRunResultAsync(capturedTenantId, capturedSession.Id,
                            "Failed", null, workResult.Error ?? "Agent failed without a reason.").ConfigureAwait(false);
                        return;
                    }

                    var descriptor = new AgentOs.Domain.Workspaces.WorkspaceDescriptor(
                        capturedWs.Id, capturedTenantId, capturedWs.Kind,
                        capturedWs.Owner, capturedWs.Repo, capturedWs.Project,
                        capturedWs.DefaultBranch, capturedPat);

                    var prResult = await prService.CreateFromBranchAsync(
                        descriptor,
                        workResult.BranchName,
                        $"fix: {capturedSession.Title}",
                        workResult.Summary).ConfigureAwait(false);

                    await sessRepo.UpdateRunResultAsync(
                        capturedTenantId, capturedSession.Id,
                        prResult.Ok ? "Done" : "Failed",
                        prResult.HtmlUrl,
                        prResult.Ok ? null : prResult.Error).ConfigureAwait(false);
                }
                catch (Exception ex)
                {
                    try
                    {
                        using var scope = ScopeFactory.CreateScope();
                        var sessRepo = scope.ServiceProvider.GetRequiredService<AgentOs.Modules.Sessions.Persistence.ISessionRepository>();
                        await sessRepo.UpdateRunResultAsync(capturedTenantId, capturedSession.Id,
                            "Failed", null, ex.Message).ConfigureAwait(false);
                    }
                    catch { /* best-effort */ }
                }
            });
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Run failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _busyId = null;
        }
    }

    // ── Runner management ────────────────────────────────────────────────────────────────────

    private async Task RegisterRunner()
    {
        if (_busy) { return; }
        if (string.IsNullOrWhiteSpace(_runnerLabel))
        {
            Toasts.Show("Spine", "A label is required.", ToastKind.Err);
            return;
        }
        _busy = true;
        try
        {
            var secret = Pairing.Issue();
            var entity = new RunnerEntity
            {
                Id = Guid.NewGuid(),
                TenantId = _tenantId,
                OwnerUserId = _userId,
                Label = _runnerLabel.Trim(),
                TokenHash = secret.TokenHash,
                Status = "Pending",
                CreatedAtUtc = DateTimeOffset.UtcNow,
                CreatedByUserId = string.IsNullOrEmpty(_userId) ? null : _userId,
            };
            await Runners.AddForTenantAsync(entity);
            _newRunner = (entity.Id, secret.Token);
            _runnerLabel = "";
            Toasts.Show("Spine", "Runner registered. Copy the pairing token now — it won't be shown again.", ToastKind.Ok);
            var r0 = await Runners.ListForTenantAsync(_tenantId);
            _runners = _isAdmin ? r0 : r0.Where(r => r.OwnerUserId == _userId).ToList();
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Register failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RevokeRunner(RunnerEntity r)
    {
        _busyId = r.Id;
        try
        {
            await Runners.SetStatusForTenantAsync(_tenantId, r.Id, "Revoked");
            Toasts.Show("Spine", $"Revoked '{r.Label}'.", ToastKind.Ok);
            var r0 = await Runners.ListForTenantAsync(_tenantId);
            _runners = _isAdmin ? r0 : r0.Where(r => r.OwnerUserId == _userId).ToList();
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Revoke failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _busyId = null;
        }
    }

    // ── Sessions ─────────────────────────────────────────────────────────────────────────────

    private async Task CloseSession(RemoteSessionEntity s)
    {
        _busyId = s.Id;
        try
        {
            await Sessions.CloseForTenantAsync(_tenantId, s.Id, DateTimeOffset.UtcNow);
            Toasts.Show("Spine", $"Closed '{s.Title}'.", ToastKind.Ok);
            var s0 = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? s0 : s0.Where(s => s.MemberUserId == _userId).ToList();
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Close failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _busyId = null;
        }
    }

    // ── Connect workspace ────────────────────────────────────────────────────────────────────

    private async Task ConnectWorkspace()
    {
        if (_busy) { return; }
        if (string.IsNullOrWhiteSpace(_wsName) || string.IsNullOrWhiteSpace(_wsOwner)
            || string.IsNullOrWhiteSpace(_wsRepo) || string.IsNullOrWhiteSpace(_wsToken))
        {
            Toasts.Show("Spine", "Name, owner, repository and token are required.", ToastKind.Err);
            return;
        }
        _busy = true;
        try
        {
            var input = new WorkspaceConnectInput(
                _wsName.Trim(), _wsKind, _wsOwner.Trim(), _wsRepo.Trim(),
                string.IsNullOrWhiteSpace(_wsProject) ? null : _wsProject.Trim(),
                string.IsNullOrWhiteSpace(_wsBranch) ? null : _wsBranch.Trim(),
                null, _wsToken);
            var result = await Connector.ConnectAsync(_tenantId, string.IsNullOrEmpty(_userId) ? null : _userId, input);
            if (result.Ok)
            {
                Toasts.Show("Spine", $"Connected '{_wsName.Trim()}'.", ToastKind.Ok);
                _wsName = _wsOwner = _wsRepo = _wsProject = _wsBranch = _wsToken = "";
                _workspaces = await Workspaces.ListForTenantAsync(_tenantId);
            }
            else
            {
                Toasts.Show("Spine", result.Error ?? "Connect failed.", ToastKind.Err);
            }
        }
        catch (Exception ex)
        {
            Toasts.Show("Spine", $"Connect failed: {ex.Message}", ToastKind.Err);
        }
        finally
        {
            _busy = false;
        }
    }
}
