@* SpineApp — Boards (a connected GitHub Projects v2 board, spanning many repos) → Tickets (board
   items across repos) → AI sessions. A board has a Repositories sub-list (the services under it) and
   a unified Tickets list filtered by repo / label / status. "Work on this" starts a session against
   the ticket's repo, then "Run" triggers the IssueWorkAgent → branch → PR.
   A Blazor Server circuit has no HttpContext, so ITenantContext is blank here — we read the tenant +
   user from AuthenticationState and call repos via tenant-explicit overloads. *@

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using AgentOs.Domain.Workspaces
@using AgentOs.Domain.Sessions
@using AgentOs.Modules.AppConfig
@using AgentOs.Modules.Integration
@using AgentOs.Modules.Pipeline.Decomposition
@using AgentOs.Modules.Workspaces
@using AgentOs.Modules.Workspaces.Persistence
@using AgentOs.Modules.Workspaces.Persistence.Entities
@using AgentOs.Modules.Sessions.Persistence
@using AgentOs.Modules.Sessions.Persistence.Entities
@using AgentOs.Domain.Pipeline
@using AgentOs.Modules.Pipeline.Pipeline
@using AgentOs.Modules.Pipeline.Sessions
@inject IWorkspaceRepository Workspaces
@inject IWorkspaceConnector Connector
@inject IRunnerRepository Runners
@inject ISessionRepository Sessions
@inject IRunnerPairingService Pairing
@inject IAppConfigStore ConfigStore
@inject IBoardTicketService BoardTicketSvc
@inject IBoardWriteService BoardWriteSvc
@inject AgentOs.Web.Shell.Services.ToastService Toasts
@inject ISessionRunFeed Feed
@inject IServiceScopeFactory ScopeFactory
@inject Microsoft.Extensions.Options.IOptions<PipelineOptions> PipelineOpts
@inject AgentOs.Web.Shell.Services.WindowManagerService WM
@implements IDisposable

<header class="page-head">
    <div>
        <h1 class="page-title">Spine · <code>@_tenantId</code></h1>
        <p class="page-sub">Boards → Tickets → AI sessions. Remote repo-execution path.</p>
    </div>
    <Btn OnClick="ReloadAll" Disabled="_loading">
        <Icon Name="arrow-clockwise" Size="14" /> Refresh
    </Btn>
</header>

<div class="spine-tabs">
    <button class="spine-tab @(_tab == Tab.Boards ? "active" : "")" @onclick="@(() => { _tab = Tab.Boards; _selectedBoard = null; })">
        Boards <Badge>@(_boards?.Count ?? 0)</Badge>
    </button>
    <button class="spine-tab @(_tab == Tab.Idea ? "active" : "")" @onclick="@(() => _tab = Tab.Idea)">
        Start from idea
    </button>
    <button class="spine-tab @(_tab == Tab.Runners ? "active" : "")" @onclick="@(() => _tab = Tab.Runners)">
        Runners <Badge>@(_runners?.Count ?? 0)</Badge>
    </button>
    <button class="spine-tab @(_tab == Tab.Sessions ? "active" : "")" @onclick="@(() => _tab = Tab.Sessions)">
        Sessions <Badge>@(_sessions?.Count ?? 0)</Badge>
    </button>
</div>

@if (!_resolved)
{
    <Spinner />
}

@* ── BOARDS TAB ───────────────────────────────────────────────────────────────────────────── *@
else if (_tab == Tab.Boards)
{
    @if (_selectedBoard is null)
    {
        @* Boards list view *@
        <Panel Title="Connect a board">
            <div class="form-grid">
                <Field Label="Provider">
                    <select class="prefs-select" @bind="_wsKind">
                        <option value="@SourceProviderKind.GitHub">GitHub Projects</option>
                        <option value="@SourceProviderKind.AzureDevOps">Azure DevOps</option>
                    </select>
                </Field>
                <Field Label="Name">
                    <input @bind="_wsName" placeholder="My product board" />
                </Field>
                <Field Label="@(_wsKind == SourceProviderKind.AzureDevOps ? "Organization" : "Owner (org or user)")">
                    <input @bind="_wsProjectOwner" placeholder="octo-org" />
                </Field>
                @if (_wsKind == SourceProviderKind.GitHub)
                {
                    <Field Label="Scope">
                        <select class="prefs-select" @bind="_wsScope">
                            <option value="org">Organization</option>
                            <option value="user">User</option>
                        </select>
                    </Field>
                }
                @if (_wsKind == SourceProviderKind.AzureDevOps)
                {
                    <Field Label="Project">
                        <input @bind="_wsProject" placeholder="MyProject" />
                    </Field>
                }
                <Field Label="Board number">
                    <input @bind="_wsNumberText" placeholder="5 (optional — leave blank for repos-only)" />
                    @if (_foundBoards is { Count: > 0 })
                    {
                        <select class="prefs-select" @onchange="OnBoardPicked">
                            <option value="">— pick from @_foundBoards.Count found —</option>
                            @foreach (var b in _foundBoards)
                            {
                                <option value="@b.Number">#@b.Number — @b.Title</option>
                            }
                        </select>
                    }
                    else if (_foundBoards is { Count: 0 })
                    {
                        <p class="muted spine-form-hint">No boards found for that owner + token.</p>
                    }
                </Field>
                <Field Label="Access token (PAT)">
                    <input type="password" @bind="_wsToken" placeholder="ghp_… (needs repo + read:project)" autocomplete="off" />
                </Field>
            </div>
            <div class="form-actions">
                <Btn Variant="Btn.ButtonVariant.Ghost" OnClick="FindBoards"
                     Disabled="_busy || _findingBoards || _wsKind != SourceProviderKind.GitHub">
                    @(_findingBoards ? "Finding…" : "Find boards")
                </Btn>
                <Btn Variant="Btn.ButtonVariant.Primary" OnClick="ConnectBoard" Disabled="_busy">
                    @(_busy ? "Connecting…" : "Connect")
                </Btn>
            </div>
            <p class="muted spine-form-hint">Token is validated, then stored encrypted — never shown again or kept on the row. A GitHub board number is its Projects v2 number (in the project URL).</p>
        </Panel>

        @if (_boards is null) { <Spinner /> }
        else
        {
            <Panel Title="Boards">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Board</th>
                        <th>Status</th>
                        <th class="actions">Open</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in _boards)
                    {
                        <tr>
                            <td><strong>@b.Name</strong></td>
                            <td>
                                <code>@b.ProjectOwner</code>
                                @if (b.ProjectNumber is not null)
                                {
                                    <span class="muted"> #@b.ProjectNumber</span>
                                }
                                else
                                {
                                    <span class="muted"> · repos only</span>
                                }
                            </td>
                            <td><Badge>@b.Status</Badge></td>
                            <td class="actions">
                                @if (b.Kind == SourceProviderKind.GitHub)
                                {
                                    <Btn Size="Btn.ButtonSize.Sm" OnClick="@(() => SelectBoard(b))">
                                        Open <Icon Name="arrow-right" Size="13" />
                                    </Btn>
                                }
                                else
                                {
                                    <span class="muted" style="font-size:12px">ADO — soon</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (_boards.Count == 0)
                    {
                        <tr><td colspan="4" class="data-empty">No boards yet — connect one above.</td></tr>
                    }
                </tbody>
            </table>
            </Panel>
        }
    }
    else
    {
        @* Board detail: repositories + unified tickets *@
        <div class="spine-back-bar">
            <Btn Size="Btn.ButtonSize.Sm" OnClick="CloseBoard">
                <Icon Name="arrow-left" Size="13" /> @_selectedBoard.Name
            </Btn>
            <span class="spine-back-repo muted">
                <code>@_selectedBoard.ProjectOwner@(_selectedBoard.ProjectNumber is not null ? $" #{_selectedBoard.ProjectNumber}" : "")</code>
            </span>
        </div>

        @* Repositories under the board *@
        <Panel Title="Repositories">
            <div class="form-grid">
                <Field Label="Owner">
                    <input @bind="_addRepoOwner" placeholder="octo-org" />
                </Field>
                <Field Label="Repository">
                    <input @bind="_addRepoName" placeholder="api-service" />
                </Field>
                <Field Label="Default branch">
                    <input @bind="_addRepoBranch" placeholder="main" />
                </Field>
            </div>
            <div class="form-actions">
                <Btn Variant="Btn.ButtonVariant.Primary" OnClick="AddRepo" Disabled="_busy">
                    @(_busy ? "Adding…" : "Add repository")
                </Btn>
            </div>
            @if (_repos is null) { <Spinner /> }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr><th>Repository</th><th>Branch</th><th class="actions">Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _repos)
                        {
                            <tr>
                                <td><code>@r.Owner/@r.Repo</code></td>
                                <td>@r.DefaultBranch</td>
                                <td class="actions">
                                    <Btn Size="Btn.ButtonSize.Sm"
                                         OnClick="@(() => SeedLabels(r))" Disabled="@(_busyId == r.Id)">
                                        <Icon Name="tag" Size="13" /> Seed labels
                                    </Btn>
                                    <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Danger"
                                         OnClick="@(() => RemoveRepo(r))" Disabled="@(_busyId == r.Id)">
                                        <Icon Name="x" Size="13" /> Remove
                                    </Btn>
                                </td>
                            </tr>
                        }
                        @if (_repos.Count == 0)
                        {
                            <tr><td colspan="3" class="data-empty">No repositories under this board yet — add the services it spans.</td></tr>
                        }
                    </tbody>
                </table>
            }
        </Panel>

        @* Unified tickets across the board's repos *@
        @if (_selectedBoard.ProjectNumber is null)
        {
            <Panel Title="Tickets">
                <p class="muted">This is a repos-only board. Reconnect it with a GitHub Projects v2 board number to pull tickets.</p>
            </Panel>
        }
        else if (_loadingTickets)
        {
            <Spinner />
        }
        else if (_ticketError is not null)
        {
            <Panel Title="Tickets">
                <p class="login-error">@_ticketError</p>
                <div class="form-actions">
                    <Btn OnClick="@(() => SelectBoard(_selectedBoard))">Retry</Btn>
                </div>
            </Panel>
        }
        else if (_tickets is not null)
        {
            <Panel Title="@($"Tickets · {_selectedBoard.Name}")">
                <div class="spine-filters">
                    <Field Label="Repository">
                        <select class="prefs-select" @bind="_filterRepo">
                            <option value="">All repos</option>
                            @foreach (var repo in TicketRepos())
                            {
                                <option value="@repo">@repo</option>
                            }
                        </select>
                    </Field>
                    <Field Label="Label">
                        <select class="prefs-select" @bind="_filterLabel">
                            <option value="">All labels</option>
                            @foreach (var label in TicketLabels())
                            {
                                <option value="@label">@label</option>
                            }
                        </select>
                    </Field>
                    <Field Label="Status">
                        <select class="prefs-select" @bind="_filterStatus">
                            <option value="">All statuses</option>
                            @foreach (var status in TicketStatuses())
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </Field>
                </div>
                @{ var readyCount = ReadyTickets().Count; }
                @if (readyCount > 0)
                {
                    <div class="form-actions spine-runall">
                        <Btn Variant="Btn.ButtonVariant.Primary" OnClick="RunAllReady" Disabled="_busy">
                            <Icon Name="lightning" Size="13" /> Run all ai:ready (@readyCount)
                        </Btn>
                    </div>
                }
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:64px">#</th>
                            <th>Title</th>
                            <th>Repo</th>
                            <th>Labels</th>
                            <th>Status</th>
                            <th>Assignee</th>
                            <th class="actions">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in FilteredTickets())
                        {
                            <tr>
                                <td class="muted">@(ticket.Number is null ? "draft" : $"#{ticket.Number}")</td>
                                <td>
                                    @if (ticket.Kind == BoardTicketKind.DraftIssue || string.IsNullOrEmpty(ticket.HtmlUrl))
                                    {
                                        @ticket.Title
                                    }
                                    else
                                    {
                                        <a href="@ticket.HtmlUrl" target="_blank" rel="noopener" class="spine-issue-link">@ticket.Title</a>
                                    }
                                </td>
                                <td>
                                    @if (ticket.RepoOwner is not null)
                                    {
                                        <code>@ticket.RepoOwner/@ticket.RepoName</code>
                                    }
                                    else
                                    {
                                        <span class="muted">—</span>
                                    }
                                </td>
                                <td>
                                    @foreach (var label in ticket.Labels.Take(3))
                                    {
                                        <Badge>@label</Badge>
                                    }
                                </td>
                                <td>@if (ticket.Status is not null) { <Badge>@ticket.Status</Badge> } else { <span class="muted">—</span> }</td>
                                <td class="muted">@(ticket.AssigneeLogin ?? "—")</td>
                                <td class="actions">
                                    <Btn Size="Btn.ButtonSize.Sm" OnClick="@(() => OpenInPipeline(ticket))"
                                         title="Open this ticket as a story in the Pipeline app (sandbox run)">
                                        <Icon Name="play" Size="13" /> Pipeline
                                    </Btn>
                                    <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Primary"
                                         OnClick="@(() => OpenWorkDialog(ticket))"
                                         Disabled="@(_busy || ticket.Kind == BoardTicketKind.DraftIssue || ticket.RepoOwner is null)">
                                        Work on this <Icon Name="arrow-right" Size="13" />
                                    </Btn>
                                </td>
                            </tr>
                        }
                        @if (!FilteredTickets().Any())
                        {
                            <tr><td colspan="7" class="data-empty">No tickets match — the board is clear or your filters are too narrow.</td></tr>
                        }
                    </tbody>
                </table>
            </Panel>
        }
    }
}

@* ── START FROM IDEA TAB (bootstrap) ──────────────────────────────────────────────────────── *@
else if (_tab == Tab.Idea)
{
    <Panel Title="Start from idea">
        <div class="spine-wizard-steps">
            <span class="spine-wizard-step @StepClass(IdeaStep.Input)">1 · Idea</span>
            <span class="spine-wizard-step @StepClass(IdeaStep.Review)">2 · Review</span>
            <span class="spine-wizard-step @StepClass(IdeaStep.Result)">3 · Create</span>
        </div>

        @if (_ideaStep == IdeaStep.Input)
        {
            <div class="form-grid">
                <Field Label="Target board">
                    <select class="prefs-select" @bind="_ideaBoardId" @bind:after="OnIdeaBoardChanged">
                        <option value="">Select a board…</option>
                        @foreach (var b in IdeaBoards())
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </Field>
                <Field Label="Target repository">
                    <select class="prefs-select" @bind="_ideaRepoId">
                        <option value="">Select a repo…</option>
                        @foreach (var r in _ideaRepos ?? Enumerable.Empty<WorkspaceRepoEntity>())
                        {
                            <option value="@r.Id">@r.Owner/@r.Repo</option>
                        }
                    </select>
                </Field>
            </div>
            <Field Label="Your idea">
                <textarea rows="5" @bind="_ideaText"
                          placeholder="Describe the feature or product you want to build. The Requirement agent turns this into a spec, then tickets."></textarea>
            </Field>
            @if (_ideaError is not null) { <p class="login-error">@_ideaError</p> }
            <div class="form-actions">
                <Btn Variant="Btn.ButtonVariant.Primary" OnClick="GenerateIdea" Disabled="_ideaBusy">
                    @(_ideaBusy ? "Generating…" : "Generate spec + tickets")
                </Btn>
            </div>
            <p class="muted spine-form-hint">Nothing is written to GitHub yet — you review and edit the tickets before anything is created. The board needs a Projects v2 number.</p>
        }
        else if (_ideaStep == IdeaStep.Review && _preview is not null)
        {
            <div class="spine-spec">
                <h3>@_preview.Spec.Title</h3>
                <p class="muted">@_preview.Spec.Summary</p>
            </div>

            <table class="data-table">
                <thead>
                    <tr><th>Title</th><th>Labels</th><th style="width:96px">Auto-run</th><th class="actions"></th></tr>
                </thead>
                <tbody>
                    @foreach (var row in _draftRows)
                    {
                        <tr>
                            <td><input class="spine-ticket-title" @bind="row.Title" /></td>
                            <td>@foreach (var l in row.Labels) { <Badge>@l</Badge> }</td>
                            <td>
                                <label class="spine-ai-toggle">
                                    <input type="checkbox" checked="@row.AiReady" aria-label="Auto-run this ticket (ai:ready)"
                                           @onchange="@(e => ToggleAiReady(row, e))" /> ai:ready
                                </label>
                            </td>
                            <td class="actions">
                                <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Danger" OnClick="@(() => _draftRows.Remove(row))">
                                    <Icon Name="x" Size="13" />
                                </Btn>
                            </td>
                        </tr>
                    }
                    @if (_draftRows.Count == 0)
                    {
                        <tr><td colspan="4" class="data-empty">No tickets — go back and regenerate.</td></tr>
                    }
                </tbody>
            </table>

            @if (_ideaError is not null) { <p class="login-error">@_ideaError</p> }
            <label class="spine-ai-toggle" style="margin:var(--space-3) 0 0">
                Engine
                <select @bind="_brain" @bind:after="OnBrainChanged" class="prefs-input" style="width:auto;margin-left:var(--space-2)">
                    <option value="Quick">Quick — runner edit loop</option>
                    <option value="Quality">Quality — 5-agent pipeline</option>
                </select>
            </label>
            @if (_brain == "Quality")
            {
                <p class="muted spine-form-hint">Quality runs the 5-agent SDLC pipeline server-side — up to @QualityNMax() QA iteration(s), higher server-token cost. Greenfield feature tickets only; bug/edit tickets are refused.</p>
            }
            <label class="spine-ai-toggle" style="margin:var(--space-3) 0">
                <input type="checkbox" @bind="_runOnMachine" disabled="@(_brain == "Quality")" aria-label="Run on my machine" />
                Run on my machine — your paired runner's CLI does the work (0 server tokens)
            </label>
            @if (_runOnMachine)
            {
                <label class="spine-ai-toggle" style="margin:0 0 var(--space-3)">
                    CLI agent
                    <select @bind="_cliProfile" class="prefs-input" style="width:auto;margin-left:var(--space-2)">
                        <option value="claude">Claude Code</option>
                        <option value="codex">Codex</option>
                    </select>
                </label>
            }
            @if (_runOnMachine && !HasRunner())
            {
                <p class="muted spine-form-hint">No paired runner yet — register one in the <strong>Runners</strong> tab and start the AgentOS remote agent (@_cliProfile) on your machine first.</p>
            }
            <div class="form-actions">
                <Btn OnClick="@(() => { _ideaStep = IdeaStep.Input; _ideaError = null; })" Disabled="_ideaBusy">Back</Btn>
                <Btn Variant="Btn.ButtonVariant.Primary" OnClick="@(() => CreateTickets(true))" Disabled="@(_ideaBusy || _draftRows.Count == 0)">
                    @(_ideaBusy ? "Working…" : "Create & run all ready")
                </Btn>
                <Btn OnClick="@(() => CreateTickets(false))" Disabled="@(_ideaBusy || _draftRows.Count == 0)">
                    Create only
                </Btn>
            </div>
            <p class="muted spine-form-hint">Creates real GitHub issues on the selected repo and adds them to the board (labels seeded first). <strong>Create &amp; run</strong> then starts an AI session on every <code>ai:ready</code> ticket — review the list above first; this is the one human gate.</p>
        }
        else if (_ideaStep == IdeaStep.Result)
        {
            <p>Created <strong>@_createdTickets.Count</strong> ticket(s).</p>
            <table class="data-table">
                <thead><tr><th style="width:64px">#</th><th>Title</th></tr></thead>
                <tbody>
                    @foreach (var t in _createdTickets)
                    {
                        <tr>
                            <td class="muted">#@t.Number</td>
                            <td><a href="@t.HtmlUrl" target="_blank" rel="noopener" class="spine-issue-link">@t.Title</a></td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="form-actions">
                <Btn Variant="Btn.ButtonVariant.Primary" OnClick="ResetIdea">Start another</Btn>
                <Btn OnClick="@(() => { _tab = Tab.Boards; ResetIdea(); })">Go to boards</Btn>
            </div>
        }
    </Panel>
}

@* ── RUNNERS TAB ───────────────────────────────────────────────────────────────────────────── *@
else if (_tab == Tab.Runners)
{
    <Panel Title="Register a runner (a paired dev machine)">
        <div class="form-grid">
            <Field Label="Label">
                <input @bind="_runnerLabel" placeholder="Hoang's laptop" />
            </Field>
        </div>
        <div class="form-actions">
            <Btn Variant="Btn.ButtonVariant.Primary" OnClick="RegisterRunner" Disabled="_busy">
                @(_busy ? "Registering…" : "Register runner")
            </Btn>
        </div>
        @if (_newRunner is not null)
        {
            <div class="cred-readout">
                <p class="cred-readout-hint">
                    Pairing token — shown <strong>once</strong>. Set these on the dev machine, then run the AgentOS remote agent:
                </p>
                <textarea readonly rows="2">REMOTE_AGENT_ID=@_newRunner.Value.Id
REMOTE_AGENT_TOKEN=@_newRunner.Value.Token</textarea>
            </div>
        }
    </Panel>

    @if (_runners is null) { <Spinner /> }
    else
    {
        <Panel Title="@(_isAdmin ? "Runners (all members)" : "My Runners")">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Label</th>
                    @if (_isAdmin) { <th>Owner</th> }
                    <th>Status</th>
                    <th>Created</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _runners)
                {
                    <tr>
                        <td>@r.Label</td>
                        @if (_isAdmin) { <td><code>@(string.IsNullOrEmpty(r.OwnerUserId) ? "—" : r.OwnerUserId)</code></td> }
                        <td><Badge>@r.Status</Badge></td>
                        <td>@r.CreatedAtUtc.ToString("u")</td>
                        <td class="actions">
                            <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Danger"
                                 OnClick="@(() => RevokeRunner(r))" Disabled="@(_busyId == r.Id || r.Status == "Revoked")">
                                <Icon Name="x" Size="13" /> Revoke
                            </Btn>
                        </td>
                    </tr>
                }
                @if (_runners.Count == 0) { <tr><td colspan="@(_isAdmin ? 5 : 4)" class="data-empty">No runners yet — register one above.</td></tr> }
            </tbody>
        </table>
        </Panel>
    }
}

@* ── SESSIONS TAB ──────────────────────────────────────────────────────────────────────────── *@
else if (_tab == Tab.Sessions)
{
    @if (_sessions is null) { <Spinner /> }
    else
    {
        <Panel Title="@(_isAdmin ? "Sessions (all members)" : "My Sessions")">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Board</th>
                    <th>Repos</th>
                    @if (_isAdmin) { <th>Member</th> }
                    <th>Status</th>
                    <th>Created</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _sessions)
                {
                    <tr>
                        <td>
                            @s.Title
                            @if (!string.IsNullOrEmpty(s.Error))
                            {
                                <br /><span class="spine-session-repo-err" style="font-size:11px">@s.Error</span>
                            }
                        </td>
                        <td><code>@BoardName(s.WorkspaceId)</code></td>
                        <td>
                            @{ var sessionRepos = SessionReposFor(s.Id); }
                            @if (sessionRepos.Count > 0)
                            {
                                @foreach (var r in sessionRepos)
                                {
                                    <div class="spine-session-repo">
                                        <code>@r.Owner/@r.Repo</code>
                                        <Badge>@r.Status</Badge>
                                        @if (!string.IsNullOrEmpty(r.PrUrl))
                                        {
                                            <a href="@r.PrUrl" target="_blank" rel="noopener">PR</a>
                                        }
                                        @if (!string.IsNullOrEmpty(r.Error))
                                        {
                                            <span class="muted spine-session-repo-err" title="@r.Error">!</span>
                                        }
                                    </div>
                                }
                            }
                            else if (!string.IsNullOrEmpty(s.RepoName))
                            {
                                <code>@s.RepoOwner/@s.RepoName</code>
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </td>
                        @if (_isAdmin) { <td><code>@(string.IsNullOrEmpty(s.MemberUserId) ? "—" : s.MemberUserId)</code></td> }
                        <td><Badge>@s.Status</Badge></td>
                        <td>@s.CreatedAtUtc.ToString("u")</td>
                        <td class="actions">
                            @if (s.Status == "Draft")
                            {
                                <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Primary"
                                     OnClick="@(() => RunSession(s))"
                                     Disabled="@(_busyId == s.Id)">
                                    <Icon Name="play" Size="13" /> Run
                                </Btn>
                            }
                            <Btn Size="Btn.ButtonSize.Sm" OnClick="@(() => CloseSession(s))"
                                 Disabled="@(_busyId == s.Id || s.Status is "Closed" or "Running")">
                                <Icon Name="check" Size="13" /> Close
                            </Btn>
                        </td>
                    </tr>
                    @if (_activity.TryGetValue(s.Id, out var feed) && feed.Count > 0)
                    {
                        <tr class="spine-activity-tr">
                            <td colspan="@(_isAdmin ? 7 : 6)">
                                <div class="spine-activity">
                                    @foreach (var ev in feed.TakeLast(8))
                                    {
                                        <div class="spine-activity-row">
                                            <span class="spine-activity-time">@ev.At.ToLocalTime().ToString("HH:mm:ss")</span>
                                            <span>@ev.Message</span>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                @if (_sessions.Count == 0) { <tr><td colspan="@(_isAdmin ? 7 : 6)" class="data-empty">No sessions yet. Open a board and start one from a ticket.</td></tr> }
            </tbody>
        </table>
        </Panel>
    }
}

@* ── Work dialog: pick which repo(s) the ticket maps to ──────────────────────────────────── *@
<Dialog Show="_showWorkDialog" Title="@($"Work on #{_workTicket?.Number}")" OnClose="CloseWorkDialog">
    <ChildContent>
        <p class="muted">Pick the repositories this ticket spans. The AI works each one and opens a PR per repo.</p>
        <div class="spine-repo-picker">
            @foreach (var opt in _workRepoOptions)
            {
                <label class="spine-repo-option">
                    <input type="checkbox" @bind="opt.Selected" aria-label="@($"Include {opt.Owner}/{opt.Repo} in this session")" />
                    <code>@opt.Owner/@opt.Repo</code>
                    <span class="muted">@opt.DefaultBranch</span>
                </label>
            }
            @if (_workRepoOptions.Count == 0)
            {
                <p class="muted">No repositories available — add one under the board first.</p>
            }
        </div>
        <label class="spine-ai-toggle" style="margin-top:var(--space-3)">
            Engine
            <select @bind="_brain" @bind:after="OnBrainChanged" class="prefs-input" style="width:auto;margin-left:var(--space-2)">
                <option value="Quick">Quick — runner edit loop</option>
                <option value="Quality">Quality — 5-agent pipeline</option>
            </select>
        </label>
        @if (_brain == "Quality")
        {
            <p class="muted spine-form-hint">Quality runs the 5-agent SDLC pipeline server-side — up to @QualityNMax() QA iteration(s), higher server-token cost. Greenfield feature tickets only; bug/edit tickets are refused.</p>
        }
        <label class="spine-ai-toggle" style="margin-top:var(--space-3)">
            <input type="checkbox" @bind="_runOnMachine" disabled="@(_brain == "Quality")" aria-label="Run on my machine" />
            Run on my machine — your paired runner's CLI does the work (0 server tokens)
        </label>
        @if (_runOnMachine)
        {
            <label class="spine-ai-toggle" style="margin:0 0 var(--space-3)">
                CLI agent
                <select @bind="_cliProfile" class="prefs-input" style="width:auto;margin-left:var(--space-2)">
                    <option value="claude">Claude Code</option>
                    <option value="codex">Codex</option>
                </select>
            </label>
        }
        @if (_runOnMachine && !HasRunner())
        {
            <p class="muted">No paired runner yet — register one in the Runners tab first.</p>
        }
    </ChildContent>
    <Footer>
        <Btn OnClick="CloseWorkDialog">Cancel</Btn>
        <Btn Variant="Btn.ButtonVariant.Primary" OnClick="ConfirmWorkSession" Disabled="_busy">Create session</Btn>
    </Footer>
</Dialog>

@code {
    private enum Tab { Boards, Idea, Runners, Sessions }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private Tab _tab = Tab.Boards;
    private bool _resolved;
    private bool _loading;
    private bool _busy;
    private Guid? _busyId;

    private string _tenantId = "default";
    private string _userId = "";
    private bool _isAdmin;

    // ── Data ────────────────────────────────────────────────────────────────────────────────
    private IReadOnlyList<WorkspaceEntity>? _boards;
    private IReadOnlyList<RunnerEntity>? _runners;
    private IReadOnlyList<RemoteSessionEntity>? _sessions;
    private IReadOnlyList<SessionRepoEntity>? _sessionRepos;

    // ── Live run activity (M6 — a live event stream backs the feed; the poll is now just a backstop) ──
    private readonly Dictionary<Guid, List<SessionRunEvent>> _activity = new();
    private readonly System.Collections.Concurrent.ConcurrentQueue<SessionRunEvent> _incoming = new();
    private System.Threading.CancellationTokenSource? _cts;
    private System.Threading.Timer? _renderTimer;   // coalesces feed renders (~150ms) to avoid burst thrash

    // ── Board detail (repos + tickets) ────────────────────────────────────────────────────────
    private WorkspaceEntity? _selectedBoard;
    private IReadOnlyList<WorkspaceRepoEntity>? _repos;
    private IReadOnlyList<BoardTicket>? _tickets;
    private bool _loadingTickets;
    private string? _ticketError;

    // ── Work dialog (ticket → repo multi-select) ───────────────────────────────────────────────
    private BoardTicket? _workTicket;
    private bool _showWorkDialog;
    private readonly List<RepoOption> _workRepoOptions = new();

    private sealed class RepoOption
    {
        public string Owner { get; set; } = "";
        public string Repo { get; set; } = "";
        public string DefaultBranch { get; set; } = "main";
        public Guid? WorkspaceRepoId { get; set; }
        public bool Selected { get; set; }
    }

    // Ticket filters (client-side over the loaded list).
    private string _filterRepo = "";
    private string _filterLabel = "";
    private string _filterStatus = "";

    // ── Add-repo form ─────────────────────────────────────────────────────────────────────────
    private string _addRepoOwner = "";
    private string _addRepoName = "";
    private string _addRepoBranch = "";

    // ── Runner registration form ─────────────────────────────────────────────────────────────
    private string _runnerLabel = "";
    private (Guid Id, string Token)? _newRunner;

    // ── "Start from idea" wizard (bootstrap) ─────────────────────────────────────────────────
    private enum IdeaStep { Input, Review, Result }
    private IdeaStep _ideaStep = IdeaStep.Input;
    private string _ideaText = "";
    private string _ideaBoardId = "";
    private string _ideaRepoId = "";
    private IReadOnlyList<WorkspaceRepoEntity>? _ideaRepos;
    private bool _ideaBusy;
    private string? _ideaError;
    // "Run on my machine" — route the issue-work loop to the member's paired dev-machine CLI (claude-code
    // / codex) instead of the server LLM. Shared by the idea-wizard auto-run + the Work-on-this dialog.
    private bool _runOnMachine;
    private string _cliProfile = "claude";   // which subscription CLI runs on-machine (claude | codex)
    private string _brain = "Quick";         // which engine runs the session (Quick = runner edit loop | Quality = 5-agent pipeline)
    private BootstrapPreview? _preview;
    private readonly List<DraftRow> _draftRows = new();
    private IReadOnlyList<CreatedTicket> _createdTickets = Array.Empty<CreatedTicket>();

    private sealed class DraftRow
    {
        public string Title { get; set; } = "";
        public string Body { get; set; } = "";
        public List<string> Labels { get; set; } = new();
        public bool AiReady { get; set; }
    }

    // ── Connect board form ───────────────────────────────────────────────────────────────────
    private SourceProviderKind _wsKind = SourceProviderKind.GitHub;
    private string _wsName = "";
    private string _wsProjectOwner = "";
    private string _wsScope = "org";
    private string _wsNumberText = "";
    private string _wsProject = "";
    private string _wsToken = "";
    // "Find boards" picker: null = not searched yet; empty = searched, none found.
    private IReadOnlyList<BoardSummary>? _foundBoards;
    private bool _findingBoards;

    // ── Polling timer (runs while any session is in "Running" state) ─────────────────────────
    private System.Threading.Timer? _pollTimer;

    // ── Lifecycle ────────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var user = state.User;
            _tenantId = user.GetTenantId() ?? string.Empty;
            _userId = user.GetUserId() ?? "";
            _isAdmin = user.IsAdmin();
        }
        _resolved = true;
        // No tenant on the token → nothing tenant-scoped to load (fail closed; never read the `default`
        // workspace for a malformed sign-in). The empty-state UI handles _tenantId == "".
        if (_tenantId.Length == 0) { return; }
        await ReloadAll();
        _pollTimer = new System.Threading.Timer(
            _ => InvokeAsync(PollRunningSessions),
            null,
            System.Threading.Timeout.Infinite,
            System.Threading.Timeout.Infinite);

        // Subscribe to the live session-run stream for this tenant (background loop, tied to the circuit).
        _cts = new System.Threading.CancellationTokenSource();
        _ = ListenAsync(_cts.Token);
        // Coalesce feed renders: fold queued events + render at most once per ~150ms (see FlushFeed).
        _renderTimer = new System.Threading.Timer(
            _ => InvokeAsync(FlushFeed), null,
            TimeSpan.FromMilliseconds(150), TimeSpan.FromMilliseconds(150));
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
        _renderTimer?.Dispose();
        if (_cts is not null)
        {
            _cts.Cancel();
            _cts.Dispose();
        }
    }

    private async Task ReloadAll()
    {
        _loading = true;
        try
        {
            _boards = await Workspaces.ListForTenantAsync(_tenantId);

            var allRunners = await Runners.ListForTenantAsync(_tenantId);
            _runners = _isAdmin ? allRunners : allRunners.Where(r => r.OwnerUserId == _userId).ToList();

            var allSessions = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? allSessions : allSessions.Where(s => s.MemberUserId == _userId).ToList();
            _sessionRepos = await Sessions.ListAllReposForTenantAsync(_tenantId);
        }
        catch (System.Net.Http.HttpRequestException ex) { HandleLoadError(ex); }
        catch (InvalidOperationException ex) { HandleLoadError(ex); }
        catch (System.IO.IOException ex) { HandleLoadError(ex); }
        catch (TimeoutException ex) { HandleLoadError(ex); }
        finally
        {
            _loading = false;
        }

        void HandleLoadError(Exception ex) =>
            Toasts.Show("Spine", $"Load failed: {ex.Message}", ToastKind.Err);
    }

    private async Task PollRunningSessions()
    {
        try
        {
            var all = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? all : all.Where(s => s.MemberUserId == _userId).ToList();
            _sessionRepos = await Sessions.ListAllReposForTenantAsync(_tenantId);
            StateHasChanged();
            if (_sessions.All(s => s.Status != "Running"))
            {
                _pollTimer?.Change(System.Threading.Timeout.Infinite, System.Threading.Timeout.Infinite);
            }
        }
        // Suppress poll errors — next tick will retry.
        catch (System.Net.Http.HttpRequestException ex) { _ = ex.Message; }
        catch (System.IO.IOException ex) { _ = ex.Message; }
        catch (InvalidOperationException ex) { _ = ex.Message; }
        catch (TimeoutException ex) { _ = ex.Message; }
    }

    // Backstop only — the live stream drives immediate updates; this slow tick reconciles from the DB
    // in case an event was dropped or this circuit joined after the run's early events had passed.
    private void StartPolling() => _pollTimer?.Change(TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));

    // ── Live activity subscription (M6) ──────────────────────────────────────────────────────────
    private async Task ListenAsync(CancellationToken ct)
    {
        try
        {
            // Lean producer: just enqueue. FlushFeed (the ~150ms render timer) folds events into _activity
            // and renders ONCE per tick, so an event burst during a run can't thrash the circuit.
            await foreach (var ev in Feed.Subscribe(_tenantId, ct))
            {
                _incoming.Enqueue(ev);
            }
        }
        catch (OperationCanceledException) { /* circuit closing — expected */ }
        // Stream fault — the backstop poll still reconciles from the DB.
        catch (Microsoft.AspNetCore.SignalR.HubException ex) { _ = ex.Message; }
        catch (System.Net.Http.HttpRequestException ex) { _ = ex.Message; }
        catch (System.IO.IOException ex) { _ = ex.Message; }
        catch (InvalidOperationException ex) { _ = ex.Message; }
    }

    // Runs on the circuit thread (via InvokeAsync from the render timer): drain queued events, fold them
    // into the per-session feed, and render at most once per tick.
    private async Task FlushFeed()
    {
        if (_incoming.IsEmpty) { return; }

        var changed = false;
        var sawTerminal = false;
        while (_incoming.TryDequeue(out var ev))
        {
            // Surface activity only for sessions this user can see (the stream is per-tenant).
            if (_sessions is null || !_sessions.Any(s => s.Id == ev.SessionId)) { continue; }
            if (!_activity.TryGetValue(ev.SessionId, out var list))
            {
                list = new List<SessionRunEvent>();
                _activity[ev.SessionId] = list;
            }
            list.Add(ev);
            if (list.Count > 40) { list.RemoveRange(0, list.Count - 40); }
            changed = true;
            if (ev.Kind is SessionRunEventKind.RepoDone or SessionRunEventKind.Done or SessionRunEventKind.Failed)
            {
                sawTerminal = true;
            }
        }

        // The DB stays authoritative — re-read on terminal/per-repo events so PR links + final status are
        // right even if a stream event was dropped.
        if (sawTerminal) { await ReloadSessionsState(); }
        if (changed || sawTerminal) { StateHasChanged(); }
    }

    private async Task ReloadSessionsState()
    {
        try
        {
            var all = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? all : all.Where(s => s.MemberUserId == _userId).ToList();
            _sessionRepos = await Sessions.ListAllReposForTenantAsync(_tenantId);
        }
        // Best-effort; the next event or poll retries.
        catch (System.Net.Http.HttpRequestException ex) { _ = ex.Message; }
        catch (System.IO.IOException ex) { _ = ex.Message; }
        catch (InvalidOperationException ex) { _ = ex.Message; }
        catch (TimeoutException ex) { _ = ex.Message; }
    }

    private string BoardName(Guid id) =>
        _boards?.FirstOrDefault(w => w.Id == id)?.Name ?? id.ToString("N")[..8];

    // ── Board detail ───────────────────────────────────────────────────────────────────────────

    private void CloseBoard()
    {
        _selectedBoard = null;
        _repos = null;
        _tickets = null;
        _ticketError = null;
        _filterRepo = _filterLabel = _filterStatus = "";
    }

    private async Task SelectBoard(WorkspaceEntity board)
    {
        _selectedBoard = board;
        _repos = null;
        _tickets = null;
        _ticketError = null;
        _filterRepo = _filterLabel = _filterStatus = "";
        _loadingTickets = board.ProjectNumber is not null;
        StateHasChanged();

        try
        {
            _repos = await Workspaces.ListReposForTenantAsync(_tenantId, board.Id);

            if (board.ProjectNumber is null)
            {
                return; // Repos-only board — no tickets to load.
            }

            var pat = await ConfigStore.GetForTenantAsync(_tenantId, board.CredentialRef);
            if (string.IsNullOrEmpty(pat))
            {
                _ticketError = "Could not retrieve board credentials. Reconnect the board.";
                return;
            }

            var descriptor = new BoardDescriptor(
                board.Id, _tenantId, board.Kind, board.ProjectOwner, board.ProjectScope,
                board.ProjectNumber, board.ProjectNodeId, pat, board.Project);
            var result = await BoardTicketSvc.ListTicketsAsync(descriptor);
            _tickets = result.Items;
        }
        catch (System.Net.Http.HttpRequestException ex) { _ticketError = $"Failed to load tickets: {ex.Message}"; }
        catch (System.Text.Json.JsonException ex) { _ticketError = $"Failed to load tickets: {ex.Message}"; }
        catch (InvalidOperationException ex) { _ticketError = $"Failed to load tickets: {ex.Message}"; }
        catch (System.IO.IOException ex) { _ticketError = $"Failed to load tickets: {ex.Message}"; }
        catch (TimeoutException ex) { _ticketError = $"Failed to load tickets: {ex.Message}"; }
        finally
        {
            _loadingTickets = false;
        }
    }

    private IEnumerable<string> TicketRepos() => _tickets is null
        ? Array.Empty<string>()
        : _tickets.Where(t => t.RepoOwner is not null)
            .Select(t => $"{t.RepoOwner}/{t.RepoName}")
            .Distinct()
            .OrderBy(s => s);

    private IEnumerable<string> TicketLabels() => _tickets is null
        ? Array.Empty<string>()
        : _tickets.SelectMany(t => t.Labels).Distinct().OrderBy(s => s);

    private IEnumerable<string> TicketStatuses() => _tickets is null
        ? Array.Empty<string>()
        : _tickets.Where(t => t.Status is not null).Select(t => t.Status!).Distinct().OrderBy(s => s);

    private IEnumerable<BoardTicket> FilteredTickets()
    {
        if (_tickets is null) { return Array.Empty<BoardTicket>(); }
        return _tickets.Where(MatchesFilters);

        bool MatchesFilters(BoardTicket t)
        {
            var matchesRepo = string.IsNullOrEmpty(_filterRepo) || $"{t.RepoOwner}/{t.RepoName}" == _filterRepo;
            var matchesLabel = string.IsNullOrEmpty(_filterLabel) || t.Labels.Contains(_filterLabel);
            var matchesStatus = string.IsNullOrEmpty(_filterStatus) || t.Status == _filterStatus;
            return matchesRepo && matchesLabel && matchesStatus;
        }
    }

    // ── Repos under a board ──────────────────────────────────────────────────────────────────────

    private async Task AddRepo()
    {
        if (_busy || _selectedBoard is null) { return; }
        if (string.IsNullOrWhiteSpace(_addRepoOwner) || string.IsNullOrWhiteSpace(_addRepoName))
        {
            Toasts.Show("Spine", "Owner and repository are required.", ToastKind.Err);
            return;
        }
        _busy = true;
        try
        {
            var result = await Connector.AddRepoAsync(
                _tenantId, _selectedBoard.Id, _addRepoOwner.Trim(), _addRepoName.Trim(),
                string.IsNullOrWhiteSpace(_addRepoBranch) ? null : _addRepoBranch.Trim());
            if (result.Ok)
            {
                Toasts.Show("Spine", $"Added {_addRepoOwner.Trim()}/{_addRepoName.Trim()}.", ToastKind.Ok);
                _addRepoOwner = _addRepoName = _addRepoBranch = "";
                _repos = await Workspaces.ListReposForTenantAsync(_tenantId, _selectedBoard.Id);
            }
            else
            {
                Toasts.Show("Spine", result.Error ?? "Could not add the repository.", ToastKind.Err);
            }
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Add failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Add failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Add failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Add failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveRepo(WorkspaceRepoEntity repo)
    {
        if (_selectedBoard is null) { return; }
        _busyId = repo.Id;
        try
        {
            await Workspaces.RemoveRepoForTenantAsync(_tenantId, repo.Id);
            Toasts.Show("Spine", $"Removed {repo.Owner}/{repo.Repo}.", ToastKind.Ok);
            _repos = await Workspaces.ListReposForTenantAsync(_tenantId, _selectedBoard.Id);
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Remove failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Remove failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Remove failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Remove failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busyId = null;
        }
    }

    // Seed the standard label taxonomy onto one repo under the board. Idempotent: already-present
    // labels are skipped. Writes to real GitHub, so it surfaces scope/credential errors as toasts.
    private async Task SeedLabels(WorkspaceRepoEntity repo)
    {
        if (_selectedBoard is null) { return; }
        _busyId = repo.Id;
        try
        {
            var pat = await ConfigStore.GetForTenantAsync(_tenantId, _selectedBoard.CredentialRef);
            if (string.IsNullOrEmpty(pat))
            {
                Toasts.Show("Spine", "Could not retrieve board credentials. Reconnect the board.", ToastKind.Err);
                return;
            }

            var descriptor = RepoDescriptor(_selectedBoard, _tenantId, repo.Owner, repo.Repo, repo.DefaultBranch, pat);
            var result = await BoardWriteSvc.EnsureLabelsAsync(descriptor, StandardLabels.All);

            Toasts.Show("Spine",
                $"{repo.Owner}/{repo.Repo}: {result.Created.Count} label(s) created, {result.Existing.Count} already present.",
                ToastKind.Ok);
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Seed failed: {ex.Message}", ToastKind.Err); }
        catch (System.Text.Json.JsonException ex) { Toasts.Show("Spine", $"Seed failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Seed failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Seed failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Seed failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busyId = null;
        }
    }

    // ── "Start from idea" wizard (bootstrap) ─────────────────────────────────────────────────────

    // Only boards with a Projects v2 number can take new tickets (each issue is added to the board).
    private IEnumerable<WorkspaceEntity> IdeaBoards()
        => _boards?.Where(b => b.ProjectNumber is not null) ?? Enumerable.Empty<WorkspaceEntity>();

    private string StepClass(IdeaStep step)
        => _ideaStep == step ? "active" : (_ideaStep > step ? "done" : "");

    private async Task OnIdeaBoardChanged()
    {
        _ideaRepoId = "";
        _ideaRepos = null;
        var board = IdeaBoards().FirstOrDefault(b => b.Id.ToString() == _ideaBoardId);
        if (board is not null)
        {
            _ideaRepos = await Workspaces.ListReposForTenantAsync(_tenantId, board.Id);
        }
    }

    // Generate spec + tickets from the idea. The bootstrap service (and the LLM-backed agents it
    // builds) is resolved LAZILY in a fresh scope — never @inject'd — so opening the app never eagerly
    // constructs an LLM client and crashes the circuit (the documented eager-DI landmine).
    private async Task GenerateIdea()
    {
        if (_ideaBusy) { return; }
        if (string.IsNullOrWhiteSpace(_ideaText))
        {
            _ideaError = "Describe your idea first.";
            return;
        }
        if (string.IsNullOrEmpty(_ideaBoardId) || string.IsNullOrEmpty(_ideaRepoId))
        {
            _ideaError = "Pick a target board and repository.";
            return;
        }
        _ideaBusy = true;
        _ideaError = null;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<IIdeaBootstrapService>();
            _preview = await svc.GenerateAsync(_ideaText.Trim());

            _draftRows.Clear();
            foreach (var t in _preview.Tickets)
            {
                _draftRows.Add(new DraftRow
                {
                    Title = t.Title,
                    Body = t.Body,
                    Labels = t.Labels.ToList(),
                    AiReady = t.AiReady,
                });
            }
            _ideaStep = IdeaStep.Review;
        }
        catch (System.Net.Http.HttpRequestException ex) { _ideaError = $"Generation failed: {ex.Message}"; }
        catch (System.Text.Json.JsonException ex) { _ideaError = $"Generation failed: {ex.Message}"; }
        catch (InvalidOperationException ex) { _ideaError = $"Generation failed: {ex.Message}"; }
        catch (System.IO.IOException ex) { _ideaError = $"Generation failed: {ex.Message}"; }
        catch (TimeoutException ex) { _ideaError = $"Generation failed: {ex.Message}"; }
        finally
        {
            _ideaBusy = false;
        }
    }

    // Flip a ticket's ai gate, keeping the ai:ready / needs-human label in sync with the flag.
    private static void ToggleAiReady(DraftRow row, ChangeEventArgs e)
    {
        row.AiReady = e.Value is true;
        row.Labels.RemoveAll(l =>
            string.Equals(l, StandardLabels.AiReady, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(l, StandardLabels.NeedsHuman, StringComparison.OrdinalIgnoreCase));
        row.Labels.Add(row.AiReady ? StandardLabels.AiReady : StandardLabels.NeedsHuman);
    }

    // Seed labels, then create the (edited) tickets as real issues on the chosen repo + add to board.
    // When runReady, auto-run a session per ai:ready ticket — the review step was the human gate, so
    // this is the autonomous idea→PRs path.
    private async Task CreateTickets(bool runReady)
    {
        if (_ideaBusy) { return; }
        var board = IdeaBoards().FirstOrDefault(b => b.Id.ToString() == _ideaBoardId);
        var repo = (_ideaRepos ?? Array.Empty<WorkspaceRepoEntity>()).FirstOrDefault(r => r.Id.ToString() == _ideaRepoId);
        if (board is null || repo is null)
        {
            _ideaError = "Pick a target board and repository.";
            return;
        }
        if (runReady && EngineSelection.Validate(_brain, _runOnMachine) is { } brainErr)
        {
            _ideaError = brainErr;
            return;
        }
        _ideaBusy = true;
        _ideaError = null;
        try
        {
            var pat = await ConfigStore.GetForTenantAsync(_tenantId, board.CredentialRef);
            if (string.IsNullOrEmpty(pat))
            {
                _ideaError = "Could not retrieve board credentials. Reconnect the board.";
                return;
            }

            var branch = string.IsNullOrWhiteSpace(repo.DefaultBranch) ? "main" : repo.DefaultBranch;
            var repoDesc = new WorkspaceDescriptor(
                repo.Id, _tenantId, board.Kind, repo.Owner, repo.Repo, board.Project, branch, pat);
            var boardDesc = new BoardDescriptor(
                board.Id, _tenantId, board.Kind, board.ProjectOwner, board.ProjectScope,
                board.ProjectNumber, board.ProjectNodeId, pat, board.Project);

            // Seed the taxonomy first so issue creation can apply the labels.
            await BoardWriteSvc.EnsureLabelsAsync(repoDesc, StandardLabels.All);

            var drafts = _draftRows
                .Where(r => !string.IsNullOrWhiteSpace(r.Title))
                .Select(r => new TicketDraft(r.Title.Trim(), r.Body, r.Labels.ToList(), r.AiReady))
                .ToList();
            _createdTickets = await BoardWriteSvc.CreateTicketsAsync(boardDesc, repoDesc, drafts);

            Toasts.Show("Spine", $"Created {_createdTickets.Count} ticket(s) on {repo.Owner}/{repo.Repo}.", ToastKind.Ok);

            // Auto-run: one session per ai:ready created ticket (created order matches the drafts sent).
            if (runReady)
            {
                var repoOpt = new RepoOption { Owner = repo.Owner, Repo = repo.Repo, DefaultBranch = branch, WorkspaceRepoId = repo.Id, Selected = true };
                var sessions = new List<RemoteSessionEntity>();
                for (var i = 0; i < _createdTickets.Count && i < drafts.Count; i++)
                {
                    if (!drafts[i].AiReady) { continue; }
                    var t = _createdTickets[i];
                    sessions.Add(await PersistSessionAsync(
                        board.Id, t.Number, $"#{t.Number} {t.Title}", t.ItemNodeId, "Issue", [repoOpt], _runOnMachine,
                        brain: _brain, ticketType: TicketTypeOf(drafts[i].Labels)));
                }
                if (sessions.Count > 0)
                {
                    Toasts.Show("Spine", $"Running {sessions.Count} ai:ready ticket(s)…", ToastKind.Ok);
                    await ReloadAll();
                    ResetIdea();
                    _tab = Tab.Sessions;
                    foreach (var s in sessions)
                    {
                        await RunSession(s);
                    }
                    return;
                }
            }

            _ideaStep = IdeaStep.Result;
        }
        catch (System.Net.Http.HttpRequestException ex) { HandleCreateError(ex); }
        catch (System.Text.Json.JsonException ex) { HandleCreateError(ex); }
        catch (InvalidOperationException ex) { HandleCreateError(ex); }
        catch (System.IO.IOException ex) { HandleCreateError(ex); }
        catch (TimeoutException ex) { HandleCreateError(ex); }
        finally
        {
            _ideaBusy = false;
        }

        void HandleCreateError(Exception ex)
        {
            _ideaError = $"Create failed: {ex.Message}";
            Toasts.Show("Spine", _ideaError, ToastKind.Err);
        }
    }

    private void ResetIdea()
    {
        _ideaStep = IdeaStep.Input;
        _ideaText = "";
        _preview = null;
        _draftRows.Clear();
        _createdTickets = Array.Empty<CreatedTicket>();
        _ideaError = null;
        _runOnMachine = false;
    }

    // ── Tickets → session ────────────────────────────────────────────────────────────────────────

    // Open the repo-picker dialog for a ticket: offer the board's repos + the ticket's own repo,
    // pre-selecting the ticket's repo.
    private void OpenWorkDialog(BoardTicket ticket)
    {
        if (ticket.RepoOwner is null || ticket.RepoName is null) { return; }
        _workTicket = ticket;
        _workRepoOptions.Clear();
        foreach (var r in _repos ?? Array.Empty<WorkspaceRepoEntity>())
        {
            _workRepoOptions.Add(new RepoOption
            {
                Owner = r.Owner,
                Repo = r.Repo,
                DefaultBranch = r.DefaultBranch,
                WorkspaceRepoId = r.Id,
                Selected = r.Owner == ticket.RepoOwner && r.Repo == ticket.RepoName,
            });
        }
        // The ticket's own repo may not be a curated board repo — add it (pre-selected).
        if (!_workRepoOptions.Any(o => o.Owner == ticket.RepoOwner && o.Repo == ticket.RepoName))
        {
            _workRepoOptions.Insert(0, new RepoOption
            {
                Owner = ticket.RepoOwner,
                Repo = ticket.RepoName,
                DefaultBranch = "main",
                Selected = true,
            });
        }
        _runOnMachine = false;
        _showWorkDialog = true;
    }

    private void CloseWorkDialog()
    {
        _showWorkDialog = false;
        _workTicket = null;
    }

    // Cross-link — open the ticket as a story in the Pipeline app (a sandbox run), prefilling the story
    // editor via a one-shot launch payload so the three surfaces read as one engine.
    private void OpenInPipeline(BoardTicket ticket)
    {
        var app = AgentOs.Web.Services.AppCatalog.Find("pipeline");
        if (app is null) { return; }
        var story = ticket.Number is { } n ? $"#{n} {ticket.Title}".Trim() : ticket.Title.Trim();
        WM.RequestLaunchPayload("pipeline", story);
        WM.OpenApp(app.Key, app.Title, app.Icon, app.W, app.H);
    }

    private async Task ConfirmWorkSession()
    {
        if (_busy || _selectedBoard is null || _workTicket is null) { return; }
        var selected = _workRepoOptions.Where(o => o.Selected).ToList();
        if (selected.Count == 0)
        {
            Toasts.Show("Spine", "Select at least one repository.", ToastKind.Err);
            return;
        }
        if (EngineSelection.Validate(_brain, _runOnMachine) is { } brainErr)
        {
            Toasts.Show("Spine", brainErr, ToastKind.Err);
            return;
        }
        _busy = true;
        try
        {
            var ticket = _workTicket;
            // The ticket's own repo becomes the session's primary repo — put it first.
            var ordered = selected
                .OrderByDescending(o => o.Owner == ticket.RepoOwner && o.Repo == ticket.RepoName)
                .ToList();
            await PersistSessionAsync(
                _selectedBoard.Id, ticket.Number, $"#{ticket.Number} {ticket.Title}",
                ticket.ItemNodeId, ticket.Kind.ToString(), ordered, _runOnMachine,
                brain: _brain, ticketType: TicketTypeOf(ticket.Labels));

            Toasts.Show("Spine", $"Session created for #{ticket.Number} across {ordered.Count} repo(s). Switch to Sessions to run it.", ToastKind.Ok);
            CloseWorkDialog();
            await ReloadAll();
            _tab = Tab.Sessions;
            CloseBoard();
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Failed to create session: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Failed to create session: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Failed to create session: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Failed to create session: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busy = false;
        }
    }

    // True when the member has at least one runner that isn't revoked — gates the "run on my machine"
    // hint (the dispatch itself still fails clearly if no runner is actually live).
    private bool HasRunner() => _runners?.Any(r => r.Status != "Revoked") == true;

    // Persist a session (+ its repo rows) for a ticket; returns the entity so the caller can run it.
    // The single source of truth for "ticket → session", shared by Work-on-this, Run-all-ready, and
    // the idea-wizard auto-run. repos[0] is the primary repo.
    private async Task<RemoteSessionEntity> PersistSessionAsync(
        Guid workspaceId, int? issueNumber, string title, string? itemNodeId, string ticketKind,
        IReadOnlyList<RepoOption> repos, bool runOnMachine = false, string brain = "Quick", string? ticketType = null)
    {
        var sessionId = Guid.NewGuid();
        var primary = repos[0];
        var session = new RemoteSessionEntity
        {
            Id = sessionId,
            TenantId = _tenantId,
            WorkspaceId = workspaceId,
            MemberUserId = _userId,
            Title = title,
            Status = "Draft",
            IssueNumber = issueNumber,
            RepoOwner = primary.Owner,
            RepoName = primary.Repo,
            RepoDefaultBranch = primary.DefaultBranch,
            BoardItemNodeId = itemNodeId,
            TicketKind = ticketKind,
            RunOnMachine = runOnMachine,
            Brain = brain,
            TicketType = ticketType,
            CreatedAtUtc = DateTimeOffset.UtcNow,
            CreatedByUserId = string.IsNullOrEmpty(_userId) ? null : _userId,
        };
        await Sessions.AddForTenantAsync(session);

        foreach (var opt in repos)
        {
            await Sessions.AddRepoForTenantAsync(new SessionRepoEntity
            {
                Id = Guid.NewGuid(),
                TenantId = _tenantId,
                SessionId = sessionId,
                WorkspaceRepoId = opt.WorkspaceRepoId,
                Owner = opt.Owner,
                Repo = opt.Repo,
                DefaultBranch = opt.DefaultBranch,
                Status = "Pending",
            });
        }
        return session;
    }

    // The ticket's `type:*` label (type:feature / type:bug / …), captured so the greenfield router can
    // hard-gate the Quality engine. First match wins; null when the ticket carries no type label.
    private static string? TicketTypeOf(IEnumerable<string>? labels) =>
        labels?.FirstOrDefault(l => l.StartsWith("type:", StringComparison.OrdinalIgnoreCase));

    // A1 residue — the single builder for the repo-level, token-carrying WorkspaceDescriptor the source /
    // PR / label services consume (transient; the PAT is resolved per call, never persisted). Kind +
    // Project come from the board (the workspace); the descriptor Id is the board's workspace id.
    private static WorkspaceDescriptor RepoDescriptor(
        WorkspaceEntity board, string tenantId, string owner, string repo, string defaultBranch, string pat) =>
        new(board.Id, tenantId, board.Kind, owner, repo, board.Project,
            string.IsNullOrWhiteSpace(defaultBranch) ? "main" : defaultBranch, pat);

    // The ai:ready tickets on the board that the spine can run unattended (real issue, has a repo).
    private List<BoardTicket> ReadyTickets() => _tickets is null
        ? new List<BoardTicket>()
        : _tickets.Where(t => t.Labels.Contains(StandardLabels.AiReady)
            && t.Kind != BoardTicketKind.DraftIssue && t.RepoOwner is not null && t.RepoName is not null).ToList();

    private RepoOption RepoOptionForTicket(BoardTicket ticket)
    {
        var curated = (_repos ?? Array.Empty<WorkspaceRepoEntity>())
            .FirstOrDefault(r => r.Owner == ticket.RepoOwner && r.Repo == ticket.RepoName);
        return new RepoOption
        {
            Owner = ticket.RepoOwner!,
            Repo = ticket.RepoName!,
            DefaultBranch = curated?.DefaultBranch ?? "main",
            WorkspaceRepoId = curated?.Id,
            Selected = true,
        };
    }

    // Batch: create a session per ai:ready ticket and run them all (the "server thinks, runner does"
    // path, unattended). Shares PersistSessionAsync + RunSession with the single-ticket flow.
    private async Task RunAllReady()
    {
        if (_busy || _selectedBoard is null) { return; }
        var ready = ReadyTickets();
        if (ready.Count == 0)
        {
            Toasts.Show("Spine", "No ai:ready tickets to run.", ToastKind.Err);
            return;
        }
        _busy = true;
        try
        {
            var sessions = new List<RemoteSessionEntity>();
            foreach (var ticket in ready)
            {
                sessions.Add(await PersistSessionAsync(
                    _selectedBoard.Id, ticket.Number, $"#{ticket.Number} {ticket.Title}",
                    ticket.ItemNodeId, ticket.Kind.ToString(), [RepoOptionForTicket(ticket)],
                    ticketType: TicketTypeOf(ticket.Labels)));
            }
            Toasts.Show("Spine", $"Running {sessions.Count} ai:ready ticket(s)…", ToastKind.Ok);
            await ReloadAll();
            _tab = Tab.Sessions;
            CloseBoard();
            foreach (var s in sessions)
            {
                await RunSession(s);
            }
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Run all failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Run all failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Run all failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Run all failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busy = false;
        }
    }

    private IReadOnlyList<SessionRepoEntity> SessionReposFor(Guid sessionId) =>
        _sessionRepos?.Where(r => r.SessionId == sessionId).OrderBy(r => r.Owner).ThenBy(r => r.Repo).ToList()
        ?? (IReadOnlyList<SessionRepoEntity>)Array.Empty<SessionRepoEntity>();

    // ── Run session (fire-and-forget AI pipeline) ──────────────────────────────────────────────

    private async Task RunSession(RemoteSessionEntity session)
    {
        if (_busyId == session.Id) { return; }
        _busyId = session.Id;
        try
        {
            var board = _boards?.FirstOrDefault(w => w.Id == session.WorkspaceId);
            if (board is null)
            {
                Toasts.Show("Spine", "Board not found — reload and try again.", ToastKind.Err);
                return;
            }
            var children = await Sessions.ListReposForTenantAsync(_tenantId, session.Id);
            if (children.Count == 0)
            {
                Toasts.Show("Spine", "This session has no target repos. Recreate it from a board ticket.", ToastKind.Err);
                return;
            }
            var pat = await ConfigStore.GetForTenantAsync(_tenantId, board.CredentialRef);
            if (string.IsNullOrEmpty(pat))
            {
                Toasts.Show("Spine", "Could not retrieve board credentials. Reconnect the board.", ToastKind.Err);
                return;
            }

            await Sessions.UpdateRunResultAsync(_tenantId, session.Id, "Running", null, null);
            var all = await Sessions.ListForTenantAsync(_tenantId);
            _sessions = _isAdmin ? all : all.Where(s => s.MemberUserId == _userId).ToList();
            Toasts.Show("Spine", $"Session #{session.IssueNumber} is running — AI agent dispatched to runner.", ToastKind.Ok);
            StartPolling();

            // Fire-and-forget background work in a fresh DI scope (independent of this circuit).
            var capturedTenantId = _tenantId;
            var capturedSession = session;
            var capturedBoard = board;
            var capturedPat = pat;
            var capturedChildren = children;
            var capturedCli = _cliProfile;   // CLI choice is transient (not persisted) — capture at dispatch.
            _ = Task.Run(async () =>
            {
                try
                {
                    using var scope = ScopeFactory.CreateScope();
                    // No HttpContext in this Task.Run, so seed the captured tenant + member as the ambient
                    // identity — the LLM tool tenant + the runner dispatch read it to target the right runner,
                    // and runner_shell tags its per-command progress to the session id carried here.
                    using var _identity = AgentOs.SharedKernel.Identity.AmbientIdentity.Push(capturedTenantId, capturedSession.MemberUserId, capturedSession.Id);
                    var sessRepo = scope.ServiceProvider.GetRequiredService<AgentOs.Modules.Sessions.Persistence.ISessionRepository>();

                    // Quality engine — the 5-agent SDLC pipeline runs server-side (generates new files,
                    // commits them + opens a PR via Octokit), greenfield only, hard-gated by the ticket-type
                    // router. The Quick engine (the default IssueWorkAgent edit loop) is below.
                    if (EngineSelection.IsQuality(capturedSession.Brain))
                    {
                        await RunQualitySessionAsync(
                            scope, sessRepo, capturedSession, capturedBoard, capturedPat, capturedChildren, capturedTenantId)
                            .ConfigureAwait(false);
                        return;
                    }

                    var agent = scope.ServiceProvider.GetRequiredService<AgentOs.Domain.Sessions.IIssueWorkAgent>();
                    var prService = scope.ServiceProvider.GetRequiredService<AgentOs.Domain.Workspaces.IPrCreationService>();

                    var workRepos = capturedChildren
                        .Select(c => new AgentOs.Domain.Sessions.WorkRepo(c.Id, c.Owner, c.Repo, c.DefaultBranch))
                        .ToList();
                    var issueRequest = new AgentOs.Domain.Sessions.IssueWorkRequest(
                        SessionId: capturedSession.Id,
                        TenantId: capturedTenantId,
                        MemberId: capturedSession.MemberUserId,
                        Repos: workRepos,
                        IssueNumber: capturedSession.IssueNumber ?? 0,
                        IssueTitle: capturedSession.Title,
                        IssueBody: "",
                        TicketKind: capturedSession.TicketKind ?? "Issue",
                        ProviderOverride: capturedSession.RunOnMachine ? "RemoteAgent" : null,
                        CliProfile: capturedSession.RunOnMachine ? capturedCli : null);

                    var workResult = await agent.RunAsync(issueRequest).ConfigureAwait(false);

                    // One PR per repo that pushed a branch; write each repo's result back incrementally
                    // (per-repo try/catch so one failure doesn't sink the others).
                    var anyFailure = false;
                    foreach (var outcome in workResult.Repos)
                    {
                        var repoLabel = $"{outcome.Owner}/{outcome.Repo}";
                        if (!outcome.Ok)
                        {
                            anyFailure = true;
                            await sessRepo.UpdateRepoRunResultAsync(capturedTenantId, outcome.SessionRepoId,
                                "Failed", outcome.BranchName, null, outcome.Error ?? "Agent failed.").ConfigureAwait(false);
                            Publish(SessionRunEventKind.RepoDone, $"{repoLabel} — failed: {outcome.Error}", repoLabel, "Failed");
                            continue;
                        }

                        var childBranch = capturedChildren.FirstOrDefault(c => c.Id == outcome.SessionRepoId)?.DefaultBranch ?? "main";
                        var descriptor = RepoDescriptor(capturedBoard, capturedTenantId, outcome.Owner, outcome.Repo, childBranch, capturedPat);

                        try
                        {
                            var prResult = await prService.CreateFromBranchAsync(
                                descriptor,
                                outcome.BranchName,
                                $"fix: #{capturedSession.IssueNumber} {capturedSession.Title}",
                                outcome.Summary).ConfigureAwait(false);

                            await sessRepo.UpdateRepoRunResultAsync(capturedTenantId, outcome.SessionRepoId,
                                prResult.Ok ? "Done" : "Failed", outcome.BranchName, prResult.HtmlUrl,
                                prResult.Ok ? null : prResult.Error).ConfigureAwait(false);
                            if (!prResult.Ok) { anyFailure = true; }
                            Publish(SessionRunEventKind.RepoDone,
                                prResult.Ok ? $"{repoLabel} — PR opened" : $"{repoLabel} — PR failed: {prResult.Error}",
                                repoLabel, prResult.Ok ? "Done" : "Failed", prResult.HtmlUrl);
                        }
                        catch (System.Net.Http.HttpRequestException prEx) { await HandlePrError(prEx).ConfigureAwait(false); }
                        catch (System.Text.Json.JsonException prEx) { await HandlePrError(prEx).ConfigureAwait(false); }
                        catch (InvalidOperationException prEx) { await HandlePrError(prEx).ConfigureAwait(false); }
                        catch (System.IO.IOException prEx) { await HandlePrError(prEx).ConfigureAwait(false); }
                        catch (TimeoutException prEx) { await HandlePrError(prEx).ConfigureAwait(false); }

                        async Task HandlePrError(Exception prEx)
                        {
                            anyFailure = true;
                            await sessRepo.UpdateRepoRunResultAsync(capturedTenantId, outcome.SessionRepoId,
                                "Failed", outcome.BranchName, null, $"PR creation failed: {prEx.Message}").ConfigureAwait(false);
                            Publish(SessionRunEventKind.RepoDone, $"{repoLabel} — PR creation failed: {prEx.Message}", repoLabel, "Failed");
                        }
                    }

                    await sessRepo.RecomputeSessionStatusForTenantAsync(capturedTenantId, capturedSession.Id).ConfigureAwait(false);
                    Publish(anyFailure ? SessionRunEventKind.Failed : SessionRunEventKind.Done,
                        anyFailure ? "Session finished with failures." : "Session complete — all repos done.");

                    // Local publish helper: tags every event with this run's tenant + session.
                    void Publish(SessionRunEventKind kind, string message, string? repo = null, string? status = null, string? prUrl = null) =>
                        Feed.Publish(new SessionRunEvent(capturedTenantId, capturedSession.Id, kind, message, DateTimeOffset.UtcNow, repo, status, prUrl));
                }
                catch (System.Net.Http.HttpRequestException ex) { await HandleRunFailure(ex).ConfigureAwait(false); }
                catch (System.Text.Json.JsonException ex) { await HandleRunFailure(ex).ConfigureAwait(false); }
                catch (Microsoft.AspNetCore.SignalR.HubException ex) { await HandleRunFailure(ex).ConfigureAwait(false); }
                catch (InvalidOperationException ex) { await HandleRunFailure(ex).ConfigureAwait(false); }
                catch (System.IO.IOException ex) { await HandleRunFailure(ex).ConfigureAwait(false); }
                catch (TimeoutException ex) { await HandleRunFailure(ex).ConfigureAwait(false); }

                async Task HandleRunFailure(Exception ex)
                {
                    try
                    {
                        using var scope = ScopeFactory.CreateScope();
                        var sessRepo = scope.ServiceProvider.GetRequiredService<AgentOs.Modules.Sessions.Persistence.ISessionRepository>();
                        await sessRepo.UpdateRunResultAsync(capturedTenantId, capturedSession.Id,
                            "Failed", null, ex.Message).ConfigureAwait(false);
                    }
                    // Best-effort.
                    catch (System.Net.Http.HttpRequestException inner) { _ = inner.Message; }
                    catch (System.IO.IOException inner) { _ = inner.Message; }
                    catch (InvalidOperationException inner) { _ = inner.Message; }
                    catch (TimeoutException inner) { _ = inner.Message; }
                    Feed.Publish(new SessionRunEvent(capturedTenantId, capturedSession.Id,
                        SessionRunEventKind.Failed, $"Session failed: {ex.Message}", DateTimeOffset.UtcNow));
                }
            });
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Run failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Run failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Run failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Run failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busyId = null;
        }
    }

    // ── Quality engine (5-agent pipeline) ─────────────────────────────────────────────────────────

    // Runs the 5-agent SDLC pipeline for a session against its PRIMARY repo (children[0]) and opens a PR
    // with the generated code + tests. Server-side end-to-end — no runner needed. Hard-gated by the
    // ticket-type router: a non-greenfield ticket is REFUSED (the pipeline only generates new files), never
    // silently downgraded to Quick. Multi-repo fan-out is deferred (Quality targets the primary repo only).
    private async Task RunQualitySessionAsync(
        IServiceScope scope,
        AgentOs.Modules.Sessions.Persistence.ISessionRepository sessRepo,
        RemoteSessionEntity session,
        WorkspaceEntity board,
        string pat,
        IReadOnlyList<SessionRepoEntity> children,
        string tenantId)
    {
        // Tenant + session tagged publish to the live feed.
        void Publish(SessionRunEventKind kind, string message, string? repo = null, string? status = null, string? prUrl = null) =>
            Feed.Publish(new SessionRunEvent(tenantId, session.Id, kind, message, DateTimeOffset.UtcNow, repo, status, prUrl));

        // Hard greenfield router (red-team HIGH) — refuse edit/bug/ambiguous tickets, never best-effort.
        var cls = TicketClassifier.Classify(session.TicketType, session.Title);
        if (cls != TicketClass.Greenfield)
        {
            var reason = TicketClassifier.RefusalMessage(cls);
            await sessRepo.UpdateRunResultAsync(tenantId, session.Id, "Failed", null, reason).ConfigureAwait(false);
            Publish(SessionRunEventKind.Failed, reason);
            return;
        }

        var primary = children.Count > 0 ? children[0] : null;
        if (primary is null)
        {
            const string noRepo = "Quality run has no target repo — recreate the session from a board ticket.";
            await sessRepo.UpdateRunResultAsync(tenantId, session.Id, "Failed", null, noRepo).ConfigureAwait(false);
            Publish(SessionRunEventKind.Failed, noRepo);
            return;
        }
        var repoLabel = $"{primary.Owner}/{primary.Repo}";

        // Resolve the heavy services lazily, inside this background scope (eager-DI landmine — never a
        // @inject'd field, which would build a pooled LLM client in the circuit ctor and crash on open).
        var pipeline = scope.ServiceProvider.GetRequiredService<IPipelineClient>();
        var prService = scope.ServiceProvider.GetRequiredService<IGitHubPrService>();

        Publish(SessionRunEventKind.Running, $"Quality engine — 5-agent pipeline on {repoLabel}.", repoLabel);

        var story = IssueToStoryAdapter.ToUserStory(session.Title, null, QualityNMax());
        PipelineResult? result = null;
        string? error = null;
        // The pipeline runs through PersistingOrchestratorAgent, which applies the S1 per-tenant budget gate
        // (the ambient identity pushed by RunSession flows in via InProcessPipelineClient).
        await foreach (var evt in pipeline.StreamAsync(story).ConfigureAwait(false))
        {
            switch (evt.Kind)
            {
                case PipelineStreamEventKind.Progress when evt.Progress is not null:
                    Publish(SessionRunEventKind.Step, PipelineProgressFormatter.Describe(evt.Progress), repoLabel);
                    break;
                case PipelineStreamEventKind.Result:
                    result = evt.Result;
                    break;
                case PipelineStreamEventKind.Error:
                    error = evt.Error ?? "Pipeline error.";
                    break;
            }
        }

        if (result is null || result.Status == PipelineStatus.Failed)
        {
            var msg = error ?? "Quality pipeline failed — see the server log.";
            await sessRepo.UpdateRepoRunResultAsync(tenantId, primary.Id, "Failed", null, null, msg).ConfigureAwait(false);
            await sessRepo.UpdateRunResultAsync(tenantId, session.Id, "Failed", null, msg).ConfigureAwait(false);
            Publish(SessionRunEventKind.Failed, $"{repoLabel} — {msg}", repoLabel, "Failed");
            return;
        }

        // Commit the generated code + tests to the primary repo and open a PR (server-side via Octokit).
        var descriptor = RepoDescriptor(board, tenantId, primary.Owner, primary.Repo, primary.DefaultBranch, pat);
        var title = $"feat: #{session.IssueNumber} {session.Title}";
        var body = $"Generated by the AgentOS Quality pipeline (5-agent SDLC loop) for session #{session.IssueNumber}.";
        try
        {
            var pr = await prService.OpenPrAsync(result, descriptor, title, body, CancellationToken.None).ConfigureAwait(false);
            await sessRepo.UpdateRepoRunResultAsync(tenantId, primary.Id, "Done", pr.Branch, pr.HtmlUrl, null).ConfigureAwait(false);
            await sessRepo.RecomputeSessionStatusForTenantAsync(tenantId, session.Id).ConfigureAwait(false);
            Publish(SessionRunEventKind.Done, $"{repoLabel} — PR opened.", repoLabel, "Done", pr.HtmlUrl);
        }
        catch (System.Net.Http.HttpRequestException ex) { await PrFailed(ex).ConfigureAwait(false); }
        catch (System.Text.Json.JsonException ex) { await PrFailed(ex).ConfigureAwait(false); }
        catch (InvalidOperationException ex) { await PrFailed(ex).ConfigureAwait(false); }
        catch (ArgumentException ex) { await PrFailed(ex).ConfigureAwait(false); }
        catch (System.IO.IOException ex) { await PrFailed(ex).ConfigureAwait(false); }
        catch (TimeoutException ex) { await PrFailed(ex).ConfigureAwait(false); }

        async Task PrFailed(Exception ex)
        {
            await sessRepo.UpdateRepoRunResultAsync(tenantId, primary.Id, "Failed", null, null, $"PR creation failed: {ex.Message}").ConfigureAwait(false);
            await sessRepo.UpdateRunResultAsync(tenantId, session.Id, "Failed", null, $"PR creation failed: {ex.Message}").ConfigureAwait(false);
            Publish(SessionRunEventKind.Failed, $"{repoLabel} — PR creation failed: {ex.Message}", repoLabel, "Failed");
        }
    }

    // The QA-loop iteration cap for a Quality run, clamped to the admin/tenant bound (S4): the pipeline
    // default (3), never above Pipeline:MaxIterations. The orchestrator re-clamps the same way, so this is
    // also what the cost label can honestly advertise.
    private int QualityNMax() => Math.Clamp(Math.Min(3, PipelineOpts.Value.MaxIterations), 1, 10);

    // Switching the engine to Quality forces "run on my machine" off — the pipeline is server-side.
    private void OnBrainChanged()
    {
        if (EngineSelection.IsQuality(_brain)) { _runOnMachine = false; }
    }

    // ── Runner management ────────────────────────────────────────────────────────────────────────

    private async Task RegisterRunner()
    {
        if (_busy) { return; }
        if (string.IsNullOrWhiteSpace(_runnerLabel))
        {
            Toasts.Show("Spine", "A label is required.", ToastKind.Err);
            return;
        }
        _busy = true;
        try
        {
            var secret = Pairing.Issue();
            var entity = new RunnerEntity
            {
                Id = Guid.NewGuid(),
                TenantId = _tenantId,
                OwnerUserId = _userId,
                Label = _runnerLabel.Trim(),
                TokenHash = secret.TokenHash,
                Status = "Pending",
                CreatedAtUtc = DateTimeOffset.UtcNow,
                CreatedByUserId = string.IsNullOrEmpty(_userId) ? null : _userId,
            };
            await Runners.AddForTenantAsync(entity);
            _newRunner = (entity.Id, secret.Token);
            _runnerLabel = "";
            Toasts.Show("Spine", "Runner registered. Copy the pairing token now — it won't be shown again.", ToastKind.Ok);
            var r0 = await Runners.ListForTenantAsync(_tenantId);
            _runners = _isAdmin ? r0 : r0.Where(r => r.OwnerUserId == _userId).ToList();
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Register failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Register failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Register failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Register failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busy = false;
        }
    }

    private async Task RevokeRunner(RunnerEntity r)
    {
        _busyId = r.Id;
        try
        {
            await Runners.SetStatusForTenantAsync(_tenantId, r.Id, "Revoked");
            Toasts.Show("Spine", $"Revoked '{r.Label}'.", ToastKind.Ok);
            var r0 = await Runners.ListForTenantAsync(_tenantId);
            _runners = _isAdmin ? r0 : r0.Where(r => r.OwnerUserId == _userId).ToList();
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busyId = null;
        }
    }

    // ── Sessions ─────────────────────────────────────────────────────────────────────────────────

