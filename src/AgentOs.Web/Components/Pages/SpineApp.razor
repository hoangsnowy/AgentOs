    // ── Connect board ────────────────────────────────────────────────────────────────────────────

    private async Task FindBoards()
    {
        if (_findingBoards) { return; }
        if (string.IsNullOrWhiteSpace(_wsProjectOwner) || string.IsNullOrWhiteSpace(_wsToken))
        {
            Toasts.Show("Spine", "Owner and token are required to find boards.", ToastKind.Err);
            return;
        }
        _findingBoards = true;
        try
        {
            _foundBoards = await Connector.ListBoardsAsync(_wsKind, _wsProjectOwner.Trim(), _wsToken);
            if (_foundBoards.Count == 0)
            {
                Toasts.Show("Spine", "No boards visible to that token.", ToastKind.Info);
            }
        }
        catch (System.Net.Http.HttpRequestException ex) { HandleFindError(ex); }
        catch (System.Text.Json.JsonException ex) { HandleFindError(ex); }
        catch (InvalidOperationException ex) { HandleFindError(ex); }
        catch (System.IO.IOException ex) { HandleFindError(ex); }
        catch (TimeoutException ex) { HandleFindError(ex); }
        finally
        {
            _findingBoards = false;
        }

        void HandleFindError(Exception ex)
        {
            Toasts.Show("Spine", $"Find boards failed: {ex.Message}", ToastKind.Err);
            _foundBoards = null;
        }
    }

    private void OnBoardPicked(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(value) || _foundBoards is null) { return; }
        if (!int.TryParse(value, System.Globalization.CultureInfo.InvariantCulture, out var number)) { return; }
        var board = _foundBoards.FirstOrDefault(b => b.Number == number);
        if (board is null) { return; }
        _wsNumberText = board.Number.ToString(System.Globalization.CultureInfo.InvariantCulture);
        if (string.IsNullOrWhiteSpace(_wsName)) { _wsName = board.Title; }
    }

    private async Task ConnectBoard()
    {
        if (_busy) { return; }
        if (string.IsNullOrWhiteSpace(_wsName) || string.IsNullOrWhiteSpace(_wsProjectOwner)
            || string.IsNullOrWhiteSpace(_wsToken))
        {
            Toasts.Show("Spine", "Name, owner and token are required.", ToastKind.Err);
            return;
        }
        int? number = null;
        if (!string.IsNullOrWhiteSpace(_wsNumberText))
        {
            if (!int.TryParse(_wsNumberText.Trim(), out var n) || n <= 0)
            {
                Toasts.Show("Spine", "Board number must be a positive integer.", ToastKind.Err);
                return;
            }
            number = n;
        }
        _busy = true;
        try
        {
            var input = new WorkspaceConnectInput(
                _wsName.Trim(), _wsKind, _wsProjectOwner.Trim(),
                _wsKind == SourceProviderKind.GitHub ? _wsScope : "org",
                number,
                string.IsNullOrWhiteSpace(_wsProject) ? null : _wsProject.Trim(),
                null, _wsToken);
            var result = await Connector.ConnectAsync(_tenantId, string.IsNullOrEmpty(_userId) ? null : _userId, input);
            if (result.Ok)
            {
                Toasts.Show("Spine", $"Connected '{_wsName.Trim()}'.", ToastKind.Ok);
                _wsName = _wsProjectOwner = _wsNumberText = _wsProject = _wsToken = "";
                _foundBoards = null;
                _boards = await Workspaces.ListForTenantAsync(_tenantId);
            }
            else
            {
                Toasts.Show("Spine", result.Error ?? "Connect failed.", ToastKind.Err);
            }
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Spine", $"Connect failed: {ex.Message}", ToastKind.Err); }
        catch (System.Text.Json.JsonException ex) { Toasts.Show("Spine", $"Connect failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Spine", $"Connect failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Spine", $"Connect failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Spine", $"Connect failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _busy = false;
        }
    }
