@using System.Net.Http.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using AgentOs.Modules.Llm
@using AgentOs.Modules.AppConfig
@using AgentOs.Domain.Llm
@using AgentOs.SharedKernel.Identity
@using AgentOs.Web.Services
@using AgentOs.Domain.Workspaces
@inject Microsoft.Extensions.Options.IOptions<LlmOptions> LlmOpts
@inject IRuntimeOverrides Overrides
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject IHttpClientFactory HttpFactory
@inject ILlmClientFactory LlmFactory
@inject AuthSession Auth
@inject ISourceProviderResolver SourceProviders

@if (!_resolved)
{
    <Spinner />
}
else if (!_isAdmin)
{
    <div class="login-error">Admin role required. Settings (LLM keys, providers, GitHub) is tenant-admin only. Your account is a member of <code>@_tenantId</code> without admin rights.</div>
}
else
{
<div class="prefs">
    <aside class="prefs-side">
        <div class="prefs-side-head">Settings</div>
        <button class="prefs-cat @(_tab == "status"   ? "active" : "")" @onclick="@(() => _tab = "status")"><span class="prefs-cat-ic"><Icon Name="circle-fill"        Size="12" /></span> Status</button>
        <button class="prefs-cat @(_tab == "providers"? "active" : "")" @onclick="@(() => _tab = "providers")"><span class="prefs-cat-ic"><Icon Name="lightning"        Size="14" /></span> Providers</button>
        <button class="prefs-cat @(_tab == "keys"     ? "active" : "")" @onclick="@(() => _tab = "keys")"><span class="prefs-cat-ic"><Icon Name="lock"             Size="14" /></span> API keys</button>
        <button class="prefs-cat @(_tab == "github"   ? "active" : "")" @onclick="@(() => _tab = "github")"><span class="prefs-cat-ic"><Icon Name="arrow-square-out" Size="14" /></span> GitHub</button>
        <button class="prefs-cat @(_tab == "data"     ? "active" : "")" @onclick="@(() => _tab = "data")"><span class="prefs-cat-ic"><Icon Name="floppy-disk"      Size="14" /></span> Storage</button>
    </aside>

    <div class="prefs-content">
        @switch (_tab)
        {
            case "status":
                <div class="prefs-section">
                    <h2 class="prefs-h">Status</h2>
                    <p class="prefs-sub">Current effective configuration.</p>
                </div>
                <table class="prefs-tbl">
                    <tr><th>Default provider</th><td><code>@LlmOpts.Value.Provider</code></td></tr>
                    <tr><th>Effective force provider</th><td>@EffectiveForceLabel()</td></tr>
                    <tr><th>Anthropic API key</th><td>@KeyState(LlmOpts.Value.Claude.ApiKey)</td></tr>
                    <tr><th>Azure OpenAI API key</th><td>@KeyState(LlmOpts.Value.AzureOpenAi.ApiKey)</td></tr>
                    <tr><th>Azure OpenAI endpoint</th><td>@(string.IsNullOrEmpty(LlmOpts.Value.AzureOpenAi.Endpoint) ? "— not set —" : LlmOpts.Value.AzureOpenAi.Endpoint)</td></tr>
                    <tr><th>Persistence</th><td>@(_dbConnected ? "Postgres connected" : "Stateless (no DB)")</td></tr>
                </table>
                break;

            case "providers":
                <div class="prefs-section">
                    <h2 class="prefs-h">Providers</h2>
                    <p class="prefs-sub">Force a single provider for every agent at runtime.</p>
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Force provider</strong><br /><span class="prefs-hint">Overrides per-agent configuration.</span></div>
                    <select @bind="_forceProvider" class="prefs-select">
                        <option value="">— per-agent config —</option>
                        <option value="Claude">Claude (Anthropic)</option>
                        <option value="AzureOpenAI">Azure OpenAI</option>
                        <option value="MAF">MAF (Azure OpenAI via SDK)</option>
                    </select>
                </div>
                <div class="prefs-actions">
                    <Btn Variant="Btn.ButtonVariant.Primary" OnClick="Save" Disabled="_saving">@(_saving ? "Saving…" : "Save")</Btn>
                    <Btn Variant="Btn.ButtonVariant.Ghost" OnClick="Clear" Disabled="_saving">Reset</Btn>
                </div>
                @if (_saveError is not null)
                {
                    <div class="prefs-saved"><Chip Variant="Chip.ChipVariant.Err">Not saved</Chip> @_saveError</div>
                }
                else if (_saved)
                {
                    <div class="prefs-saved"><Chip Variant="Chip.ChipVariant.Ok">Saved</Chip> @SaveScopeLabel()</div>
                }

                <div class="prefs-row" style="margin-top:var(--space-5)">
                    <div class="prefs-label"><strong>Test connection</strong><br /><span class="prefs-hint">Send a minimal probe to the configured provider.</span></div>
                    <Btn OnClick="TestConnection" Disabled="_testing">@(_testing ? "Testing…" : "Test")</Btn>
                </div>
                @if (_testResult is not null)
                {
                    <div class="prefs-saved">
                        @if (_testOk)
                        {
                            <Chip Variant="Chip.ChipVariant.Ok">OK</Chip>
                        }
                        else
                        {
                            <Chip Variant="Chip.ChipVariant.Err">Failed</Chip>
                        }
                        @_testResult
                    </div>
                }
                break;

            case "keys":
                <div class="prefs-section">
                    <h2 class="prefs-h">API keys</h2>
                    <p class="prefs-sub">Your workspace's own keys — encrypted + stored per-tenant. Used only by <code>@_tenantId</code>; other tenants never see or spend them. Leave blank to fall back to the platform key (dev/demo only).</p>
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Anthropic API key</strong></div>
                    <input type="password" @bind="_anthropicKey" placeholder="sk-ant-..." class="prefs-input" />
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Azure OpenAI API key</strong></div>
                    <input type="password" @bind="_azureKey" placeholder="(Azure key)" class="prefs-input" />
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Azure OpenAI endpoint</strong></div>
                    <input type="text" @bind="_azureEndpoint" placeholder="https://your-resource.openai.azure.com" class="prefs-input" />
                </div>
                <div class="prefs-actions">
                    <Btn Variant="Btn.ButtonVariant.Primary" OnClick="Save" Disabled="_saving">@(_saving ? "Saving…" : "Save")</Btn>
                    <Btn Variant="Btn.ButtonVariant.Ghost" OnClick="Clear" Disabled="_saving">Reset</Btn>
                </div>
                @if (_saveError is not null)
                {
                    <div class="prefs-saved"><Chip Variant="Chip.ChipVariant.Err">Not saved</Chip> @_saveError</div>
                }
                else if (_saved)
                {
                    <div class="prefs-saved"><Chip Variant="Chip.ChipVariant.Ok">Saved</Chip> @SaveScopeLabel()</div>
                }
                break;

            case "github":
                <div class="prefs-section">
                    <h2 class="prefs-h">GitHub — Pipeline auto-PR</h2>
                    <p class="prefs-sub">Used <strong>only</strong> by the 5-agent Pipeline to open a PR with generated code. Spine boards use their own per-board token — connect those in the Spine app, not here. PAT needs the <code>repo</code> scope.</p>
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Personal access token</strong></div>
                    <input type="password" @bind="_githubPat" placeholder="ghp_..." class="prefs-input" />
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Repo owner</strong></div>
                    <input type="text" @bind="_repoOwner" placeholder="your-username" class="prefs-input" />
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Repo name</strong></div>
                    <input type="text" @bind="_repoName" placeholder="target-repo" class="prefs-input" />
                </div>
                <div class="prefs-row">
                    <div class="prefs-label"><strong>Base branch</strong></div>
                    <input type="text" @bind="_baseBranch" placeholder="main" class="prefs-input" />
                </div>
                <div class="prefs-actions">
                    <Btn Variant="Btn.ButtonVariant.Primary" OnClick="SaveGithub" Disabled="_savingGithub">@(_savingGithub ? "Saving…" : "Save")</Btn>
                    <Btn OnClick="TestGithub" Disabled="_ghTesting || _savingGithub">@(_ghTesting ? "Testing…" : "Test")</Btn>
                </div>
                @if (_saveErrorGithub is not null)
                {
                    <div class="prefs-saved"><Chip Variant="Chip.ChipVariant.Err">Not saved</Chip> @_saveErrorGithub</div>
                }
                else if (_savedGithub)
                {
                    <div class="prefs-saved"><Chip Variant="Chip.ChipVariant.Ok">Saved</Chip> "Open PR" on the pipeline will use these.</div>
                }
                @if (_ghTestResult is not null)
                {
                    <div class="prefs-saved">
                        @if (_ghTestOk)
                        {
                            <Chip Variant="Chip.ChipVariant.Ok">OK</Chip>
                        }
                        else
                        {
                            <Chip Variant="Chip.ChipVariant.Err">Failed</Chip>
                        }
                        @_ghTestResult
                    </div>
                }
                break;

            case "data":
                <div class="prefs-section">
                    <h2 class="prefs-h">Storage</h2>
                    <p class="prefs-sub">Where pipeline data lives.</p>
                </div>
                <ul class="prefs-list">
                    <li><strong>Pipeline results</strong>: in-memory unless <code>ConnectionStrings:DefaultConnection</code> is set → Postgres tables <code>pipeline_runs</code> / <code>run_metrics</code> / <code>orchestrations</code>.</li>
                    <li><strong>API keys</strong>: keys you enter on the "API keys" tab are encrypted (DataProtection) and stored <strong>per-tenant</strong> in <code>config.app_config</code> — durable across restarts, isolated to your workspace. The platform-wide key in <code>appsettings</code>/env is only a dev/demo fallback when a tenant sets none.</li>
                    <li><strong>Generated code / tests</strong>: returned inline in the pipeline response. Use the <em>Verify build</em> card on the Pipeline app to compile them in a temp dir.</li>
                    <li><strong>GitHub PR</strong>: <em>Open PR</em> on the Pipeline app commits the generated files + opens a PR against the repo configured on the GitHub tab.</li>
                </ul>
                <details class="prefs-details">
                    <summary>CLI setup</summary>
                    <pre class="code">cd src/AgentOs.Api
dotnet user-secrets set "Llm:Claude:ApiKey"      "sk-ant-..."
dotnet user-secrets set "Llm:AzureOpenAi:ApiKey" "..."
dotnet user-secrets set "Llm:AzureOpenAi:Endpoint" "https://your-resource.openai.azure.com"</pre>
                </details>
                break;
        }
    </div>
</div>
}

@code {
    private string _tab = "status";

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private bool _resolved;
    private bool _isAdmin;
    private string _tenantId = string.Empty;
    private string? _userId;

    private string _forceProvider = "";
    private string _anthropicKey = "";
    private string _azureKey = "";
    private string _azureEndpoint = "";
    private bool _saved;
    private bool _saving;
    private string? _saveError;
    private bool _dbConnected;

    private string _githubPat = "";
    private string _repoOwner = "";
    private string _repoName = "";
    private string _baseBranch = "";
    private bool _savedGithub;
    private bool _savingGithub;
    private string? _saveErrorGithub;
    private bool _ghTesting;
    private bool _ghTestOk;
    private string? _ghTestResult;

    // When Api:BaseUrl is set the Web is a thin client; settings live in the API's encrypted
    // app_config store. Blank → single-process, settings are the in-memory overrides.
    private string? _apiBase;
    private bool Split => !string.IsNullOrWhiteSpace(_apiBase);

    private bool _testing;
    private bool _testOk;
    private string? _testResult;

    protected override async Task OnInitializedAsync()
    {
        // Resolve tenant + admin from the circuit's AuthenticationState — a Blazor interactive-Server
        // component has no HttpContext, so ITenantContext can't be used here (it would resolve `default`).
        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            _isAdmin = user.IsInRole("admin");
            _tenantId = user.FindFirst("tenant")?.Value ?? string.Empty;
            _userId = user.FindFirst("sub")?.Value ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        }
        _resolved = true;
        if (!_isAdmin) { return; }

        _apiBase = Config["Api:BaseUrl"];
        _dbConnected = !string.IsNullOrWhiteSpace(Config.GetConnectionString("DefaultConnection"));

        // In-process: seed from this tenant's persisted overrides. Push the circuit's real tenant so the
        // singleton RuntimeOverrides → EfAppConfigStore reads the signed-in tenant's row, not `default`.
        // Split: re-seeded from the API (token-scoped) in OnAfterRenderAsync below.
        if (!Split)
        {
            using var _ = TenantScope();
            _forceProvider = Overrides.ForceProvider ?? "";
            _anthropicKey = Overrides.AnthropicApiKey ?? "";
            _azureKey = Overrides.AzureApiKey ?? "";
            _azureEndpoint = Overrides.AzureEndpoint ?? "";
            _githubPat = Overrides.GitHubPat ?? "";
            _repoOwner = Overrides.GitHubRepoOwner ?? "";
            _repoName = Overrides.GitHubRepoName ?? "";
            _baseBranch = Overrides.GitHubBaseBranch ?? "";
        }
    }

    // Ambient identity for the in-process path so every Overrides read/write lands in THIS tenant's
    // encrypted app_config row. No-op (null) in standalone dev-auto-login (empty tenant claim, single tenant).
    private IDisposable? TenantScope()
        => string.IsNullOrEmpty(_tenantId) ? null : AmbientIdentity.Push(_tenantId, _userId);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Split)
        {
            try
            {
                using var client = ApiClient();
                var llm = await client.GetFromJsonAsync<Dictionary<string, string?>>("settings/Llm");
                var gh = await client.GetFromJsonAsync<Dictionary<string, string?>>("settings/Github");
                if (llm is not null)
                {
                    _forceProvider = llm.GetValueOrDefault("Llm:ForceProvider") ?? "";
                    _anthropicKey = llm.GetValueOrDefault("Llm:Claude:ApiKey") ?? "";
                    _azureKey = llm.GetValueOrDefault("Llm:AzureOpenAi:ApiKey") ?? "";
                    _azureEndpoint = llm.GetValueOrDefault("Llm:AzureOpenAi:Endpoint") ?? "";
                }
                if (gh is not null)
                {
                    _githubPat = gh.GetValueOrDefault("Github:Pat") ?? "";
                    _repoOwner = gh.GetValueOrDefault("Github:RepoOwner") ?? "";
                    _repoName = gh.GetValueOrDefault("Github:RepoName") ?? "";
                    _baseBranch = gh.GetValueOrDefault("Github:BaseBranch") ?? "";
                }
                StateHasChanged();
            }
            catch (System.Net.Http.HttpRequestException ex)
            {
                // API unreachable / unauthorized — keep the seeded values.
                _ = ex.Message;
            }
            catch (System.Text.Json.JsonException ex)
            {
                _ = ex.Message;
            }
            catch (System.InvalidOperationException ex)
            {
                _ = ex.Message;
            }
            catch (System.TimeoutException ex)
            {
                _ = ex.Message;
            }
        }
    }

    private HttpClient ApiClient()
    {
        var client = HttpFactory.CreateClient();
        client.BaseAddress = new Uri(_apiBase!.EndsWith('/') ? _apiBase! : _apiBase! + "/");
        if (!string.IsNullOrWhiteSpace(Auth.Token))
        {
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Auth.Token);
        }
        return client;
    }

    // Mirrors the server-side SettingsKeyRegistry checks so an invalid value never round-trips
    // (the API enforces the same rules — this is feedback, not the gate).
    private string? ValidateLlmFields()
    {
        if (!string.IsNullOrWhiteSpace(_azureEndpoint)
            && (!Uri.TryCreate(_azureEndpoint, UriKind.Absolute, out var uri) || uri.Scheme != Uri.UriSchemeHttps))
        {
            return "Azure OpenAI endpoint must be an absolute https:// URL.";
        }
        return null;
    }

    private string? ValidateGithubFields()
    {
        if (!string.IsNullOrWhiteSpace(_githubPat)
            && !_githubPat.StartsWith("ghp_", StringComparison.Ordinal)
            && !_githubPat.StartsWith("github_pat_", StringComparison.Ordinal)
            && !_githubPat.StartsWith("gho_", StringComparison.Ordinal))
        {
            return "GitHub token must start with ghp_, github_pat_ or gho_.";
        }
        if (!string.IsNullOrWhiteSpace(_baseBranch) && _baseBranch.Contains(' ', StringComparison.Ordinal))
        {
            return "Base branch must not contain spaces.";
        }
        return null;
    }

    /// <summary>POSTs one setting; returns the server's validation error, or null on success.</summary>
    private static async Task<string?> SetRemoteAsync(HttpClient client, string key, string? value)
    {
        using var resp = await client.PostAsJsonAsync("settings", new { key, value = value ?? "" });
        if (resp.IsSuccessStatusCode)
        {
            return null;
        }
        try
        {
            var problem = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (problem.TryGetProperty("errors", out var errors))
            {
                foreach (var field in errors.EnumerateObject())
                {
                    foreach (var msg in field.Value.EnumerateArray())
                    {
                        return msg.GetString();
                    }
                }
            }
            if (problem.TryGetProperty("detail", out var detail))
            {
                return detail.GetString();
            }
        }
        catch (System.Text.Json.JsonException)
        {
            // Non-JSON error body — fall through to the status line.
        }
        return $"HTTP {(int)resp.StatusCode}";
    }

    private async Task Save()
    {
        _saved = false;
        _saveError = ValidateLlmFields();
        if (_saveError is not null)
        {
            return;
        }
        _saving = true;
        try
        {
            if (Split)
            {
                using var client = ApiClient();
                // _saveError is null here (the validation guard above returned otherwise) — the first
                // write assigns, the rest short-circuit on the first error.
                _saveError = await SetRemoteAsync(client, "Llm:ForceProvider", _forceProvider);
                _saveError ??= await SetRemoteAsync(client, "Llm:Claude:ApiKey", _anthropicKey);
                _saveError ??= await SetRemoteAsync(client, "Llm:AzureOpenAi:ApiKey", _azureKey);
                _saveError ??= await SetRemoteAsync(client, "Llm:AzureOpenAi:Endpoint", _azureEndpoint);
            }
            else
            {
                using var _ = TenantScope();
                Overrides.ForceProvider = string.IsNullOrWhiteSpace(_forceProvider) ? null : _forceProvider;
                Overrides.AnthropicApiKey = string.IsNullOrWhiteSpace(_anthropicKey) ? null : _anthropicKey;
                Overrides.AzureApiKey = string.IsNullOrWhiteSpace(_azureKey) ? null : _azureKey;
                Overrides.AzureEndpoint = string.IsNullOrWhiteSpace(_azureEndpoint) ? null : _azureEndpoint;
            }
            _saved = _saveError is null;
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Clear()
    {
        _forceProvider = _anthropicKey = _azureKey = _azureEndpoint = "";
        _saved = false;
        _saveError = null;
        _saving = true;
        try
        {
            if (Split)
            {
                using var client = ApiClient();
                _saveError = await SetRemoteAsync(client, "Llm:ForceProvider", "");
                _saveError ??= await SetRemoteAsync(client, "Llm:Claude:ApiKey", "");
                _saveError ??= await SetRemoteAsync(client, "Llm:AzureOpenAi:ApiKey", "");
                _saveError ??= await SetRemoteAsync(client, "Llm:AzureOpenAi:Endpoint", "");
            }
            else
            {
                using var _ = TenantScope();
                Overrides.ForceProvider = null;
                Overrides.AnthropicApiKey = null;
                Overrides.AzureApiKey = null;
                Overrides.AzureEndpoint = null;
            }
            _saved = _saveError is null;
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveGithub()
    {
        _savedGithub = false;
        _saveErrorGithub = ValidateGithubFields();
        if (_saveErrorGithub is not null)
        {
            return;
        }
        _savingGithub = true;
        try
        {
            if (Split)
            {
                using var client = ApiClient();
                // _saveErrorGithub is null here (guard above returned otherwise) — first write assigns.
                _saveErrorGithub = await SetRemoteAsync(client, "Github:Pat", _githubPat);
                _saveErrorGithub ??= await SetRemoteAsync(client, "Github:RepoOwner", _repoOwner);
                _saveErrorGithub ??= await SetRemoteAsync(client, "Github:RepoName", _repoName);
                _saveErrorGithub ??= await SetRemoteAsync(client, "Github:BaseBranch", _baseBranch);
            }
            else
            {
                using var _ = TenantScope();
                Overrides.GitHubPat = string.IsNullOrWhiteSpace(_githubPat) ? null : _githubPat;
                Overrides.GitHubRepoOwner = string.IsNullOrWhiteSpace(_repoOwner) ? null : _repoOwner;
                Overrides.GitHubRepoName = string.IsNullOrWhiteSpace(_repoName) ? null : _repoName;
                Overrides.GitHubBaseBranch = string.IsNullOrWhiteSpace(_baseBranch) ? null : _baseBranch;
            }
            _savedGithub = _saveErrorGithub is null;
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            _saveErrorGithub = ex.Message;
        }
        finally
        {
            _savingGithub = false;
        }
    }

    // Probe GitHub with the form's token + repo coordinates (nothing has to be saved first).
    // In-process: the same ISourceProvider.ValidateAsync the Spine board-connect flow uses.
    // Split mode: the API's token probe (POST /workspaces/repos) — validates the token's reach.
    private async Task TestGithub()
    {
        _ghTestResult = null;
        if (string.IsNullOrWhiteSpace(_githubPat))
        {
            _ghTestOk = false;
            _ghTestResult = "Enter a token first.";
            return;
        }
        _ghTesting = true;
        try
        {
            if (Split)
            {
                using var client = ApiClient();
                using var resp = await client.PostAsJsonAsync("workspaces/repos",
                    new { kind = "GitHub", accessToken = _githubPat, owner = _repoOwner });
                _ghTestOk = resp.IsSuccessStatusCode;
                _ghTestResult = _ghTestOk
                    ? "Token OK — it can list repositories. (Repo itself not checked in split mode.)"
                    : $"Token rejected (HTTP {(int)resp.StatusCode}).";
            }
            else if (string.IsNullOrWhiteSpace(_repoOwner) || string.IsNullOrWhiteSpace(_repoName))
            {
                _ghTestOk = false;
                _ghTestResult = "Enter the repo owner + name to test against.";
            }
            else
            {
                var descriptor = new WorkspaceDescriptor(
                    Guid.NewGuid(),
                    _tenantId.Length == 0 ? "default" : _tenantId,
                    SourceProviderKind.GitHub,
                    _repoOwner, _repoName, null,
                    string.IsNullOrWhiteSpace(_baseBranch) ? "main" : _baseBranch,
                    _githubPat);
                var result = await SourceProviders.Resolve(SourceProviderKind.GitHub).ValidateAsync(descriptor);
                _ghTestOk = result.Ok;
                _ghTestResult = result.Ok
                    ? $"{_repoOwner}/{_repoName} reachable — default branch {result.DefaultBranch}."
                    : result.Error ?? "Validation failed.";
            }
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            _ghTestOk = false;
            _ghTestResult = ex.Message;
        }
        catch (System.InvalidOperationException ex)
        {
            _ghTestOk = false;
            _ghTestResult = ex.Message;
        }
        finally
        {
            _ghTesting = false;
        }
    }

    private async Task TestConnection()
    {
        _testing = true;
        _testResult = null;
        try
        {
            if (Split)
            {
                using var client = ApiClient();
                using var resp = await client.PostAsync("llm/test", null);
                var body = await resp.Content.ReadFromJsonAsync<LlmTestResult>();
                _testOk = body?.Ok ?? false;
                _testResult = body is { Ok: true }
                    ? $"{body.Provider} · {body.Model}"
                    : (body?.Error ?? $"HTTP {(int)resp.StatusCode}");
            }
            else
            {
                using var _scope = TenantScope();
                var provider = Config["Agents:Orchestrator:Provider"] ?? "Anthropic";
                var model = Config["Agents:Orchestrator:Model"] ?? "claude-haiku-4-5";
                var probe = new LlmRequest("You are a connectivity probe.", "Reply with the single word: OK", model, 0.0, 5);
                _ = await LlmFactory.Create(provider).SendAsync(probe);
                _testOk = true;
                _testResult = $"{provider} · {model}";
            }
        }
        catch (System.InvalidOperationException ex)
        {
            _testOk = false;
            _testResult = ex.Message;
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            _testOk = false;
            _testResult = ex.Message;
        }
        catch (System.Text.Json.JsonException ex)
        {
            _testOk = false;
            _testResult = ex.Message;
        }
        catch (System.TimeoutException ex)
        {
            _testOk = false;
            _testResult = ex.Message;
        }
        finally
        {
            _testing = false;
        }
    }

    private string SaveScopeLabel()
        => Split
            ? "Saved to the API (encrypted, per-tenant store)."
            : $"Saved for tenant {(_tenantId.Length == 0 ? "(local)" : _tenantId)} — encrypted, applied to subsequent LLM calls.";

    private sealed record LlmTestResult(bool Ok, string? Provider, string? Model, string? Sample, string? Error);

    private string EffectiveForceLabel()
    {
        var runtime = Overrides.ForceProvider;
        var appset = LlmOpts.Value.ForceProvider;
        if (!string.IsNullOrWhiteSpace(runtime)) return $"{runtime} (runtime override)";
        if (!string.IsNullOrWhiteSpace(appset))  return $"{appset} (appsettings)";
        return "— none (per-agent config) —";
    }

    private MarkupString KeyState(string key)
        => string.IsNullOrWhiteSpace(key)
            ? new MarkupString("<span class=\"chip chip-err\">not set</span>")
            : new MarkupString("<span class=\"chip chip-ok\">set</span>");
}
