@* SessionsApp — admin surface for the Sessions module: the tenant's paired runners (dev machines)
   and the AI coding sessions they executed. Lists are tenant-wide; the Revoke/Close actions mirror
   the server-side ownership rule (admin OR the row's owner) so a member never sees a button the
   API would refuse. A Blazor Server circuit has no HttpContext, so ITenantContext is blank here —
   we read the tenant + user from AuthenticationState and call repos via tenant-explicit overloads. *@

@using System.Security.Claims
@using AgentOs.Modules.Sessions.Persistence
@using AgentOs.Modules.Sessions.Persistence.Entities
@inject IRunnerRepository Runners
@inject ISessionRepository Sessions
@inject AgentOs.SharedKernel.Persistence.DatabaseAvailability Db
@inject AgentOs.Web.Shell.Services.ToastService Toasts

<header class="page-head">
    <div>
        <h1 class="page-title">Sessions</h1>
        <p class="page-sub">Paired runners and the AI coding sessions they executed.</p>
    </div>
    <Btn OnClick="ReloadAll" Disabled="@(_loading || !Db.IsConfigured)">
        <Icon Name="arrow-clockwise" Size="14" /> Refresh
    </Btn>
</header>

@if (!Db.IsConfigured)
{
    @* Honest degraded mode — without Postgres, revoking/closing would fake-succeed into no-op repos. *@
    <EmptyState Icon="info" Title="Requires a database"
                Hint="Run the full stack (dotnet run --project infra/AgentOs.AppHost) — without Postgres this app would fake-success into no-op repositories." />
}
else if (!_resolved)
{
    <Spinner />
}
else if (_tenantId.Length == 0)
{
    @* Fail-closed (C1 rule): an authenticated principal without a tenant claim is a
       misconfiguration — never fall back to the shared `default` tenant. *@
    <EmptyState Icon="warning" Title="No tenant resolved"
                Hint="Your sign-in carries no tenant claim — check the realm's protocol mappers." />
}
else
{
    <Panel Title="Runners">
        @if (_runners is null) { <Spinner /> }
        else if (_runners.Count == 0)
        {
            <EmptyState Icon="device-mobile" Title="No runners paired"
                        Hint="Pair a dev machine from the Spine app or the VS Code extension." />
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Label</th>
                        <th>Owner</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Last seen</th>
                        <th class="actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _runners)
                    {
                        <tr>
                            <td>@r.Label</td>
                            <td><code>@(string.IsNullOrEmpty(r.OwnerUserId) ? "—" : r.OwnerUserId)</code></td>
                            <td><Chip Variant="@RunnerChip(r.Status)">@r.Status</Chip></td>
                            <td>@r.CreatedAtUtc.ToString("u")</td>
                            <td>@(r.LastSeenUtc?.ToString("u") ?? "—")</td>
                            <td class="actions">
                                @if (CanManage(r.OwnerUserId))
                                {
                                    <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Danger"
                                         OnClick="@(() => OpenRevoke(r))" Disabled="@(r.Status == "Revoked")">
                                        <Icon Name="x" Size="13" /> Revoke
                                    </Btn>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </Panel>

    <Panel Title="Sessions">
        @if (_sessions is null) { <Spinner /> }
        else if (_sessions.Count == 0)
        {
            <EmptyState Icon="clock-counter" Title="No sessions yet"
                        Hint="Sessions appear here once a member starts AI work from a Spine board ticket." />
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Closed</th>
                        <th class="actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _sessions)
                    {
                        <tr>
                            <td>@s.Title</td>
                            <td><Chip Variant="@SessionChip(s.Status)">@s.Status</Chip></td>
                            <td>@s.CreatedAtUtc.ToString("u")</td>
                            <td>@(s.ClosedAtUtc?.ToString("u") ?? "—")</td>
                            <td class="actions">
                                @if (CanManage(s.MemberUserId))
                                {
                                    <Btn Size="Btn.ButtonSize.Sm" Variant="Btn.ButtonVariant.Danger"
                                         OnClick="@(() => OpenClose(s))" Disabled="@(s.Status is "Closed" or "Running")">
                                        <Icon Name="x" Size="13" /> Close
                                    </Btn>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </Panel>
}

@* ── Confirm dialogs (Destructive: only the explicit buttons close them) ───────────────────── *@

<Dialog Show="@(_revokeTarget is not null)" Title="Revoke runner" Destructive="true" OnClose="CancelDialogs">
    <ChildContent>
        <p class="muted">
            Revoke <strong>@_revokeTarget?.Label</strong>? The paired machine loses access immediately
            and must be re-paired before it can run sessions again. This cannot be undone.
        </p>
    </ChildContent>
    <Footer>
        <Btn OnClick="CancelDialogs" Disabled="_actBusy">Cancel</Btn>
        <Btn Variant="Btn.ButtonVariant.Danger" OnClick="ConfirmRevoke" Loading="_actBusy">Revoke</Btn>
    </Footer>
</Dialog>

<Dialog Show="@(_closeTarget is not null)" Title="Close session" Destructive="true" OnClose="CancelDialogs">
    <ChildContent>
        <p class="muted">
            Close <strong>@_closeTarget?.Title</strong>? The session is marked Closed and can no
            longer be run.
        </p>
    </ChildContent>
    <Footer>
        <Btn OnClick="CancelDialogs" Disabled="_actBusy">Cancel</Btn>
        <Btn Variant="Btn.ButtonVariant.Danger" OnClick="ConfirmClose" Loading="_actBusy">Close session</Btn>
    </Footer>
</Dialog>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _resolved;
    private bool _loading;
    private bool _actBusy;

    private string _tenantId = "";
    private string _userId = "";
    private bool _isAdmin;

    private IReadOnlyList<RunnerEntity>? _runners;
    private IReadOnlyList<RemoteSessionEntity>? _sessions;

    // Pending confirmation targets — a non-null target shows its dialog.
    private RunnerEntity? _revokeTarget;
    private RemoteSessionEntity? _closeTarget;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var user = state.User;
            // Fail-closed (C1 rule): no tenant claim → no tenant, never the shared `default`.
            // DevAutoLogin always issues tenant=default, so the standalone dev path is unaffected.
            _tenantId = user.GetTenantId() ?? "";
            _userId = user.GetUserId() ?? "";
            _isAdmin = user.IsAdmin();
        }
        _resolved = true;
        if (!Db.IsConfigured) { return; }   // Degraded mode — the notice replaces all data loads.
        await ReloadAll();
    }

    private async Task ReloadAll()
    {
        if (!Db.IsConfigured || _tenantId.Length == 0) { return; }
        _loading = true;
        try
        {
            _runners = await Runners.ListForTenantAsync(_tenantId);
            _sessions = await Sessions.ListForTenantAsync(_tenantId);
        }
        catch (System.Net.Http.HttpRequestException ex) { HandleLoadError(ex); }
        catch (InvalidOperationException ex) { HandleLoadError(ex); }
        catch (System.IO.IOException ex) { HandleLoadError(ex); }
        catch (TimeoutException ex) { HandleLoadError(ex); }
        finally
        {
            _loading = false;
        }

        void HandleLoadError(Exception ex) =>
            Toasts.Show("Sessions", $"Load failed: {ex.Message}", ToastKind.Err);
    }

    // The UI mirror of the server-side ownership rule: admins manage everything; members manage
    // only their own rows. Never show a button the API would refuse.
    private bool CanManage(string ownerUserId) =>
        _isAdmin || (_userId.Length > 0 && string.Equals(ownerUserId, _userId, StringComparison.Ordinal));

    private void OpenRevoke(RunnerEntity runner) => _revokeTarget = runner;
    private void OpenClose(RemoteSessionEntity session) => _closeTarget = session;

    private void CancelDialogs()
    {
        if (_actBusy) { return; }   // A pending action must finish before the dialog can go away.
        _revokeTarget = null;
        _closeTarget = null;
    }

    private async Task ConfirmRevoke()
    {
        if (_revokeTarget is null || _actBusy) { return; }
        var runner = _revokeTarget;
        _actBusy = true;
        try
        {
            var ok = await Runners.SetStatusForTenantAsync(_tenantId, runner.Id, "Revoked");
            if (ok)
            {
                Toasts.Show("Sessions", $"Revoked runner \"{runner.Label}\".", ToastKind.Ok);
                _runners = await Runners.ListForTenantAsync(_tenantId);
            }
            else
            {
                Toasts.Show("Sessions", "Runner not found — it may have been removed already.", ToastKind.Err);
            }
            _revokeTarget = null;
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Sessions", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Sessions", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Sessions", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Sessions", $"Revoke failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _actBusy = false;
        }
    }

    private async Task ConfirmClose()
    {
        if (_closeTarget is null || _actBusy) { return; }
        var session = _closeTarget;
        _actBusy = true;
        try
        {
            var ok = await Sessions.CloseForTenantAsync(_tenantId, session.Id, DateTimeOffset.UtcNow);
            if (ok)
            {
                Toasts.Show("Sessions", $"Closed \"{session.Title}\".", ToastKind.Ok);
                _sessions = await Sessions.ListForTenantAsync(_tenantId);
            }
            else
            {
                Toasts.Show("Sessions", "Session not found — it may have been removed already.", ToastKind.Err);
            }
            _closeTarget = null;
        }
        catch (System.Net.Http.HttpRequestException ex) { Toasts.Show("Sessions", $"Close failed: {ex.Message}", ToastKind.Err); }
        catch (InvalidOperationException ex) { Toasts.Show("Sessions", $"Close failed: {ex.Message}", ToastKind.Err); }
        catch (System.IO.IOException ex) { Toasts.Show("Sessions", $"Close failed: {ex.Message}", ToastKind.Err); }
        catch (TimeoutException ex) { Toasts.Show("Sessions", $"Close failed: {ex.Message}", ToastKind.Err); }
        finally
        {
            _actBusy = false;
        }
    }

    // Color = state: Paired is healthy, Pending is awaiting first connect, Revoked is dead.
    private static Chip.ChipVariant RunnerChip(string status) => status switch
    {
        "Paired" => Chip.ChipVariant.Ok,
        "Pending" => Chip.ChipVariant.Warn,
        "Revoked" => Chip.ChipVariant.Err,
        _ => Chip.ChipVariant.Default,
    };

    private static Chip.ChipVariant SessionChip(string status) => status switch
    {
        "Done" or "Closed" => Chip.ChipVariant.Ok,
        "Running" or "Active" => Chip.ChipVariant.Info,
        "Failed" => Chip.ChipVariant.Err,
        _ => Chip.ChipVariant.Default,
    };
}
