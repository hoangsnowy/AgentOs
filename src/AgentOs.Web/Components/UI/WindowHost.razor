@* WindowHost — renders every open app window from WindowManagerService. App-agnostic: it resolves the
   component from the AppCatalog registry (built-ins + plugins alike) via DynamicComponent, so the shell
   never names a specific app. Adding/removing an app is a registry edit, not a shell change. *@

@using AgentOs.Web.Services
@implements IDisposable
@inject WindowManagerService WM

@foreach (var w in WM.Open.Where(w => !w.Minimized))
{
        <AppFrame W="@w" @key="w.Id">
            @if (AppCatalog.Find(w.AppKey)?.ComponentType is { } appComponent)
            {
                <DynamicComponent Type="appComponent" />
            }
            else
            {
                <div class="appwin-blank">Unknown app: <code>@w.AppKey</code></div>
            }
        </AppFrame>
}

@code {
    protected override void OnInitialized()
    {
        WM.Changed += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => WM.Changed -= OnChanged;
}
