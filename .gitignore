# ---------------------------------------------------------------------------
# .gitignore — agentos (.NET 10)
# ---------------------------------------------------------------------------

# Build outputs
**/bin/
**/obj/
**/out/
**/publish/
# Self-contained runner exe served by the Web for the VS Code extension (built by scripts/build-runner.ps1)
src/AgentOs.Web/runner-dist/
# Runtime plugin drop folders (built by scripts/build-plugins.ps1; plugin SOURCE lives in samples/)
src/AgentOs.Api/plugins/
src/AgentOs.Web/plugins/
**/*.binlog
**/*.tlog

# User / IDE artifacts
**/.vs/
**/*.user
**/*.suo
**/*.userosscache
**/*.sln.docstates
**/.idea/
**/.vscode/*
!**/.vscode/launch.json
!**/.vscode/tasks.json
!**/.vscode/extensions.json

# Rider
**/.idea/

# App runtime data (orchestration seed is regenerated at startup)
**/App_Data/

# Cache and temp
**/TestResults/
**/coverage/
**/*.coverage
**/*.coveragexml
**/*.lcov
**/.cache/
**/Temp/

# NuGet
**/.nuget/
**/packages/
**/project.lock.json
**/project.fragment.lock.json
**/artifacts/

# Secrets — NEVER commit
**/appsettings.Development.json
**/appsettings.Local.json
**/.env
**/.env.*
**/secrets.json
**/*.pfx
**/*.key
**/*.pem

# OS
.DS_Store
Thumbs.db

# Logs
**/*.log
**/logs/

# Claude Code — commit skills + settings, do NOT commit ephemeral worktrees / cache
.claude/worktrees/
.claude/cache/
.claude/sessions/
.claude/.session-env/

# Aspire manifest-publish artifacts (regenerated by azd on every deploy)
infra/AgentOs.AppHost/*.module.bicep
infra/AgentOs.AppHost/aspire-manifest.json
